<h1 class="text-2xl font-bold mb-6">Puzzeltochten</h1>

<a href="/admin-puzzles/new"
class="bg-blue-600 text-white px-4 py-2 rounded">
Nieuwe puzzeltocht
</a>

<div class="mt-6 space-y-3">

<% puzzles.forEach(p => { %>

<a
href="/admin-builder/<%= p._id %>"
class="block border p-4 rounded"
>

<%= p.name %>

</a>

<a href="/admin-puzzles/export/<%= puzzle._id %>" class="btn" style="background-color: #10b981; margin-left: 10px;">💾 Backup (JSON)</a>

<% }) %>

</div>
