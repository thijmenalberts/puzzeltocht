<h1 class="text-2xl font-bold mb-6">Puzzeltochten</h1>

<a href="/admin-puzzles/new" class="bg-blue-600 text-white px-4 py-2 rounded">
  Nieuwe puzzeltocht
</a>

<div class="mt-6 space-y-3">
  <% puzzles.forEach(p => { %>
    <div class="flex items-center space-x-2">
      <a href="/admin-builder/<%= p._id %>" class="block border p-4 rounded flex-1">
        <%= p.name %>
      </a>
      
      <a href="/admin-puzzles/export/<%= p._id %>" class="btn" style="background-color: #10b981; color: white; padding: 10px; border-radius: 8px; text-decoration: none;">
        💾 Backup
      </a>
    </div>
  <% }) %>
</div>

<div style="margin-top: 40px; padding: 25px; border: 2px dashed #6366f1; background: #f8fafc; border-radius: 12px;">
  <h3 style="margin-top: 0; color: #1e293b; font-weight: bold;">
    📥 Puzzeltocht Importeren
  </h3>
  <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 20px;">
    Selecteer een <strong>.json</strong> backup bestand om een puzzel te herstellen.
  </p>
  
  <form action="/admin-puzzles/import" method="POST" enctype="multipart/form-data">
    <input type="file" name="file" accept=".json" required 
           style="padding: 10px; background: white; border: 1px solid #cbd5e1; border-radius: 6px; width: 100%; margin-bottom: 15px;">
    
    <button type="submit" style="background-color: #6366f1; color: white; font-weight: bold; border: none; padding: 12px 24px; border-radius: 6px; cursor: pointer; width: 100%;">
      🚀 Start Import
    </button>
  </form>
</div>
