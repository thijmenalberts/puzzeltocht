<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Puzzeltocht</title>

  <!-- TailwindCSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <style>

    /* Floating Score Animatie  */
.score-float {
  position: fixed;
  top: 40%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 4rem;
  font-weight: 900;
  color: #10b981;
  pointer-events: none;
  z-index: 10000;
  text-shadow: 0 0 20px rgba(16, 185, 129, 0.4);
  animation: floatAndFade 1.8s ease-out forwards;
}

@keyframes floatAndFade {
  0% { opacity: 0; transform: translate(-50%, -50%) scale(0.5); }
  20% { opacity: 1; transform: translate(-50%, -50%) scale(1.2); }
  100% { opacity: 0; transform: translate(-50%, -150%) scale(1.5); }
}

/* Typing Indicator Styling [cite: 32] */
.typing-indicator {
  display: flex;
  gap: 4px;
  padding: 10px 15px;
  background: #f3f4f6;
  border-radius: 12px 12px 12px 0;
  width: fit-content;
  margin-bottom: 10px;
}
.typing-dot {
  width: 6px;
  height: 6px;
  background: #9ca3af;
  border-radius: 50%;
  animation: typingBlink 1.4s infinite both;
}
.typing-dot:nth-child(2) { animation-delay: 0.2s; }
.typing-dot:nth-child(3) { animation-delay: 0.4s; }
@keyframes typingBlink { 0%, 100% { opacity: 0.2; } 50% { opacity: 1; } }
    :root{
      --primary: <%= theme?.primaryColor || '#2563eb' %>;
      --bg: <%= theme?.backgroundColor || '#ffffff' %>;
      --text: <%= theme?.textColor || '#111827' %>;
      --radius: <%= theme?.borderRadius || '0.75rem' %>;
      --font: <%= theme?.fontFamily || 'Inter, ui-sans-serif, system-ui' %>;
    }
    body{
      background: var(--bg);
      color: var(--text);
      font-family: var(--font);
    }
    .btn-primary{
      background: var(--primary);
      color: #fff;
      border-radius: var(--radius);
    }
    .card{
      background: #ffffffcc;
      backdrop-filter: blur(6px);
      border-radius: var(--radius);
    }
    a.link { color: var(--primary); }
  </style>
</head>

<body class="min-h-screen">

  <!-- Navigatie -->
  <% var isImmersiveView = typeof pageIndex !== 'undefined'; %>
  <% if (!isImmersiveView) { %>
  <header class="sticky top-0 z-30 bg-white/80 backdrop-blur border-b">
    <nav class="mx-auto max-w-md px-4 h-14 flex items-center justify-between">
      <a href="/" class="font-semibold text-lg">Puzzeltocht</a>
    </nav>
  </header>
  <% } %>

  <!-- Pagina-inhoud -->
  <% if (typeof builderPage !== "undefined" && builderPage === true) { %>

      <!-- BUILDER FULL WIDTH -->
      <main class="w-full h-[calc(100vh-56px)] p-0 m-0">
        <%- body %>
      </main>

  <% } else { %>

      <!-- STANDAARD PAGINA (max 450px breed) -->
      <main class="mx-auto max-w-md px-4 py-6">
        <%- body %>
      </main>

  <% } %>

  <script src="/app.js"></script>
</body>
</html>
