<style>
  body {
    max-width: none !important;
  }

  main, .container {
    max-width: none !important;
    width: 100% !important;
  }
</style>

<section class="max-w-screen-xl mx-auto p-10">

  <!-- Header -->
  <div class="flex justify-between items-center mb-12">
    <h1 class="text-3xl font-black text-gray-900">📂 Mediabeheer</h1>
    <a href="/admin-dashboard"
       class="bg-gray-100 hover:bg-gray-200 text-gray-600 px-5 py-2 rounded-lg font-bold transition">
      ← Dashboard
    </a>
  </div>

  <!-- Mappen -->
  <div class="grid grid-cols-3 md:grid-cols-4 xl:grid-cols-6 gap-8">

    <% folders.forEach(folder => { %>
      <a href="/admin-files/<%= folder.name %>"
         class="group bg-white border border-gray-200 rounded-2xl p-6 text-center
                shadow-sm hover:border-indigo-300 hover:shadow-md transition">

        <div class="text-6xl mb-4">📁</div>

        <p class="font-black text-gray-800 break-all">
          <%= folder.name %>
        </p>
      </a>
    <% }) %>

    <% if (hasRootFiles) { %>
      <a href="/admin-files/__root__"
         class="group bg-white border border-gray-200 rounded-2xl p-6 text-center
                shadow-sm hover:border-indigo-300 hover:shadow-md transition">

        <div class="text-6xl mb-4">📁</div>

        <p class="font-black text-gray-800">
          Overige bestanden
        </p>
      </a>
    <% } %>

  </div>

</section>
