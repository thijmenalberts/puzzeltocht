<section class="space-y-6">

<h1 class="text-2xl font-bold">Admin Dashboard</h1>

<!-- Puzzeltochten -->

<div class="card p-4 border bg-blue-50">
  <h2 class="font-semibold mb-3 text-blue-800">📍 Airtable Koppeling</h2>
  <p class="text-xs text-blue-600 mb-4">Koppel een Airtable naam aan een puzzeltocht.</p>
  
  <form action="/admin/map-airtable" method="POST" class="space-y-3">
    <div>
      <label class="text-xs font-bold text-gray-500 uppercase">Naam in Airtable:</label>
      <input type="text" name="airtableString" placeholder="Bijv: Borger" required class="border p-2 rounded w-full"/>
    </div>
    
    <div>
      <label class="text-xs font-bold text-gray-500 uppercase">Koppel aan Puzzeltocht:</label>
      <select name="internalId" required class="border p-2 rounded w-full bg-white">
        <option value="">-- Selecteer een puzzel --</option>
        <% puzzles.forEach(puz => { %>
          <option value="<%= puz._id %>"><%= puz.name %></option>
        <% }) %>
      </select>
    </div>
    
    <button class="bg-blue-600 text-white px-4 py-2 rounded w-full font-bold">Koppeling Opslaan</button>
  </form>

  <% if (mappings && mappings.length > 0) { %>
    <div class="mt-4 pt-4 border-t border-blue-200">
      <h3 class="text-xs font-bold text-blue-800 mb-2 uppercase">Actieve Koppelingen:</h3>
      <% mappings.forEach(m => { %>
        <div class="flex justify-between text-sm py-1 border-b border-blue-100 italic text-gray-600">
          <span><%= m.airtableString %></span>
          <span>➜ <%= m.internalPuzzleId ? m.internalPuzzleId.name : 'Puzzel verwijderd' %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>


<!-- Theme -->

<a class="block p-4 border rounded card hover:ring-2 ring-blue-200" href="/admin-theme">
<h2 class="font-semibold mb-1">Thema aanpassen</h2>
<p class="text-sm text-gray-600">Pas kleuren en design aan.</p>
</a>

<a
  class="block p-4 border rounded card hover:ring-2 ring-blue-200"
  href="/admin-files"
>
  <h2 class="font-semibold mb-1">Bestanden</h2>
  <p class="text-sm text-gray-600">
    Bekijk alle geüploade bestanden per map.
  </p>
</a>

<!-- Code toevoegen -->

<div class="card p-4 border">

<h2 class="font-semibold mb-3">Code toevoegen</h2>

<form action="/admin-add-code" method="POST" class="space-x-2">

<input
type="text"
name="code"
placeholder="Code"
required
class="border p-2 rounded"
/>

<select name="type" class="border p-2 rounded">
<option value="user">User</option>
<option value="admin">Admin</option>
</select>

<button class="bg-blue-600 text-white px-4 py-2 rounded">
Toevoegen
</button>

</form>

</div>



<!-- CSV upload -->

<div class="card p-4 border">

<h2 class="font-semibold mb-3">CSV upload (meerdere codes)</h2>

<form action="/admin-upload-csv" method="POST" enctype="multipart/form-data">

<input type="file" name="csvfile" accept=".csv" required>

<button class="bg-green-600 text-white px-4 py-2 rounded ml-2">
Upload CSV
</button>

</form>

<p class="text-sm text-gray-600 mt-3">
CSV formaat:
</p>

<pre class="bg-gray-100 p-3 rounded text-sm">
code,type
TEST123,user
ADMIN999,admin
CODE456,user
</pre>

</div>

</section>
