<section class="space-y-6">
  <h1 class="text-2xl font-bold">Admin Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <a class="block p-4 border rounded card hover:ring-2 ring-blue-200 bg-white" href="/admin-puzzles">
      <h2 class="font-semibold mb-1">Puzzeltochten</h2>
      <p class="text-sm text-gray-600">Maak en beheer puzzeltochten.</p>
    </a>

    <a class="block p-4 border rounded card hover:ring-2 ring-yellow-200 bg-yellow-50" href="/admin/feedback">
      <h2 class="font-semibold mb-1 text-yellow-800">⭐ Bekijk Feedback</h2>
      <p class="text-sm text-yellow-600">Lees wat teams van de tochten vonden.</p>
    </a>
  </div>

  <div class="card p-6 border bg-blue-50 rounded-xl">
    <h2 class="font-bold mb-3 text-blue-800 flex items-center gap-2">📍 Airtable Koppeling</h2>
    <form action="/admin/map-airtable" method="POST" class="space-y-4">
      <div>
        <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Naam in Airtable (kolom 'Puzzeltocht'):</label>
        <input type="text" name="airtableString" placeholder="Bijv: Borger" required class="border p-2 rounded w-full"/>
      </div>
      <div>
        <label class="text-xs font-bold text-gray-500 uppercase block mb-1">Koppel aan interne Puzzel:</label>
        <select name="internalId" required class="border p-2 rounded w-full bg-white">
          <option value="">-- Selecteer een puzzel --</option>
          <% puzzles.forEach(puz => { %>
            <option value="<%= puz._id %>"><%= puz.name %></option>
          <% }) %>
        </select>
      </div>
      <button class="bg-blue-600 text-white px-4 py-2 rounded w-full font-bold hover:bg-blue-700">Koppeling Opslaan</button>
    </form>

    <% if (mappings && mappings.length > 0) { %>
      <div class="mt-6 pt-4 border-t border-blue-200">
        <h3 class="text-xs font-bold text-blue-800 mb-2 uppercase">Huidige Koppelingen:</h3>
        <div class="space-y-2">
          <% mappings.forEach(m => { %>
            <div class="flex justify-between text-sm p-2 bg-white rounded border border-blue-100 shadow-sm">
              <span class="font-medium"><%= m.airtableString %></span>
              <span class="text-blue-600">➜ <%= m.internalPuzzleId ? m.internalPuzzleId.name : 'Puzzel verwijderd' %></span>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <a class="block p-4 border rounded card hover:ring-2 ring-gray-200 bg-white" href="/admin-theme">
      <h2 class="font-semibold mb-1">Thema aanpassen</h2>
    </a>
    <a class="block p-4 border rounded card hover:ring-2 ring-gray-200 bg-white" href="/admin-files">
      <h2 class="font-semibold mb-1">Bestanden</h2>
    </a>
  </div>
</section>
