<!DOCTYPE html>
<html lang="<%= lang || puzzle.defaultLanguage || 'nl' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
  
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

<style>
  <% 
    const theme = puzzle.theme?.preset || 'standard'; 
    const primary = puzzle.theme?.primaryColor || '#0066cc';
    const bgMap = {
      standard: "linear-gradient(135deg, #667eea 0%, #764ba2 100%)",
      medieval: "url('https://www.transparenttextures.com/patterns/aged-paper.png'), #d4b483",
      future: "linear-gradient(135deg, #0f2027 0%, #203a43 50%, #2c5364 100%)",
      iceage: "linear-gradient(to bottom, #e0eafc, #cfdef3)",
      caveman: "url('https://www.transparenttextures.com/patterns/stucco.png'), #57534e"
    };
    const defaultBg = "linear-gradient(135deg, #667eea 0%, #764ba2 100%)";
  %>

  :root { 
    --primary: <%= primary %>; 
    --bg-layer: <%- bgMap[theme] || defaultBg %>;
    --text-main: <%= ['standard', 'future', 'caveman'].includes(theme) ? '#f8fafc' : '#1e293b' %>;
    --glass-bg: <%= ['standard', 'future', 'caveman'].includes(theme) ? 'rgba(255, 255, 255, 0.15)' : 'rgba(255, 255, 255, 0.4)' %>;
    --glass-border: <%= ['standard', 'future', 'caveman'].includes(theme) ? 'rgba(255, 255, 255, 0.3)' : 'rgba(255, 255, 255, 0.6)' %>;
    --glass-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
    --chat-bg: #f8fafc;
    --chat-header-bg: #e2e8f0;
    --chat-header-text: #1e293b;
    --chat-text-ai: #334155;
    --chat-bubble-ai: #f1f5f9;
    --chat-bubble-user: var(--primary);
    --chat-text-user: #ffffff;
  }

  /* BASIS RESET */
  * { box-sizing: border-box; margin: 0; padding: 0; }
  
  body { 
    background: var(--bg-layer);
    background-size: cover;
    background-attachment: fixed;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--text-main);
    min-height: 100vh;
    overflow-x: hidden;
    padding-bottom: 60px;
    transition: background 0.5s ease;
  }

  /* GLASSMORPHISM MODULES */
  .module {
    background: var(--glass-bg);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 20px;
    border: 1px solid var(--glass-border);
    padding: 30px 25px;
    margin: 20px auto 35px auto;
    max-width: 600px;
    width: 90%;
    box-shadow: var(--glass-shadow);
    text-align: center;
    position: relative;
    animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) backwards;
  }

  @keyframes slideUpFade { 
    0% { opacity: 0; transform: translateY(30px); } 
    100% { opacity: 1; transform: translateY(0); } 
  }

  @keyframes floatPulse {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-5px); }
  }

  h2.title-module {
    font-size: 28px; 
    font-weight: 700;
    margin-bottom: 10px;
    text-shadow: 0 2px 4px rgba(0,0,0,0.3);
  }

  p { font-size: 16px; line-height: 1.6; margin-bottom: 15px; }

  /* Knoppen - Modern, met hover effecten */
  .btn {
    display: block; width: 100%; padding: 16px; margin: 15px 0;
    background: var(--glass-bg);
    backdrop-filter: blur(5px);
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    color: var(--text-main);
    font-family: inherit; font-weight: 600; font-size: 16px;
    text-transform: uppercase; letter-spacing: 0.5px; 
    cursor: pointer; transition: all 0.2s ease;
    box-shadow: 0 4px 15px rgba(0,0,0,0.05);
  }
  .btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0,0,0,0.15);
    background: rgba(255, 255, 255, 0.1);
  }
  .btn:active {
    transform: translateY(1px) scale(0.98);
  }
  .btn.accent { 
    background-color: var(--primary); 
    color: #fff;
    border: none;
    box-shadow: 0 4px 15px var(--primary);
  }
  .btn.accent:hover {
    opacity: 0.9;
  }

  /* Invoervelden */
  input[type="text"], input[type="email"], input[type="number"], select, textarea {
    width: 100%; padding: 14px; margin-bottom: 15px;
    background: rgba(255, 255, 255, 0.1); 
    border: 1px solid var(--glass-border); 
    border-radius: 12px;
    color: #fff; 
    font-size: 16px; font-family: sans-serif;
    outline: none; transition: border 0.3s;
  }
  input:focus, textarea:focus {
    border-color: var(--primary);
    box-shadow: 0 0 0 3px rgba(255, 255, 255, 0.2);
  }
  input::placeholder, textarea::placeholder { color: inherit; opacity: 0.7; }
  
  /* Meerkeuze Opties */
  .mc-option {
    display: block; padding: 14px; text-align: left;
    background: rgba(255, 255, 255, 0.05); border-radius: 12px; margin-bottom: 10px;
    border: 1px solid var(--glass-border); cursor: pointer; transition: all 0.2s;
  }
  .mc-option:hover {
    background: rgba(255, 255, 255, 0.1);
  }
  .mc-option input[type="radio"] { display: none; }
  .mc-option:has(input:checked) { 
    background: var(--primary); 
    color: white; 
    border-color: var(--primary);
    box-shadow: 0 4px 15px rgba(0,0,0,0.1);
  }

  /* Status / Score Tag bovenaan */
  .stone-tag {
    display: inline-block; padding: 10px 24px; 
    background: var(--glass-bg);
    backdrop-filter: blur(12px);
    border-radius: 0 0 20px 20px; 
    border: 1px solid var(--glass-border); 
    border-top: none; font-weight: 600; 
    box-shadow: var(--glass-shadow);
    animation: floatPulse 4s ease-in-out infinite;
  }

  </style>
</head>

<body>

<%
  if (!page) return;
  var activeLanguage = lang || puzzle.defaultLanguage || "nl";
  var fallback = puzzle.defaultLanguage || "nl";
  var t = (value) => typeof value === "string" ? value : value?.[activeLanguage] || value?.[fallback] || "";
%>

<!-- Bovenste status (als stenen label) -->
<div style="text-align: center; margin-bottom: 20px;">
  <div class="stone-tag">
    <span style="opacity:0.7;">Team: <%= session?.teamName || 'Gast' %></span> | 
    <span style="color: #fbbf24;">Punten: <span id="ui-score"><%= session?.totalScore || 0 %></span></span>
  </div>
</div>

<div id="artifact-viewport">

<% if (typeof isCompleted !== 'undefined' && isCompleted) { %>
  <div style="background: #e5e7eb; color: #4b5563; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold; border: 2px dashed #9ca3af;">
    🔒 Je bekijkt een oude pagina. Vragen beantwoorden is uitgeschakeld.
  </div>
<% } %>

<% if (page.playSoundOnStart && page.soundUrl) { %>
<script>
  new Audio("<%= page.soundUrl %>").play().catch(()=>{ console.warn("Autoplay geblokkeerd"); });
</script>
<% } %>

<% if (page.isMap) { %>
  <div class="module" style="padding: 10px;">
    <div id="map"></div>
    <div class="feedback" id="mapFeedback" style="padding: 15px; font-weight: bold; color: #d6d3d1;">Locatie bepalen...</div>
  </div>
<% } %>

<% (page.modules || []).forEach((mod, qIndex) => { %>
  <% var mData = mod.data || {}; %>
  <% var qId = "q-" + pageIndex + "-" + qIndex; %>

  <% if (mod.type === "title") { %>
    <div class="module" style="background: transparent; border: none; box-shadow: none; padding-bottom: 0;">
      <h2 class="title-module"><%= t(mData.title) %></h2>
    </div>
  <% } %>

  <% if (mod.type === "text") { %>
    <div class="module">
      <p><%- t(mData.text) %></p>
    </div>
  <% } %>

  <% if (mod.type === "image") { %>
    <div class="module" style="padding: 15px;">
      <img src="<%= mData.url || '' %>" style="width: 100%; border-radius: 10px; display: block; filter: sepia(0.3);" onclick="openImage(this.src)">
    </div>
  <% } %>

  <% if (mod.type === "audio") { %>
    <div class="module">
      <p style="font-weight: bold; color: #d6d3d1;">Geluidsfragment</p>
      <audio controls preload="none" style="width:100%;"><source src="<%= mData.url || '' %>"></audio>
    </div>
  <% } %>

  <% if (mod.type === "team-name") { %>
    <div class="module">
      <h3 style="margin-bottom:15px; color:#fbbf24;">Start de Tocht</h3>
      <input type="text" id="team-name-input" class="no-lock" placeholder="Kies een teamnaam" value="<%= session?.teamName || '' %>">
      <input type="email" id="team-email-input" class="no-lock" placeholder="E-mail (voor uitslag)" value="<%= session?.teamEmail || '' %>">
      <button class="btn accent no-lock" onclick="saveTeamName()">Starten</button>
      <div class="feedback" id="teamname-feedback" style="margin-top: 10px;"></div>
    </div>
  <% } %>

  <% if (mod.type === "photo") { %>
    <div class="module">
      <h3 style="margin-bottom:15px; color:#d6d3d1;">Foto Opdracht</h3>
      <input type="file" accept="image/*" capture="environment" onchange="uploadPhoto(this,<%=pageIndex%>,<%=qIndex%>)" style="padding: 0; border: none;">
      <input type="hidden" id="photo-url-<%=pageIndex%>-<%=qIndex%>" value="<%= mData.url || '' %>">
      <div class="feedback" id="photo-feedback-<%=pageIndex%>-<%=qIndex%>"></div>
      <% if (mData.url) { %><img src="<%= mData.url %>" class="photo-preview" onclick="openImage(this.src)"><% } %>
      <button class="btn secondary" style="margin-top:15px;" onclick="setAsTeamPhoto(document.getElementById('photo-url-<%=pageIndex%>-<%=qIndex%>').value)">Stel in als profielfoto</button>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <% 
      var isTimed = mData.isTimed === "true" || mData.isTimed === true; 
      var limit = Number(mData.timeLimit) || 60;
      var maxPts = Number(mData.maxPoints) || 10;
      var pSec = Number(mData.penaltySec) || 10;
      var pPts = Number(mData.penaltyPoints) || 1;
      var qTextClean = t(mData.question).replace(/'/g, "\\'");
    %>
    
    <% if (isTimed) { %>
      <div id="prep-screen-<%= qIndex %>" class="module" style="border-color: #f59e0b; text-align: center;">
        <h3 style="color: #f59e0b; font-weight: 300;">[ TIME CRITICAL ]</h3>
        <p>Je hebt <%= limit %>s voordat de data vervalt.</p>
        <button class="btn accent" style="background: #f59e0b;" onclick="startTimedChallenge('<%= qIndex %>', '<%= qId %>', <%= limit %>, <%= pSec %>, <%= pPts %>, <%= maxPts %>)">[ INITIATE OVERRIDE ]</button>
      </div>
    <% } %>

    <div class="module" id="question-content-<%= qIndex %>" style="<%= isTimed ? 'display:none;' : '' %>">
      <% if (isTimed) { %>
        <div style="display: flex; justify-content: space-between; color: #f59e0b; font-family: monospace; margin-bottom: 20px; border-bottom: 1px solid rgba(245, 158, 11, 0.3); padding-bottom: 10px;">
          <span>T:<span id="timer-clock-<%= qIndex %>">00:00</span></span>
          <span>YLD:<span id="timer-pts-<%= qIndex %>"><%= maxPts %></span></span>
        </div>
      <% } %>
      
      <strong style="display:block; margin-bottom: 20px; font-size:18px;"><%= t(mData.question) %></strong>

      <% if (mData.questionType === "mc") { %>
        <div id="form-<%= qIndex %>" data-good="<%= mData.goodPage ?? '' %>" data-bad="<%= mData.badPage ?? '' %>" data-puzzle="<%= puzzle._id %>">
          <% (mData.options || []).forEach((opt,i)=>{ %>
            <label class="mc-option">
              <input type="radio" name="mc-<%=qIndex%>" value="<%= !!opt.correct %>"> 
              <span>> <%= t(opt.text) %></span>
            </label>
          <% }) %>
          <button class="btn secondary" style="margin-top:15px;" onclick="verifyMC(this, '<%= qIndex %>', '<%= qId %>', <%= maxPts %>, <%= limit %>, <%= pSec %>, <%= pPts %>, <%= isTimed %>, '<%= qTextClean %>')">[ VERIFY ]</button>
          <div class="feedback" id="fb-<%= qIndex %>"></div>
        </div>
      <% } else { %>
        <div id="form-<%= qIndex %>">
          <input type="text" id="open-ans-<%= qIndex %>" placeholder="> Voer input in...">
          <input type="hidden" id="open-correct-<%= qIndex %>" value="<%= t(mData.answer) %>">
          <input type="hidden" id="good-<%= qIndex %>" value="<%= mData.goodPage ?? '' %>">
          <input type="hidden" id="bad-<%= qIndex %>" value="<%= mData.badPage ?? '' %>">
          <button class="btn secondary" style="margin-top:10px;" onclick="verifyOpen(this, '<%= qIndex %>', '<%= qId %>', <%= maxPts %>, <%= limit %>, <%= pSec %>, <%= pPts %>, <%= isTimed %>, '<%= qTextClean %>')">[ VERIFY ]</button>
          <div class="feedback" id="fb-<%= qIndex %>"></div>
        </div>
      <% } %>

      <% if (Number(mData.hintCost) > 0) { %>
         <div class="hint-container" style="margin-top: 25px; border-top: 1px solid rgba(255,255,255,0.1); padding-top: 15px;">
           <button class="btn secondary" style="font-size: 12px; padding: 10px;" onclick="document.getElementById('hint-box-<%= qIndex %>').style.display='block'; this.style.display='none';">
             [ REQUEST ASSISTANCE (-<%= mData.hintCost %> CRDT) ]
           </button>
           
           <div id="hint-box-<%= qIndex %>" style="display:none;">
              <% if (mData.hintType === 'static') { %>
                <button class="btn accent" onclick="executeStaticHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.staticHintText) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">[ DECRYPT STATIC LOG ]</button>
              <% } else { %>
                <div style="display:flex; flex-direction:column; gap:10px;">
                  <input type="text" id="hint-in-<%= qIndex %>" placeholder="> Query details...">
                  <button class="btn accent" onclick="executeAiHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.aiKnowledge) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">[ QUERY AI CORE ]</button>
                </div>
              <% } %>
              <div id="hint-res-<%= qIndex %>" style="margin-top: 12px; font-family: monospace; color: var(--accent);"></div>
           </div>
         </div>
      <% } %>

    </div>
  <% } %>

  <% if (mod.type === 'aiphoto') { %>
    <div class="module" id="ai-mod-<%= qIndex %>" data-prompt="<%= t(mData.prompt) %>" data-maxpoints="<%= mData.points || 10 %>">
      <h3 style="margin-top: 0; color: #fbbf24;">Foto Beoordeling</h3>
      <p><%= t(mData.instruction) %></p>
      
      <input type="file" accept="image/*" capture="environment" class="ai-file-input" style="display: none;">
      <button type="button" class="btn accent ai-camera-btn">Maak Foto & Controleer</button>
      
      <div class="ai-status feedback" style="display: none; margin-top:15px; font-weight:bold;"></div>
      <img class="ai-preview" style="display: none; width: 100%; border-radius: 10px; margin-top: 15px; border: 2px solid #1c1917;">
    </div>
  <% } %>

<% if (mod.type === 'historychat') { %>
  <div class="module" data-maxturns="<%= mData.maxTurns || 3 %>">
    <div style="border-bottom: 1px solid rgba(0,0,0,0.3); padding-bottom: 10px; margin-bottom: 15px;">
        <strong style="display: block; font-size: 18px; color: #fbbf24;">Personage: <%= t(mData.characterName) %></strong>
    </div>
    <div id="chat-win-<%= qIndex %>" style="height: 250px; overflow-y: auto; display: flex; flex-direction: column; gap: 10px; text-align: left; padding-right: 5px;">
      <div style="color: #a3e635; align-self: flex-start; max-width: 85%;">Verbonden...</div>
      
      <div id="typing-indicator-<%= qIndex %>" style="display: none; opacity: 0.6; font-style: italic;">
        Aan het typen...
      </div>
    </div>
    <div style="margin-top: 15px; display: flex; gap: 10px;">
      <input type="text" id="chat-input-<%= qIndex %>" placeholder="Stel een vraag..." style="margin:0; flex:1;">
      <button id="chat-btn-<%= qIndex %>" class="btn secondary" style="width: auto; padding: 0 20px; margin:0;">Stuur</button>
    </div>
  </div>
<% } %>

  <% if (mod.type === 'feedback') { %>
    <div class="module" style="text-align: center;">
      <h2 style="margin-bottom: 10px;">Einde van de Puzzeltocht</h2>
      <p>Hoe vonden jullie het? Schrijf hier jullie reactie (leuk voor de AI!).</p>
      
      <textarea id="finale-feedback" rows="4" placeholder="Typ hier..."></textarea>
      
      <button id="btn-finale" class="btn accent" onclick="triggerFinale('<%= puzzle._id %>')">
        Afronden & Verslag Maken
      </button>

      <div id="finale-loading" style="display: none; margin-top: 20px; font-style: italic;">
        Verwerken... Een moment geduld alstublieft.
      </div>

      <div id="finale-result" style="display: none; margin-top: 25px; text-align: left;">
        <h3 style="border-bottom: 1px solid rgba(255,255,255,0.2); padding-bottom: 10px; margin-bottom:15px; color:#fbbf24;">Eindverslag</h3>
        <div id="finale-text" style="line-height: 1.7; font-size: 16px; margin-bottom: 20px; white-space: pre-wrap;"></div>
        
        <div style="border: 2px solid #292524; background: rgba(0,0,0,0.2); border-radius: 10px; padding: 20px; text-align: center; margin-bottom: 20px;">
          <strong style="display: block; font-size: 14px; text-transform: uppercase; letter-spacing: 1px; color: #a3e635;">Eindscore</strong>
          <div style="font-size: 48px; font-weight: bold; line-height: 1; margin: 10px 0; color: #fff;"><span id="finale-score">0</span></div>
          <div style="font-size: 14px; opacity:0.8;">Tijd: <span id="finale-time">0</span> min</div>
        </div>

        <a href="/leaderboard/<%= puzzle._id %>" class="btn secondary" style="text-decoration: none;">Bekijk Leaderboard</a>
      </div>
    </div>
  <% } %>

<% }) %> 

<!-- SENSOR HUD: Visualiseert de hardware triggers -->
<% if (page.triggers && page.triggers.length > 0) { %>
  <div class="module" style="text-align: center;">
     <p style="font-size: 14px; font-weight: bold; color: #fbbf24;">Kompas & Sensoren Actief</p>
     
     <% const hasCompass = page.triggers.find(t => t.type === 'orientation'); %>
     <% if (hasCompass) { %>
        <div class="compass-ring" id="ui-compass" style="margin: 15px auto;"></div>
        <p style="font-size:12px; margin-top:15px;">Kalibreer de richting...</p>
     <% } %>

     <% const hasMic = page.triggers.find(t => t.type === 'speech_match'); %>
     <% if (hasMic) { %>
        <div class="mic-waves" style="display:none; justify-content:center; margin: 15px auto;" id="ui-mic"><span></span><span></span><span></span><span></span><span></span></div>
        <p style="font-size:12px; margin-top:15px;" id="ui-mic-text">Wachten op stem-input...</p>
     <% } %>
  </div>
<% } else if (page.showNext && pageIndex + 1 < puzzle.pages.length) { %>
  <!-- Fallback als er geen hardware triggers zijn maar we wel door mogen -->
  <a class="btn secondary no-lock" href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>" style="text-decoration:none;">Volgende</a>
<% } %>

</div> <!-- End Artifact Viewport -->

<div class="img-overlay" id="imgOverlay" onclick="this.style.display='none'"><img id="overlayImg"></div>

<script>
// =========================================
// HUD SENSOR LOGICA (Luistert naar ArtifactEngine)
// =========================================
window.addEventListener('sensor-compass-update', (e) => {
    const ring = document.getElementById('ui-compass');
    if(ring) {
        // Draai de ring visueel mee
        ring.style.transform = `rotate(${-e.detail.degrees}deg)`;
        // Als je in de buurt komt, geef een glow!
        if(e.detail.targetDiff < 20) {
            ring.style.boxShadow = '0 0 20px var(--accent), inset 0 0 20px var(--accent)';
            ring.style.borderColor = 'var(--accent)';
        } else {
            ring.style.boxShadow = 'none';
            ring.style.borderColor = 'rgba(255,255,255,0.1)';
        }
    }
});

window.addEventListener('sensor-mic-status', (e) => {
    const mic = document.getElementById('ui-mic');
    const txt = document.getElementById('ui-mic-text');
    if(mic) { mic.style.display = 'flex'; txt.innerText = "Luisteren naar commando..."; }
});

// =========================================
// REST VAN DE STANDAARD FUNCTIES (Aangepast aan Dark Theme)
// =========================================

function openImage(src){ document.getElementById("overlayImg").src = src; document.getElementById("imgOverlay").style.display = "flex"; }
function updateGlobalScore(newScore) {
  const el = document.getElementById("ui-score");
  if(el) {
    const oldScore = parseInt(el.innerText || 0);
    const difference = newScore - oldScore;
    
    if(difference > 0) {
      // Speel animatie af bij winst
      const float = document.createElement("div");
      float.className = "score-float";
      float.innerText = `+${difference}`;
      document.body.appendChild(float);
      setTimeout(() => float.remove(), 2000);
    }
    
    el.innerText = newScore;
  }
}

window.activeTimers = {};

async function startTimedChallenge(idx, questionId, limit, pSec, pPts, maxPts) {
  document.getElementById(`prep-screen-${idx}`).style.display = 'none';
  document.getElementById(`question-content-${idx}`).style.display = 'block';
  
  try {
    await fetch('/api/timer/start', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ questionId }) });
  } catch(e) { console.error("Klok kon niet op server starten."); }

  window.activeTimers[idx] = { startTime: Date.now(), limit, pSec, pPts, maxPts };
  const clockEl = document.getElementById(`timer-clock-${idx}`);
  const ptsEl = document.getElementById(`timer-pts-${idx}`);
  
  setInterval(() => {
    if(!window.activeTimers[idx]) return;
    let passed = Math.floor((Date.now() - window.activeTimers[idx].startTime) / 1000);
    clockEl.innerText = `${String(Math.floor(passed / 60)).padStart(2, '0')}:${String(passed % 60).padStart(2, '0')}`;
    let currentPts = maxPts;
    if (passed > limit) {
      currentPts = Math.max(0, maxPts - (Math.floor((passed - limit) / pSec) * pPts));
      clockEl.parentElement.parentElement.style.background = "#fee2e2"; 
      clockEl.parentElement.parentElement.style.borderColor = "#fecaca"; 
      clockEl.parentElement.parentElement.style.color = "#991b1b"; 
    }
    ptsEl.innerText = currentPts;
  }, 1000);
}

async function handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, questionText) {
  btn.disabled = true;
  const fb = document.getElementById(`fb-${idx}`);
  fb.innerHTML = "Antwoord geaccepteerd..."; fb.style.color = "#4ade80";
  
  try {
    let res;
    if (isTimed) {
      delete window.activeTimers[idx];
      res = await fetch('/api/timer/stop', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ questionId, maxPts, limit, pSec, pPts, logMessage: `Vraag beantwoord: "${questionText}"` })
      });
    } else {
      res = await fetch('/api/log-action', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ points: maxPts, logMessage: `Vraag correct beantwoord: "${questionText}"` })
      });
    }
    const data = await res.json();
    updateGlobalScore(data.totalScore);
    fb.innerHTML = `✅ Correct! (+${isTimed ? data.earnedPoints : maxPts} pt)`;
    
    setTimeout(() => {
      const form = document.getElementById(`form-${idx}`);
      const goodPage = isTimed ? form.parentElement.querySelector(`[data-good]`)?.dataset.good : document.getElementById(`good-${idx}`)?.value;
      const puzzleId = isTimed ? form.dataset.puzzle : "<%= puzzle._id %>";
      if(goodPage && goodPage !== "") window.location.href = `/puzzle/${puzzleId}/${goodPage}`;
    }, 1500);

  } catch(e) {
    fb.innerHTML = "⚠️ Fout bij opslaan. Antwoord was goed."; fb.style.color="#fca5a5";
  }
}

function verifyMC(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText) {
  const form = document.getElementById(`form-${idx}`);
  const fb = document.getElementById(`fb-${idx}`);
  const checked = form.querySelector('input:checked');
  if(!checked) { fb.innerHTML = "Kies een antwoord."; fb.style.color = "#fca5a5"; return; }
  
  if (checked.value === "true") {
    handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText);
  } else {
    fb.innerHTML = "Helaas, niet juist."; fb.style.color = "#fca5a5";
  }
}

function verifyOpen(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText) {
  const ans = document.getElementById(`open-ans-${idx}`).value.trim().toLowerCase();
  const correct = document.getElementById(`open-correct-${idx}`).value.trim().toLowerCase();
  const fb = document.getElementById(`fb-${idx}`);
  
  if(ans === correct && ans !== "") {
    handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText);
  } else {
    fb.innerHTML = "Helaas, niet juist."; fb.style.color = "#fca5a5";
  }
}

async function executeStaticHint(btn, idx, staticTextEn, cost, qText, qId) {
  if (!confirm(`Weet je het zeker? Een hint vragen kost punten! (Let op: een tweede hint kost extra).`)) return;
  
  btn.disabled = true; btn.innerHTML = "Laden...";
  try {
    const res = await fetch('/api/get-hint', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ hintType: 'static', staticHintText: decodeURIComponent(staticTextEn), hintCost: cost, questionText: qText, questionId: qId })
    });
    const data = await res.json();
    if (data.limitReached) btn.style.display = 'none';
    document.getElementById(`hint-res-${idx}`).innerHTML = "Hint: " + (data.hint || "Geen hint gevonden.");
    updateGlobalScore(data.newScore);
    if (!data.limitReached) { btn.disabled = false; btn.innerHTML = "Nog een hint (+2 pt)"; }
  } catch(e) { btn.disabled = false; btn.innerHTML = "Probeer opnieuw"; }
}

async function executeAiHint(btn, idx, aiKnowledgeEn, cost, qText, qId) {
  const input = document.getElementById(`hint-in-${idx}`);
  const msg = input.value.trim();
  if(!msg) { alert("Typ eerst je vraag!"); return; }
  
  if (!confirm(`Weet je zeker dat je dit wilt vragen? Dit kost punten! (Let op: een 2e vraag kost extra).`)) return;
  
  btn.disabled = true; input.disabled = true; btn.innerHTML = "⏳";
  const resDiv = document.getElementById(`hint-res-${idx}`);
  resDiv.innerHTML = "Aan het nadenken...";

  try {
    const res = await fetch('/api/get-hint', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ hintType: 'ai', userMessage: msg, secretKnowledge: decodeURIComponent(aiKnowledgeEn), hintCost: cost, questionText: qText, questionId: qId })
    });
    const data = await res.json();
    
    if (data.limitReached) {
       input.style.display = 'none'; btn.style.display = 'none';
    }
    
    resDiv.innerHTML = "" + (data.hint || "Geen antwoord van assistent.");
    updateGlobalScore(data.newScore);
    if (!data.limitReached) { btn.innerHTML = "Stel nog een vraag (2/2)"; btn.disabled = false; input.disabled = false; input.value = ""; }
  } catch(e) { resDiv.innerHTML = "Systeem offline."; btn.disabled = false; input.disabled = false; btn.innerHTML = "Stel Vraag"; }
}

async function triggerFinale(puzzleId) {
  const btn = document.getElementById('btn-finale');
  const loading = document.getElementById('finale-loading');
  const result = document.getElementById('finale-result');
  const feedback = document.getElementById('finale-feedback').value;

  btn.style.display = 'none';
  loading.style.display = 'block';

  try {
    const res = await fetch('/api/generate-finale-report', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ userFeedback: feedback, puzzleId: puzzleId })
    });
    const data = await res.json();
    
    loading.style.display = 'none';
    result.style.display = 'block';
    
    document.getElementById('finale-text').innerHTML = data.report.replace(/\n/g, '<br>');
    document.getElementById('finale-score').innerText = data.score;
    document.getElementById('finale-time').innerText = data.timeMin;

    if (typeof confetti === "function") {
      var duration = 3000; var end = Date.now() + duration;
      (function frame() {
        confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: ['#0891b2', '#fbbf24', '#4f46e5'] });
        confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, colors: ['#0891b2', '#fbbf24', '#4f46e5'] });
        if (Date.now() < end) requestAnimationFrame(frame);
      }());
    }
  } catch (e) {
    loading.innerHTML = "Fout bij ophalen van het verslag.";
  }
}

document.querySelectorAll('.ai-camera-btn').forEach(btn => {
  btn.addEventListener('click', () => btn.parentElement.querySelector('.ai-file-input').click());
});

document.querySelectorAll('.ai-file-input').forEach(input => {
  input.addEventListener('change', async () => {
    const file = input.files[0]; if (!file) return;
    const mod = input.closest('.card');
    const btn = mod.querySelector('.ai-camera-btn');
    const statusDiv = mod.querySelector('.ai-status');
    const previewImg = mod.querySelector('.ai-preview');

    btn.disabled = true; btn.innerHTML = "Uploaden...";
    statusDiv.style.display = "block"; statusDiv.style.color = "#fbbf24";
    statusDiv.innerHTML = "De foto wordt beoordeeld...";
    previewImg.src = URL.createObjectURL(file); previewImg.style.display = "block";

    const fd = new FormData();
    fd.append("file", file); fd.append("prompt", mod.dataset.prompt); fd.append("maxPoints", mod.dataset.maxpoints);

    try {
      const res = await fetch('/api/verify-aiphoto', { method: 'POST', body: fd });
      const result = await res.json();
      if (!res.ok) throw new Error(result.error);
      
      const currentScore = parseInt(document.getElementById("ui-score")?.innerText || "0");
      updateGlobalScore(currentScore + result.pointsAwarded);

      if (result.match) {
        statusDiv.style.color = "#4ade80";
        statusDiv.innerHTML = `✅ Goedgekeurd! (Zekerheid: ${result.score}%)<br>+${result.pointsAwarded}/${result.maxPoints} pt<br><span style="font-weight:normal;">${result.reason}</span>`;
        btn.style.display = "none"; 
      } else {
        statusDiv.style.color = "#fca5a5";
        statusDiv.innerHTML = "❌ Afgekeurd.<br><span style="font-weight:normal;">" + result.reason + "</span>";
        btn.disabled = false; btn.innerHTML = "Probeer opnieuw";
      }
    } catch (err) {
      statusDiv.style.color = "#fca5a5"; statusDiv.innerHTML = "⚠️ Fout: " + err.message;
      btn.disabled = false; btn.innerHTML = "Probeer opnieuw";
    }
  });
});

document.querySelectorAll('[id^="chat-btn-"]').forEach(btn => {
  btn.addEventListener('click', async () => {
    const idx = btn.id.split('-').pop();
    const input = document.getElementById(`chat-input-${idx}`);
    const win = document.getElementById(`chat-win-${idx}`);
    const msg = input.value.trim();
    if(!msg) return;

    input.value = ''; input.disabled = true; btn.disabled = true;
    win.innerHTML += `<div style="color: #fff; align-self: flex-end; max-width: 85%; background:rgba(0,0,0,0.3); padding:10px; border-radius:10px;">${msg}</div>`;
    win.scrollTop = win.scrollHeight;

    try {
      const mod = btn.closest('.card');
      const charName = mod.querySelector('strong').innerText; 
      
      // Toon typing indicator & scroll naar beneden
      const indicator = document.getElementById(`typing-indicator-${idx}`);
      win.appendChild(indicator); // Verplaats hem naar onderen
      indicator.style.display = 'block';
      win.scrollTop = win.scrollHeight;

      const res = await fetch('/api/chat-persona', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ 
          message: msg, 
          characterName: charName, 
          systemPrompt: "Je bent " + charName,
          maxTurns: mod.dataset.maxturns,
          history: [] // Optioneel: Voeg history array hier later toe
        })
      });
      
      indicator.style.display = 'none'; // Verberg typen zodra API klaar is
      const data = await res.json();
      
      win.innerHTML += `<div style="color: #fbbf24; align-self: flex-start; max-width: 85%; background:rgba(0,0,0,0.5); padding:10px; border-radius:10px;">${data.reply || "..."}</div>`;
      win.appendChild(indicator); // Zet indicator weer helemaal onderaan (verborgen)
      
      if (data.closeChat) {
         input.placeholder = "Gesprek beëindigd door " + charName;
         input.disabled = true; 
         btn.style.opacity = "0.5";
         btn.disabled = true;
         return;
      }

    } catch(e) { 
      document.getElementById(`typing-indicator-${idx}`).style.display = 'none';
      win.innerHTML += `<div style="color:#fca5a5; text-align:center; font-size:12px;">Verbinding verbroken.</div>`; 
    }
    
    input.disabled = false; btn.disabled = false; win.scrollTop = win.scrollHeight;
  });
});

async function uploadPhoto(input, pIdx, mIdx) {
  const file = input.files?.[0]; if (!file) return;
  const fb = document.getElementById(`photo-feedback-${pIdx}-${mIdx}`);
  const fd = new FormData(); fd.append("file", file); fb.textContent = "Uploaden..."; fb.style.color = "#d6d3d1";
  try {
    const res = await fetch("/upload-photo", { method: "POST", body: fd });
    if (!res.ok) throw new Error();
    const json = await res.json();
    document.getElementById(`photo-url-${pIdx}-${mIdx}`).value = json.url;
    fb.textContent = "Foto opgeslagen."; fb.style.color = "#4ade80";
  } catch { fb.textContent = "Upload mislukt."; fb.style.color = "#fca5a5"; }
}

async function setAsTeamPhoto(url) {
  if (!url) { alert("Maak eerst een foto."); return; }
  if (confirm("Deze foto instellen als teamfoto?")) {
    const res = await fetch("/team/profile-photo", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ photoUrl:url }) });
    if (res.ok) location.reload(); else alert("Instellen mislukt");
  }
}
// Gamification Animatie
function popScoreAnim(points) {
  const el = document.createElement("div");
  el.className = "score-float";
  el.innerText = "+" + points;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 1600);
}

// Overschrijf de oude updateGlobalScore om animaties af te spelen!
const oldUpdate = updateGlobalScore;
updateGlobalScore = function(newScore) {
  const el = document.getElementById("ui-score");
  if(el) {
    const oldScore = parseInt(el.innerText || 0);
    if(newScore > oldScore) popScoreAnim(newScore - oldScore);
    el.innerText = newScore;
  }
};

async function saveTeamName() {
  const nameEl = document.getElementById("team-name-input");
  const emailEl = document.getElementById("team-email-input");
  if(!nameEl || !emailEl) return;
  
  const name = nameEl.value.trim();
  const email = emailEl.value.trim();
  const fb = document.getElementById("teamname-feedback");

  if (!name || !email) { fb.textContent = "Vul beide velden in!"; fb.style.color = "red"; return; }

  fb.textContent = "Opslaan..."; fb.style.color = "black";
  
  // Haal puzzle ID uit de pagina URL of een verborgen veld
  const puzzleId = "<%= puzzle._id %>"; 

  const res = await fetch("/team/name", { 
    method: "POST", 
    headers: { "Content-Type": "application/json" }, 
    body: JSON.stringify({ name, email, puzzleId }) 
  });
  
  const data = await res.json();
  if (res.ok) { 
    fb.textContent = data.isReturningUser ? "✅ Welkom terug! De klok loopt." : "✅ Team geregistreerd! De klok loopt."; 
    fb.style.color = "green"; 
    nameEl.disabled = true; emailEl.disabled = true;
    setTimeout(()=>location.reload(), 1000); 
  } else { 
    fb.textContent = "❌ Opslaan mislukt"; fb.style.color = "red"; 
  }
}
</script>

