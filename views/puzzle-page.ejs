<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= puzzle.name %> — <%= page.title %></title>

  <style>
    body {
      font-family: system-ui, sans-serif;
      margin: 0;
      padding: 24px;
      background: #f5f7fa;
    }

    .card {
      background: #fff;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .btn {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 8px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      font-size: 16px;
      cursor: pointer;
      border: none;
    }

    .btn.secondary {
      background: #334155;
      margin-top: 24px;
    }

    .feedback {
      margin-top: 10px;
      font-weight: 600;
    }

    label {
      display: flex;
      gap: 8px;
      margin-top: 6px;
      cursor: pointer;
      align-items: center;
    }
  </style>
</head>

<body>

<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<% (page.modules || []).forEach((mod, qIndex) => { %>

  <% if (mod.type === "text") { %>
    <div class="card">
      <%- mod.data?.text || "" %>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <div class="card">
      <strong><%= mod.data?.question || "" %></strong>

      <% if (mod.data?.questionType === "mc") { %>

        <!-- MULTIPLE CHOICE -->
        <div
          data-mc
          data-options='<%- JSON.stringify(mod.data.options || []) %>'
          data-good="<%= mod.data.goodPage ?? '' %>"
          data-bad="<%= mod.data.badPage  ?? '' %>"
          data-puzzle="<%= puzzle._id %>"
        >

          <% (mod.data.options || []).forEach((opt, i) => { %>
            <label>
              <input type="radio" name="mc-<%= qIndex %>" value="<%= i %>">
              <%= opt.text %>
            </label>
          <% }) %>

          <button class="btn" onclick="handleMC(this)">
            Controleer
          </button>

          <div class="feedback"></div>
        </div>

      <% } else { %>

        <!-- OPEN VRAAG -->
        <form onsubmit="return handleOpen(event, this)">
          <input type="text" name="answer" placeholder="Jouw antwoord">
          <button class="btn" type="submit">Controleer</button>
          <div class="feedback"></div>

          <input type="hidden" name="correct" value="<%= mod.data.answer || '' %>">
          <input type="hidden" name="good" value="<%= mod.data.goodPage ?? '' %>">
          <input type="hidden" name="bad"  value="<%= mod.data.badPage  ?? '' %>">
          <input type="hidden" name="puzzle" value="<%= puzzle._id %>">
        </form>

      <% } %>
    </div>
  <% } %>

<% }) %>

<%
  const hasNext =
    page.showNext === true &&
    typeof pageIndex === "number" &&
    pageIndex + 1 < puzzle.pages.length;
%>

<% if (hasNext) { %>
  <a
    href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>"
    class="btn secondary"
  >
    Volgende pagina →
  </a>
<% } %>

<script>
/* MULTIPLE CHOICE */
function handleMC(btn) {
  const block = btn.closest('[data-mc]');
  const fb = block.querySelector('.feedback');

  const checked = block.querySelector('input[type="radio"]:checked');
  if (!checked) {
    fb.textContent = "Kies eerst een antwoord.";
    fb.style.color = "red";
    return;
  }

  const options = JSON.parse(block.dataset.options || "[]");
  const correct = !!options[checked.value]?.correct;

  const target = correct ? block.dataset.good : block.dataset.bad;
  if (target !== "") {
    location.href = `/puzzle/${block.dataset.puzzle}/${target}`;
    return;
  }

  fb.textContent = correct ? "Goed!" : "Fout!";
  fb.style.color = correct ? "green" : "red";
}

/* OPEN VRAAG */
function handleOpen(event, form) {
  event.preventDefault();

  const fb = form.querySelector('.feedback');
  const answer = form.answer.value.trim().toLowerCase();
  const correct = form.correct.value.trim().toLowerCase();

  const ok = answer === correct;
  const target = ok ? form.good.value : form.bad.value;

  if (target !== "") {
    location.href = `/puzzle/${form.puzzle.value}/${target}`;
    return false;
  }

  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
  return false;
}
</script>

</body>
</html>
