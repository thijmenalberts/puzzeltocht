      <div>
        <strong style="display: block; color: var(--chat-header-text); font-size: 18px;"><%= t(mData.characterName) %></strong>
      </div>
    </div>
    <div id="chat-win-<%= qIndex %>" style="height: 50vh; max-height: 400px; overflow-y: auto; padding: 15px; background: var(--chat-bg); display: flex; flex-direction: column; gap: 10px; scroll-behavior: smooth;">
      <div style="background: var(--chat-bubble-ai); color: var(--chat-text-ai); padding: 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; max-width: 85%;">Gegroet! Heb je een vraag?</div>
      
      <div id="typing-indicator-<%= qIndex %>" class="typing-indicator" style="display: none;">
        <span></span><span></span><span></span>
