          <input type="text" id="open-ans-<%= qIndex %>" placeholder="Jouw antwoord..." style="background: #f9fafb; padding: 14px; font-size: 16px;">
          <input type="hidden" id="open-correct-<%= qIndex %>" value="<%= t(mData.answer) %>">
          <input type="hidden" id="good-<%= qIndex %>" value="<%= mData.goodPage ?? '' %>">
          <input type="hidden" id="bad-<%= qIndex %>" value="<%= mData.badPage ?? '' %>">
          <button class="btn" style="margin-top:15px;" onclick="verifyOpen(this, '<%= qIndex %>', '<%= qId %>', <%= maxPts %>, <%= limit %>, <%= pSec %>, <%= pPts %>, <%= isTimed %>, '<%= qTextClean %>')">Controleer Antwoord</button>
          <div class="feedback" id="fb-<%= qIndex %>"></div>
