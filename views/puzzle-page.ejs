<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= puzzle.name %> — <%= page.title %></title>

  <!-- Leaflet -->
  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    body {
      font-family: system-ui, sans-serif;
      background: #f5f7fa;
      padding: 24px;
      margin: 0;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    #map {
      height: 320px;
      border-radius: 12px;
    }

    .btn {
      display: inline-block;
      padding: 12px 18px;
      border-radius: 8px;
      background: #2563eb;
      color: white;
      text-decoration: none;
      border: none;
      cursor: pointer;
      font-size: 15px;
    }

    .btn.secondary {
      background: #334155;
      margin-top: 16px;
    }

    .feedback {
      margin-top: 12px;
      font-weight: 600;
    }
  </style>
</head>

<body>

<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<!-- ================= MAP PAGINA ================= -->
<% if (page.isMap) { %>
  <div class="card">
    <div id="map"></div>
    <div class="feedback" id="mapFeedback">
      Lokatie bepalen…
    </div>
  </div>
<% } %>

<!-- ================= VOLGENDE PAGINA ================= -->
<%
  const hasNext =
    page.showNext &&
    pageIndex + 1 < puzzle.pages.length;
%>

<% if (hasNext) { %>
  <a
    id="nextBtn"
    class="btn secondary"
    style="display:none"
    href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
    Volgende pagina →
  </a>
<% } %>

<script>
/* ==================================================
   MAP LOGICA
   ================================================== */
<% if (page.isMap) { %>

const targetLat = <%= page.targetLat %>;
const targetLng = <%= page.targetLng %>;
const radius = <%= page.targetRadius %>;
const showTarget = <%= page.showTarget ? "true" : "false" %>;
const autoNext = <%= page.autoNext ? "true" : "false" %>;

const map = L.map("map").setView([targetLat, targetLng], 16);

L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
  attribution: "© OpenStreetMap"
}).addTo(map);

const target = L.latLng(targetLat, targetLng);

if (showTarget) {
  L.marker(target).addTo(map).bindPopup("Doel");
  L.circle(target, {
    radius,
    color: "green",
    fillOpacity: 0.15
  }).addTo(map);
}

const feedback = document.getElementById("mapFeedback");
const nextBtn = document.getElementById("nextBtn");

function distance(a, b) {
  return map.distance(a, b);
}

if (navigator.geolocation) {
  navigator.geolocation.watchPosition(pos => {
    const user = L.latLng(
      pos.coords.latitude,
      pos.coords.longitude
    );

    L.marker(user).addTo(map)
      .bindPopup("Jij bent hier")
      .openPopup();

    map.setView(user, 17);

    const d = distance(user, target);

    if (d <= radius) {
      feedback.textContent = "✅ Doel bereikt!";
      feedback.style.color = "green";

      if (autoNext && nextBtn) {
        setTimeout(() => {
          location.href = nextBtn.href;
        }, 1000);
      } else if (nextBtn) {
        nextBtn.style.display = "inline-block";
      }
    } else {
      feedback.textContent =
        `Afstand tot doel: ${Math.round(d)} meter`;
      feedback.style.color = "black";
    }
  }, () => {
    feedback.textContent =
      "Locatie niet beschikbaar";
    feedback.style.color = "red";
  });
} else {
  feedback.textContent =
    "Geolocatie niet ondersteund";
  feedback.style.color = "red";
}

<% } %>
</script>

</body>
</html>
