<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">

  <title><%= puzzle.name %> — <%= page.title %></title>

  <style>
    body {
      font-family: system-ui, sans-serif;
      margin: 0;
      padding: 24px;
      background: #f5f7fa;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 16px;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }

    .btn {
      display: inline-block;
      margin-top: 12px;
      padding: 10px 16px;
      border: none;
      border-radius: 8px;
      background: #2563eb;
      color: white;
      cursor: pointer;
      font-size: 15px;
    }

    .feedback {
      margin-top: 10px;
      font-weight: 600;
    }

    label {
      display: flex;
      gap: 8px;
      align-items: center;
      margin-top: 6px;
      cursor: pointer;
    }
  </style>
</head>

<body>

<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<% (page.modules || []).forEach((mod, qIndex) => { %>

  <% if (mod.type === "text") { %>
    <div class="card">
      <%- mod.data?.text || "" %>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <div class="card">
      <strong><%= mod.data?.question || "" %></strong>

      <% if (mod.data?.questionType === "mc") { %>

        <!-- ===== MULTIPLE CHOICE ===== -->
        <div
          data-mc
          data-puzzle="<%= puzzle._id %>"
          data-good="<%= Number.isInteger(mod.data.goodPage) ? mod.data.goodPage : '' %>"
          data-bad="<%= Number.isInteger(mod.data.badPage) ? mod.data.badPage : '' %>"
          data-options='<%- JSON.stringify(mod.data.options || []) %>'
          style="margin-top:10px;"
        >

          <% (mod.data.options || []).forEach((opt, i) => { %>
            <label>
              <input
                type="radio"
                name="mc-<%= qIndex %>"
                value="<%= i %>"
              >
              <%= opt.text %>
            </label>
          <% }) %>

          <button class="btn" onclick="handleMC(this)">
            Controleer
          </button>

          <div class="feedback"></div>
        </div>

      <% } else { %>

        <!-- ===== OPEN VRAAG ===== -->
        <form onsubmit="return handleOpen(this)">
          <input type="text" name="answer" placeholder="Jouw antwoord">
          <button class="btn" type="submit">Controleer</button>
          <div class="feedback"></div>

          <input type="hidden" name="correct" value="<%= mod.data.answer || '' %>">
          <input type="hidden" name="good" value="<%= Number.isInteger(mod.data.goodPage) ? mod.data.goodPage : '' %>">
          <input type="hidden" name="bad"  value="<%= Number.isInteger(mod.data.badPage)  ? mod.data.badPage  : '' %>">
          <input type="hidden" name="puzzle" value="<%= puzzle._id %>">
        </form>

      <% } %>
    </div>
  <% } %>

<% }) %>

<script>
/* ===== MULTIPLE CHOICE ===== */
function handleMC(btn) {
  const block = btn.closest('[data-mc]');
  const fb = block.querySelector('.feedback');

  const radios = block.querySelectorAll('input[type="radio"]');
  let checked = null;

  radios.forEach(r => {
    if (r.checked) checked = r;
  });

  if (!checked) {
    fb.textContent = "Kies eerst een antwoord.";
    fb.style.color = "red";
    return;
  }

  const options = JSON.parse(block.dataset.options || "[]");
  const index = Number(checked.value);
  const correct = !!options[index]?.correct;

  const good = block.dataset.good;
  const bad  = block.dataset.bad;
  const puzzle = block.dataset.puzzle;

  const target =
    correct && good !== "" ? good :
    !correct && bad !== "" ? bad :
    null;

  if (target !== null) {
    window.location.href = `/puzzle/${puzzle}/${target}`;
    return;
  }

  fb.textContent = correct ? "Goed!" : "Fout!";
  fb.style.color = correct ? "green" : "red";
}

/* ===== OPEN VRAAG ===== */
function handleOpen(form) {
  event.preventDefault();

  const fb = form.querySelector('.feedback');
  const answer = form.answer.value.trim().toLowerCase();
  const correct = form.correct.value.trim().toLowerCase();

  const good = form.good.value;
  const bad = form.bad.value;
  const puzzle = form.puzzle.value;

  const ok = answer === correct;
  const target =
    ok && good ? good :
    !ok && bad ? bad :
    null;

  if (target !== null) {
    window.location.href = `/puzzle/${puzzle}/${target}`;
    return false;
  }

  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
  return false;
}
</script>

</body>
</html>
