<%
  const hasNext  = !!puzzle.pages[pageIndex + 1];
  const showNext = (typeof page?.showNext === 'boolean') ? page.showNext : true;
  const isMap    = (typeof page?.isMap === 'boolean')    ? page.isMap    : false;

  const showTarget   = (typeof page?.showTarget === 'boolean') ? page.showTarget : true;
  const autoNext     = (typeof page?.autoNext === 'boolean') ? page.autoNext : false;
  const soundUrl     = page?.soundUrl || "";
  const playSoundOnStart =
    (typeof page?.playSoundOnStart === 'boolean') ? page.playSoundOnStart : false;
%>

<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1"/>
  <title><%= puzzle.name %> — <%= page.title %></title>

  <link
    rel="stylesheet"
    href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
  />

  <style>
    :root{
      --primary:#2563eb;
      --text:#111827;
      --muted:#6b7280;
      --card:#ffffff;
      --border:#e5e7eb;
      --accent:#ef4444;
    }

    body{
      margin:0;
      font-family:Inter, system-ui;
      color:var(--text);
    }

    .container{
      max-width:900px;
      margin:0 auto;
      padding:16px;
      display:grid;
      gap:16px;
    }

    .card{
      background:var(--card);
      border:1px solid var(--border);
      border-radius:14px;
      padding:16px;
      box-shadow:0 4px 12px rgba(0,0,0,.06);
    }

    .next-btn{
      padding:10px 14px;
      background:var(--primary);
      color:white;
      border:none;
      border-radius:10px;
      cursor:pointer;
      display:inline-flex;
      align-items:center;
      gap:8px;
    }

    .muted{ color:var(--muted); }

    #map{
      height:60vh;
      min-height:360px;
      border-radius:14px;
      border:1px solid var(--border);
    }
  </style>
</head>

<body>

<audio id="global-sound-player" style="display:none;"></audio>

<div class="container">
  <header>
    <h1><%= puzzle.name %></h1>
    <h2><%= page.title %></h2>
  </header>

  <% if (isMap) { %>

    <!-- ================= MAP PAGINA ================= -->
    <div class="card" style="padding:0;">
      <div id="map"></div>
      <div style="padding:12px;">
        <p class="muted">
          Loop naar de juiste locatie om automatisch door te gaan.
        </p>
      </div>
    </div>

    <% if (hasNext && showNext) { %>
      <a class="next-btn"
         href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
        Volgende pagina →
      </a>
    <% } %>

  <% } else { %>

    <!-- ================= NORMALE PAGINA ================= -->
    <% (page.modules || []).forEach((mod, idx) => { %>

      <% if (mod.type === "text") { %>
        <div class="card"><%- mod.data?.text || "" %></div>
      <% } %>

      <% if (mod.type === "image") { %>
        <div class="card" style="padding:0;">
          <% if (mod.data?.url) { %>
            <img src="<%= mod.data.url %>"
                 style="width:100%; border-radius:14px;">
          <% } %>
        </div>
      <% } %>

      <% if (mod.type === "question") { %>
        <div class="card">
          <p><strong><%= mod.data?.question || "" %></strong></p>

          <% if (mod.data?.questionType === "mc") { %>

            <!-- ===== MULTIPLE CHOICE ===== -->
            <div
              class="mc-block"
              data-mc-block
              style="display:grid; gap:8px;"
            >
              <% (mod.data?.options || []).forEach((opt, i) => { %>
                <label style="display:flex; gap:8px; align-items:center;">
                  <input type="radio"
                         name="mc-<%= pageIndex %>-<%= idx %>"
                         value="<%= i %>">
                  <%= opt.text %>
                </label>
              <% }) %>

              <button type="button"
                class="next-btn"
                onclick="checkMCBranch(
                  this,
                  <%- JSON.stringify(mod.data?.options || []) %>,
                  <%= Number.isInteger(mod.data?.goodPage) ? mod.data.goodPage : 'null' %>,
                  <%= Number.isInteger(mod.data?.badPage) ? mod.data.badPage : 'null' %>,
                  '<%= puzzle._id %>'
                )">
                Controleer
              </button>

              <div data-feedback></div>
            </div>

          <% } else { %>

            <!-- ===== OPEN VRAAG ===== -->
            <form onsubmit="return checkOpenBranch(
              this,
              '<%= (mod.data?.answer || '').replace(/"/g,'&quot;') %>',
              <%= Number.isInteger(mod.data?.goodPage) ? mod.data.goodPage : 'null' %>,
              <%= Number.isInteger(mod.data?.badPage) ? mod.data.badPage : 'null' %>,
              '<%= puzzle._id %>'
            )">
              <input type="text" name="answer"
                     placeholder="Jouw antwoord">
              <button class="next-btn" type="submit">Controleer</button>
              <div data-feedback></div>
            </form>

          <% } %>
        </div>
      <% } %>

    <% }) %>

    <% if (hasNext && showNext) { %>
      <a class="next-btn"
         href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
        Volgende pagina →
      </a>
    <% } %>

  <% } %>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

<script>
/* ===== MULTIPLE CHOICE ===== */
function checkMCBranch(button, options, goodPage, badPage, puzzleId) {
  const block = button.closest('[data-mc-block]');
  const fb = block.querySelector('[data-feedback]');
  const checked = block.querySelector('input[type="radio"]:checked');

  if (!checked) {
    fb.textContent = "Kies eerst een antwoord.";
    fb.style.color = "var(--accent)";
    return;
  }

  const index = Number(checked.value);
  const isCorrect = !!options[index]?.correct;

  let target = null;
  if (isCorrect && Number.isInteger(goodPage)) target = goodPage;
  if (!isCorrect && Number.isInteger(badPage)) target = badPage;

  if (Number.isInteger(target)) {
    window.location.href = `/puzzle/${puzzleId}/${target}`;
    return;
  }

  fb.textContent = isCorrect ? "Goed!" : "Fout!";
  fb.style.color = isCorrect ? "green" : "var(--accent)";
}

/* ===== OPEN VRAAG ===== */
function checkOpenBranch(form, answer, goodPage, badPage, puzzleId){
  event.preventDefault();
  const fb = form.querySelector('[data-feedback]');
  const val = form.answer.value.trim().toLowerCase();
  const ok = val === answer.toLowerCase();

  let target = null;
  if (ok && Number.isInteger(goodPage)) target = goodPage;
  if (!ok && Number.isInteger(badPage)) target = badPage;

  if (Number.isInteger(target)) {
    window.location.href = `/puzzle/${puzzleId}/${target}`;
    return false;
  }

  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "var(--accent)";
  return false;
}
</script>

</body>
</html>
