<!DOCTYPE html>
<html lang="<%= lang || puzzle.defaultLanguage || 'nl' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <!-- Leaflet -->
  <link rel="stylesheet"
        href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>

  <style>
    body {
      font-family: system-ui, sans-serif;
      background:#f5f7fa;
      padding:24px;
      margin:0;
    }

    h1, h2 { margin-top:0; }

    .card {
      background:#fff;
      border-radius:12px;
      padding:16px;
      margin-bottom:16px;
      box-shadow:0 4px 12px rgba(0,0,0,.08);
    }

    .btn {
      display:inline-block;
      padding:12px 18px;
      border-radius:8px;
      background:#2563eb;
      color:#fff;
      text-decoration:none;
      border:none;
      cursor:pointer;
      font-size:15px;
    }

    .btn.secondary {
      background:#334155;
      margin-top:24px;
    }

    .feedback {
      margin-top:8px;
      font-weight:600;
    }

    label {
      display:flex;
      gap:8px;
      margin-top:6px;
      align-items:center;
      cursor:pointer;
    }

    .img-thumb,
    .photo-preview {
      max-width:100%;
      border-radius:8px;
      cursor: zoom-in;
    }

    .img-overlay {
      position:fixed;
      inset:0;
      background:rgba(0,0,0,.75);
      display:none;
      align-items:center;
      justify-content:center;
      z-index:1000;
    }

    .img-overlay img {
      max-width:90%;
      max-height:90%;
      border-radius:12px;
    }

    #map {
      height:320px;
      border-radius:12px;
    }

    .team-header {
      display:flex;
      align-items:center;
      gap:12px;
      margin-bottom:16px;
    }

    .team-photo {
      width:80px;
      height:80px;
      border-radius:50%;
      object-fit:cover;
    }

    /* Titel-module styling */
    .title-module {
      font-size: 26px;
      font-weight: 800;
      line-height: 1.3;
      margin: 0;
    }
  </style>
</head>

<body>

<%
  const activeLanguage = lang || puzzle.defaultLanguage || "nl";
  const fallback = puzzle.defaultLanguage || "nl";

  // ✅ Centrale vertaalhelper
  const t = (value) =>
    typeof value === "string"
      ? value
      : value?.[activeLanguage]
        || value?.[fallback]
        || "";
%>

<!-- 🌍 TAALKEUZE -->
<form id="language-form"
      style="margin-bottom:16px;"
      onchange="this.submit()"
      method="POST"
      action="/puzzle/set-language">

  <label style="display:flex; align-items:center; gap:8px;">
    <strong>Taal:</strong>

    <select name="language">
      <% puzzle.languages.forEach(l => { %>
        <option value="<%= l %>"
          <%= l === activeLanguage ? "selected" : "" %>>
          <%= l.toUpperCase() %>
        </option>
      <% }) %>
    </select>
  </label>

  <!-- 🔒 terugsturen naar dezelfde pagina -->
  <input type="hidden" name="redirect"
         value="/puzzle/<%= puzzle._id %>/<%= pageIndex %>">
</form>

<!-- 🔊 AUDIO BIJ START -->
<% if (page.playSoundOnStart && page.soundUrl) { %>
<script>
  new Audio("<%= page.soundUrl %>").play().catch(()=>{});
</script>
<% } %>

<!-- 🗺️ MAP PAGINA -->
<% if (page.isMap) { %>
  <div class="card">
    <div id="map"></div>
    <div class="feedback" id="mapFeedback">
      Locatie bepalen…
    </div>
  </div>
<% } %>

<!-- 📦 MODULES -->
<% (page.modules || []).forEach((mod, qIndex) => { %>

  <% if (mod.type === "title") { %>
    <div class="card">
      <h2 class="title-module">
        <%= t(mod.data.title) %>
      </h2>
    </div>
  <% } %>

  <% if (mod.type === "text") { %>
    <div class="card"><%- t(mod.data.text) %></div>
  <% } %>

  <% if (mod.type === "image") { %>
    <div class="card">
      <img src="<%= mod.data.url %>"
           class="img-thumb"
           onclick="openImage(this.src)">
    </div>
  <% } %>

  <% if (mod.type === "audio") { %>
    <div class="card">
      <audio controls preload="none" style="width:100%;">
        <source src="<%= mod.data.url %>">
      </audio>
    </div>
  <% } %>

  <% if (mod.type === "team-name") { %>
    <div class="card">
      <strong>Teamnaam</strong>
      <input type="text"
             placeholder="Voer jullie teamnaam in"
             value="<%= session?.teamName || '' %>"
             onblur="saveTeamName(this.value)">
      <div class="feedback" id="teamname-feedback"></div>
    </div>
  <% } %>

  <% if (mod.type === "photo") { %>
    <div class="card">
      <strong>Maak een foto</strong>
      <input type="file" accept="image/*" capture="environment"
             onchange="uploadPhoto(this,<%=pageIndex%>,<%=qIndex%>)">

      <input type="hidden"
             id="photo-url-<%=pageIndex%>-<%=qIndex%>"
             value="<%= mod.data?.url || '' %>">

      <div class="feedback"
           id="photo-feedback-<%=pageIndex%>-<%=qIndex%>"></div>

      <% if (mod.data?.url) { %>
        <img src="<%= mod.data.url %>"
             class="photo-preview"
             onclick="openImage(this.src)">
      <% } %>

      <button class="btn"
              style="margin-top:8px"
              onclick="setAsTeamPhoto(
                document.getElementById(
                  'photo-url-<%=pageIndex%>-<%=qIndex%>'
                ).value)">⭐ Zet als teamfoto</button>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <div class="card">
      <strong><%= t(mod.data.question) %></strong>

      <% if (mod.data.questionType === "mc") { %>
        <div data-mc
             data-options='<%- JSON.stringify(mod.data.options || []) %>'
             data-good="<%= mod.data.goodPage ?? '' %>"
             data-bad="<%= mod.data.badPage ?? '' %>"
             data-puzzle="<%= puzzle._id %>">

          <% mod.data.options.forEach((opt,i)=>{ %>
            <label>
              <input type="radio"
                     name="mc-<%=qIndex%>"
                     value="<%= i %>">
              <span><%= t(opt.text) %></span>
            </label>
  
          <% }) %>

          <button class="btn" onclick="handleMC(this)">
            Controleer
          </button>
          <div class="feedback"></div>
        </div>

      <% } else { %>

        <form onsubmit="return handleOpen(event,this)">
          <input name="answer" placeholder="Jouw antwoord">
          <button class="btn">Controleer</button>
          <div class="feedback"></div>

          <input type="hidden" name="correct"
                 value="<%= t(mod.data.answer) %>">
          <input type="hidden" name="good"
                 value="<%= mod.data.goodPage ?? '' %>">
          <input type="hidden" name="bad"
                 value="<%= mod.data.badPage ?? '' %>">
          <input type="hidden" name="puzzle"
                 value="<%= puzzle._id %>">
        </form>

      <% } %>
    </div>
  <% } %>

<% if (mod.type === 'historychat') { %>
  <% 
     const charName = t(mod.data.characterName);
     const sysPrompt = t(mod.data.systemPrompt);
  %>
  
  <div class="card module-historychat" style="border: 2px solid #fee2e2; overflow: hidden; padding: 0;">
    <div style="background: #fee2e2; padding: 12px; display: flex; align-items: center; gap: 10px;">
      <div style="width: 40px; height: 40px; background: #991b1b; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px;">🎭</div>
      <div>
        <strong style="display: block; color: #991b1b;"><%= charName %></strong>
        <span style="font-size: 11px; color: #b91c1c;">Historisch figuur</span>
      </div>
    </div>

    <div id="chat-win-<%= qIndex %>" style="height: 250px; overflow-y: auto; padding: 15px; background: #fffcfc; display: flex; flex-direction: column; gap: 10px;">
      <div style="background: #f3f4f6; padding: 8px 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; font-size: 14px; max-width: 85%; color: #111827;">
        Gegroet reiziger! Ik ben <%= charName %>. Heb je vragen voor mij?
      </div>
    </div>

    <div style="padding: 10px; border-top: 1px solid #fee2e2; display: flex; gap: 8px; background: white;">
      <input type="text" id="chat-input-<%= qIndex %>" placeholder="Typ je vraag..." style="flex: 1; border: 1px solid #ddd; padding: 10px; border-radius: 20px; font-size: 14px; outline: none;">
      <button id="chat-btn-<%= qIndex %>" style="background: #991b1b; color: white; border: none; width: 40px; height: 40px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; transition: opacity 0.2s;">✈️</button>
    </div>
  </div>

  <script>
    (function() {
      // 1. Veilig de data vanuit de server inladen
      const config = <%- JSON.stringify({ charName: charName, sysPrompt: sysPrompt }) %>;
      
      // 2. Exacte elementen pakken op basis van de unieke qIndex
      const win = document.getElementById('chat-win-<%= qIndex %>');
      const input = document.getElementById('chat-input-<%= qIndex %>');
      const btn = document.getElementById('chat-btn-<%= qIndex %>');
      let history = [];

      async function send() {
        const msg = input.value.trim();
        if(!msg) return;
        
        // UI op slot zetten tijdens het wachten (voorkomt dubbel klikken)
        input.value = '';
        input.disabled = true;
        btn.disabled = true;
        btn.style.opacity = '0.5';

        // Voeg bericht van de speler toe (via createElement om DOM breuken te voorkomen)
        const userDiv = document.createElement('div');
        userDiv.style.cssText = "background: #991b1b; color: white; padding: 8px 12px; border-radius: 12px 12px 0 12px; align-self: flex-end; font-size: 14px; max-width: 85%;";
        userDiv.textContent = msg;
        win.appendChild(userDiv);
        win.scrollTop = win.scrollHeight;

        // Voeg "Is aan het typen..." laad-animatie toe
        const loadDiv = document.createElement('div');
        loadDiv.style.cssText = "color: #991b1b; font-size: 12px; align-self: flex-start; margin-bottom: 5px; font-style: italic;";
        loadDiv.textContent = config.charName + " is een antwoord aan het schrijven...";
        win.appendChild(loadDiv);
        win.scrollTop = win.scrollHeight;

        try {
          // Stuur naar de backend API
          const res = await fetch('/api/chat-persona', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({
              message: msg,
              characterName: config.charName,
              systemPrompt: config.sysPrompt,
              history: history
            })
          });
          
          const data = await res.json();
          
          // Haal de laad-tekst weg
          if (win.contains(loadDiv)) win.removeChild(loadDiv);

          if(!res.ok) throw new Error(data.error || "Fout bij laden");
          
          // Voeg het antwoord van de AI toe
          const botDiv = document.createElement('div');
          botDiv.style.cssText = "background: #f3f4f6; color: #111827; padding: 8px 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; font-size: 14px; max-width: 85%;";
          botDiv.textContent = data.reply;
          win.appendChild(botDiv);
          win.scrollTop = win.scrollHeight;
          
          // Update het geheugen (zodat Visboer Jos weet wat we eerder zeiden)
          history.push({ role: "user", parts: [{ text: msg }] });
          history.push({ role: "model", parts: [{ text: data.reply }] });

        } catch (e) {
          if (win.contains(loadDiv)) win.removeChild(loadDiv);
          const errDiv = document.createElement('div');
          errDiv.style.cssText = "color: #ef4444; font-size: 12px; text-align: center; margin-top: 5px; font-weight: bold;";
          errDiv.textContent = "Oeps, de verbinding met het verleden is even verbroken...";
          win.appendChild(errDiv);
        } finally {
          // Geef de UI weer vrij
          input.disabled = false;
          btn.disabled = false;
          btn.style.opacity = '1';
          input.focus();
        }
      }

      // Koppel de knoppen
      btn.addEventListener('click', send);
      input.addEventListener('keypress', (e) => { 
        if(e.key === 'Enter') send(); 
      });
    })();
  </script>
<% } %>
//----------------------------------------- AI foto

<% if (mod.type === 'aiphoto') { %>
  <% 
     // Data ophalen uit de database (ingevuld in de Builder)
     const aiInstruction = t(mod.data.instruction);
     const aiPrompt = t(mod.data.prompt);
     const maxPoints = mod.data.points || 10;
  %>
  
  <div class="card module-aiphoto" 
       id="ai-mod-<%= qIndex %>"
       data-prompt="<%= aiPrompt %>" 
       data-maxpoints="<%= maxPoints %>" 
       style="border: 2px solid #c7d2fe;">
       
    <h3 style="margin-top: 0; font-size: 1.2rem; font-weight: 800; color: #4f46e5; display: flex; align-items: center; gap: 8px;">
      ✨ AI Opdracht
    </h3>
    <p style="margin-bottom: 16px; font-size: 1rem; color: #374151;">
      <strong>Opdracht:</strong> <%= aiInstruction %>
    </p>

    <div class="ai-interaction-area" style="display: flex; flex-direction: column; gap: 12px;">
      <input type="file" accept="image/*" capture="environment" class="ai-file-input" style="display: none;">
      
      <button type="button" class="btn ai-camera-btn" style="width: 100%; padding: 14px; font-weight: bold; background: #4f46e5; color: white; border: none;">
        📸 Maak Foto & Controleer
      </button>
      
      <div class="ai-status" style="display: none; padding: 14px; border-radius: 8px; font-size: 0.95rem; font-weight: 600; line-height: 1.4;"></div>
      
      <img class="ai-preview" style="display: none; width: 100%; border-radius: 8px; margin-top: 4px; border: 1px solid #e5e7eb;">
    </div>
  </div>

  <script>
    (function() {
      const module = document.getElementById('ai-mod-<%= qIndex %>');
      const btn = module.querySelector('.ai-camera-btn');
      const fileInput = module.querySelector('.ai-file-input');
      const statusDiv = module.querySelector('.ai-status');
      const previewImg = module.querySelector('.ai-preview');

      btn.addEventListener('click', () => fileInput.click());

      fileInput.addEventListener('change', async () => {
        const file = fileInput.files[0];
        if (!file) return;

        // UI naar loading state
        btn.disabled = true;
        btn.innerHTML = "🤖 AI jury overlegt...";
        statusDiv.style.display = "block";
        statusDiv.style.background = "#eef2ff";
        statusDiv.style.color = "#4f46e5";
        statusDiv.innerHTML = "De jury beoordeelt je foto...";
        
        previewImg.src = URL.createObjectURL(file);
        previewImg.style.display = "block";

        // Belangrijk: Pak de data die de admin in de builder heeft gezet
        const fd = new FormData();
        fd.append("file", file);
        fd.append("prompt", module.dataset.prompt);
        fd.append("maxPoints", module.dataset.maxpoints);

        try {
          const res = await fetch('/api/verify-aiphoto', { method: 'POST', body: fd });
          const result = await res.json();

          if (!res.ok) throw new Error(result.error);

          if (result.match) {
            statusDiv.style.background = "#dcfce7";
            statusDiv.style.color = "#166534";
            statusDiv.innerHTML = `✅ <strong>Goedgekeurd!</strong> (Score: ${result.score}%)<br>` +
                                 `Je verdient <strong>${result.pointsAwarded} van de ${result.maxPoints} punten!</strong><br>` +
                                 `<small style="font-weight:normal;">${result.reason}</small>`;
            btn.style.display = "none"; 
          } else {
            statusDiv.style.background = "#fee2e2";
            statusDiv.style.color = "#991b1b";
            statusDiv.innerHTML = "❌ <strong>Helaas!</strong><br>" + result.reason;
            btn.disabled = false;
            btn.innerHTML = "📸 Probeer opnieuw";
          }
        } catch (err) {
          statusDiv.style.background = "#fee2e2";
          statusDiv.style.color = "#991b1b";
          statusDiv.innerHTML = "⚠️ Fout: " + err.message;
          btn.disabled = false;
          btn.innerHTML = "📸 Probeer opnieuw";
        }
      });
    })();
  </script>
<% } %>

<% }) %>
// ---------------------------------------- AI foto

<!-- ▶ VOLGENDE PAGINA -->
<% if (page.showNext && pageIndex + 1 < puzzle.pages.length) { %>
  <a class="btn secondary"
     href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">
     Volgende pagina →
  </a>
<% } %>

<!-- IMAGE OVERLAY -->
<div class="img-overlay" id="imgOverlay"
     onclick="this.style.display='none'">
  <img id="overlayImg">
</div>

<script>
function openImage(src){
  overlayImg.src = src;
  imgOverlay.style.display = "flex";
}
</script>

<script>
/* === QUESTIONS === */
function handleMC(btn) {
  const b = btn.closest('[data-mc]');
  const fb = b.querySelector('.feedback');
  const r = b.querySelector('input:checked');
  if (!r) {
    fb.textContent = "Kies een antwoord.";
    fb.style.color = "red";
    return;
  }

  const opts = JSON.parse(b.dataset.options || "[]");
  const ok = !!opts[r.value]?.correct;
  const go = ok ? b.dataset.good : b.dataset.bad;

  if (go !== "") {
    location.href = `/puzzle/${b.dataset.puzzle}/${go}`;
    return;
  }

  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
}

function handleOpen(e, f) {
  e.preventDefault();

  const ok =
    f.answer.value.trim().toLowerCase() ===
    f.correct.value.trim().toLowerCase();

  const go = ok ? f.good.value : f.bad.value;
  if (go !== "") {
    location.href = `/puzzle/${f.puzzle.value}/${go}`;
    return false;
  }

  const fb = f.querySelector('.feedback');
  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
  return false;
}

/* === PHOTO UPLOAD === */
async function uploadPhoto(input, pageIndex, moduleIndex) {
  const file = input.files?.[0];
  if (!file) return;

  const fb = document.getElementById(
    `photo-feedback-${pageIndex}-${moduleIndex}`
  );

  const fd = new FormData();
  fd.append("file", file);

  try {
    fb.textContent = "Uploaden…";

    const res = await fetch("/upload-photo", {
      method: "POST",
      body: fd
    });

    if (!res.ok) throw new Error();

    const json = await res.json();
    document.getElementById(
      `photo-url-${pageIndex}-${moduleIndex}`
    ).value = json.url;

    fb.textContent = "✅ Foto opgeslagen";
    fb.style.color = "green";
  } catch {
    fb.textContent = "❌ Upload mislukt";
    fb.style.color = "red";
  }
}

/* === TEAM PHOTO === */
async function setAsTeamPhoto(photoUrl) {
  if (!photoUrl) {
    alert("Maak eerst een foto.");
    return;
  }

  if (!confirm("Deze foto instellen als teamfoto?")) return;

  const res = await fetch("/team/profile-photo", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ photoUrl })
  });

  if (!res.ok) {
    alert("Instellen mislukt");
    return;
  }

  location.reload();
}

/* === TEAM NAME === */
async function saveTeamName(name) {
  name = name.trim();
  if (!name) return;

  const fb = document.getElementById("teamname-feedback");

  const res = await fetch("/team/name", {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({ name })
  });

  if (!res.ok) {
    fb.textContent = "❌ Opslaan mislukt";
    fb.style.color = "red";
    return;
  }

  fb.textContent = "✅ Teamnaam opgeslagen";
  fb.style.color = "green";
}
</script>

<!-- MAP SCRIPT (ongewijzigd) -->
<% if (page.isMap) { %>
<script>
const target = L.latLng(<%= page.targetLat %>,<%= page.targetLng %>);
const radius = <%= page.targetRadius %>;
const showTarget = <%= page.showTarget ? "true":"false" %>;
const autoNext = <%= page.autoNext ? "true":"false" %>;

const map = L.map("map").setView(target,16);
L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);

if(showTarget){
  L.marker(target).addTo(map);
  L.circle(target,{radius,color:"green",fillOpacity:.15}).addTo(map);
}

const fb = document.getElementById("mapFeedback");
const nextBtn = document.querySelector(".btn.secondary");

navigator.geolocation.watchPosition(p=>{
  const user = L.latLng(p.coords.latitude,p.coords.longitude);
  map.setView(user,17);
  L.marker(user).addTo(map);

  const d = map.distance(user,target);
  if(d<=radius){
    fb.textContent="✅ Doel bereikt!";
    fb.style.color="green";
    if(autoNext && nextBtn){
      setTimeout(()=>location.href=nextBtn.href,1000);
    }
  } else {
    fb.textContent=`Afstand: ${Math.round(d)} meter`;
  }
},()=>{ fb.textContent="Locatie niet beschikbaar"; fb.style.color="red"; });
</script>
<% } %>

</body>
</html>
