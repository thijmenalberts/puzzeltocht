      <h3 style="margin-top:0; color:#4f46e5; display:flex; align-items:center; gap:8px;">✨ AI Opdracht</h3>
      <p><strong>Opdracht:</strong> <%= t(mod.data.instruction) %></p>
      <input type="file" accept="image/*" capture="environment" class="ai-file-input" style="display:none;">
      <button class="btn ai-camera-btn" style="background:#4f46e5;">📸 Maak Foto & Controleer</button>
      <div class="ai-status" style="display:none; padding:14px; border-radius:12px; margin-top:10px;"></div>
      <img class="ai-preview" style="display:none; width:100%; border-radius:12px; margin-top:10px;">
    </div>
    <script>
      (function(){
        const mod = document.getElementById('ai-mod-<%= qIndex %>');
        const btn = mod.querySelector('.ai-camera-btn');
        const input = mod.querySelector('.ai-file-input');
        const status = mod.querySelector('.ai-status');
        btn.onclick = () => input.click();
        input.onchange = async () => {
          const file = input.files[0]; if(!file) return;
          btn.disabled = true; btn.innerHTML = "🤖 AI overlegt...";
          status.style.display = "block"; status.style.background = "#eef2ff"; status.innerHTML = "Jury beoordeelt de foto...";
          const fd = new FormData(); fd.append("file", file); fd.append("prompt", mod.dataset.prompt); fd.append("maxPoints", mod.dataset.maxpoints);
          try {
            const res = await fetch('/api/verify-aiphoto', { method: 'POST', body: fd });
            const data = await res.json();
            if(!res.ok) throw new Error(data.error);
            if(data.match){
              status.style.background = "#dcfce7"; status.style.color = "#166534";
              status.innerHTML = `✅ <strong>Goedgekeurd! (${data.score}%)</strong><br>Je verdient ${data.pointsAwarded} punten!<br><small>${data.reason}</small>`;
              btn.style.display = "none";
            } else {
              status.style.background = "#fee2e2"; status.style.color = "#991b1b";
              status.innerHTML = `❌ <strong>Helaas!</strong><br>${data.reason}`;
              btn.disabled = false; btn.innerHTML = "📸 Probeer opnieuw";
            }
          } catch(e) { status.innerHTML = "⚠️ Fout: " + e.message; btn.disabled = false; }
        };
      })();
    </script>
  <% } %>

  <% if (mod.type === "historychat") { %>
    <% 
       const cName = t(mod.data.characterName);
       const sPrompt = t(mod.data.systemPrompt);
       const tLat = mod.data.lat || null;
       const tLng = mod.data.lng || null;
       const tRad = mod.data.radius || 50;
    %>
    <div class="card" style="border: 2px solid #fee2e2; padding:0; overflow:hidden;">
      <div style="background:#fee2e2; padding:12px; display:flex; align-items:center; gap:10px;">
        <div style="width:40px; height:40px; background:#991b1b; color:#fff; border-radius:50%; display:flex; align-items:center; justify-content:center;">🎭</div>
        <div><strong style="display:block; color:#991b1b;"><%= cName %></strong><span style="font-size:11px; color:#b91c1c;">Historisch personage</span></div>
      </div>

      <div id="chat-locker-<%= qIndex %>" style="display:<%= tLat ? 'flex' : 'none' %>; flex-direction:column; align-items:center; padding:30px 15px; text-align:center; background:#fffcfc;">
        <div style="font-size:30px; margin-bottom:10px;">📍</div>
        <strong style="color:#991b1b;">Locatie Vergrendeld</strong>
        <p style="font-size:13px; color:#6b7280;">Je moet dichterbij <%= cName %> komen om te kunnen praten.</p>
        <div id="dist-<%= qIndex %>" style="background:#fee2e2; padding:8px 15px; border-radius:20px; font-weight:800; color:#991b1b;">Zoeken naar GPS...</div>
      </div>

      <div id="chat-main-<%= qIndex %>" style="display:<%= tLat ? 'none' : 'flex' %>; flex-direction:column;">
        <div id="win-<%= qIndex %>" style="height:45vh; min-height:250px; overflow-y:auto; padding:15px; background:#fffcfc; display:flex; flex-direction:column; gap:10px;">
          <div style="background:#f3f4f6; padding:8px 12px; border-radius:12px 12px 12px 0; align-self:flex-start; font-size:14px; max-width:85%;">Gegroet! Ik ben <%= cName %>. Wat wil je weten?</div>
        </div>
        <div style="padding:10px; border-top:1px solid #fee2e2; display:flex; gap:8px; background:#fff;">
          <input id="in-<%= qIndex %>" placeholder="Typ je vraag..." style="margin:0; flex:1; border-radius:20px;">
          <button id="send-<%= qIndex %>" style="background:#991b1b; color:#fff; border:none; width:40px; height:40px; border-radius:50%; cursor:pointer;">✈️</button>
        </div>
      </div>
    </div>
    <script>
      (function(){
        const qIdx = "<%= qIndex %>";
        const cfg = <%- JSON.stringify({ name: cName, prompt: sPrompt, lat: tLat, lng: tLng, rad: tRad }) %>;
        const win = document.getElementById('win-' + qIdx);
        const input = document.getElementById('in-' + qIdx);
        const locker = document.getElementById('chat-locker-' + qIdx);
        const main = document.getElementById('chat-main-' + qIdx);
        const distDiv = document.getElementById('dist-' + qIdx);
        let history = [];

        if(cfg.lat){
          navigator.geolocation.watchPosition(p => {
            const d = L.latLng(p.coords.latitude, p.coords.longitude).distanceTo(L.latLng(cfg.lat, cfg.lng));
            if(d <= cfg.rad){ locker.style.display='none'; main.style.display='flex'; }
            else { locker.style.display='flex'; main.style.display='none'; distDiv.innerHTML = `Nog ${Math.round(d - cfg.rad)}m lopen`; }
          }, e => { distDiv.innerHTML = "GPS Fout"; }, { enableHighAccuracy:true });
        }

        async function send() {
          const m = input.value.trim(); if(!m) return;
          input.value = ''; input.disabled = true;
          win.innerHTML += `<div style="background:#991b1b; color:#fff; padding:8px 12px; border-radius:12px 12px 0 12px; align-self:flex-end; font-size:14px; max-width:85%;">${m}</div>`;
          win.scrollTop = win.scrollHeight;
          try {
            const res = await fetch('/api/chat-persona', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ message: m, characterName: cfg.name, systemPrompt: cfg.prompt, history: history }) });
            const data = await res.json();
            win.innerHTML += `<div style="background:#f3f4f6; padding:8px 12px; border-radius:12px 12px 12px 0; align-self:flex-start; font-size:14px; max-width:85%;">${data.reply}</div>`;
            win.scrollTop = win.scrollHeight;
            history.push({role:"user", parts:[{text:m}]}, {role:"model", parts:[{text:data.reply}]});
          } catch(e) { win.innerHTML += `<div style="color:red; font-size:11px;">Oeps, verbinding verbroken...</div>`; }
          finally { input.disabled = false; input.focus(); }
        }
        document.getElementById('send-'+qIdx).onclick = send;
        input.onkeypress = (e) => e.key==='Enter' && send();
      })();
    </script>
  <% } %>

<% }) %> <% if (page.showNext && pageIndex + 1 < puzzle.pages.length) { %>
  <a class="btn secondary" href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">Volgende pagina →</a>
<% } %>

<script>
/* HELPER FUNCTIES */
function handleMC(btn) {
  const b = btn.closest('[data-mc]');
  const r = b.querySelector('input:checked'); if(!r) return;
  const opts = JSON.parse(b.dataset.options);
  const ok = opts[r.value].correct;
  if(ok && b.dataset.good !== "") location.href=`/puzzle/${b.dataset.puzzle}/${b.dataset.good}`;
  else if(!ok && b.dataset.bad !== "") location.href=`/puzzle/${b.dataset.puzzle}/${b.dataset.bad}`;
  else { b.querySelector('.feedback').innerHTML = ok ? "✅ Goed!" : "❌ Fout!"; b.querySelector('.feedback').style.color = ok ? "green" : "red"; }
}
function handleOpen(e, f) {
  e.preventDefault();
  const ok = f.answer.value.trim().toLowerCase() === f.correct.value.trim().toLowerCase();
  const target = ok ? f.good.value : f.bad.value;
  if(target !== "") location.href=`/puzzle/${f.puzzle.value}/${target}`;
  else { f.querySelector('.feedback').innerHTML = ok ? "✅ Goed!" : "❌ Fout!"; f.querySelector('.feedback').style.color = ok ? "green" : "red"; }
  return false;
}
</script>
</body>
</html>
