<!DOCTYPE html>
<html lang="<%= lang || puzzle.defaultLanguage || 'nl' %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
  
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>

  <style>
    body { font-family: "Inter", system-ui, sans-serif; background:#f5f7fa; padding:24px; margin:0; color:#111827; }
    h1, h2 { margin-top:0; color:#1f2937; }
    .card { background:#fff; border-radius:14px; padding:20px; margin-bottom:18px; box-shadow:0 6px 16px rgba(0,0,0,.06); border: 1px solid #f3f4f6; }
    .btn { display:block; width:100%; text-align:center; padding:14px 18px; border-radius:10px; background:#4f46e5; color:#fff; text-decoration:none; border:none; cursor:pointer; font-size:16px; font-weight: 700; transition: background 0.2s; }
    .btn:hover { background:#4338ca; }
    .btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .btn.secondary { background:#334155; margin-top:24px; }
    .feedback { margin-top:10px; font-weight:700; font-size: 15px; }
    label { display:flex; gap:10px; margin-top:8px; align-items:center; cursor:pointer; }
    input[type="text"], input[type="number"], select, textarea { width: 100%; padding: 12px; border: 1px solid #d1d5db; border-radius: 8px; font-size: 15px; font-family: inherit; box-sizing: border-box; }
    .img-thumb, .photo-preview { max-width:100%; border-radius:10px; cursor: zoom-in; margin-top: 10px; }
    .img-overlay { position:fixed; inset:0; background:rgba(0,0,0,.85); display:none; align-items:center; justify-content:center; z-index:1000; padding: 20px; }
    .img-overlay img { max-width:100%; max-height:100%; border-radius:12px; }
    #map { height:350px; border-radius:12px; border: 2px solid #e5e7eb; }
    
    .title-module { font-size: 26px; font-weight: 800; line-height: 1.3; margin: 0; color: #111827; }
    .hint-container { margin-top: 18px; border-top: 1px dashed #cbd5e1; padding-top: 15px; }
    .hint-btn { display: flex; align-items: center; justify-content: center; gap: 8px; width: 100%; background: #fffbeb; color: #d97706; border: 2px solid #fde68a; padding: 10px; border-radius: 8px; font-weight: 800; cursor: pointer; transition: 0.2s; }
    .hint-btn:hover { background: #fef3c7; }
    
    @keyframes spin { 100% { transform: rotate(360deg); } }
  </style>
</head>

<body>

<%
  if (!page) return;
  var activeLanguage = lang || puzzle.defaultLanguage || "nl";
  var fallback = puzzle.defaultLanguage || "nl";
  var t = (value) => typeof value === "string" ? value : value?.[activeLanguage] || value?.[fallback] || "";
%>

<form id="language-form" style="margin-bottom:16px;" onchange="this.submit()" method="POST" action="/puzzle/set-language">
  <label style="display:flex; align-items:center; gap:8px;">
    <strong>Taal:</strong>
    <select name="language" style="width: auto; padding: 8px;">
      <% (puzzle.languages || ['nl']).forEach(l => { %>
        <option value="<%= l %>" <%= l === activeLanguage ? "selected" : "" %>><%= l.toUpperCase() %></option>
      <% }) %>
    </select>
  </label>
  <input type="hidden" name="redirect" value="/puzzle/<%= puzzle._id %>/<%= pageIndex %>">
</form>

<% if (session?.teamName) { %>
  <div style="position: sticky; top: 10px; background: #1e293b; color: white; padding: 14px 20px; display: flex; justify-content: space-between; align-items: center; border-radius: 12px; margin-bottom: 20px; z-index: 100; box-shadow: 0 10px 25px rgba(0,0,0,0.2);">
    <strong style="font-size: 16px; margin: 0; text-overflow: ellipsis; overflow: hidden; white-space: nowrap; max-width: 60%;">👥 <%= session.teamName %></strong>
    <strong style="color: #fbbf24; margin: 0; background: rgba(255,255,255,0.15); padding: 6px 14px; border-radius: 20px; flex-shrink: 0;">
      🏆 <span id="ui-score" style="font-weight: 900;"><%= session.totalScore || 0 %></span> pt
    </strong>
  </div>
<% } %>

<% if (typeof isCompleted !== 'undefined' && isCompleted) { %>
  <div style="background: #e5e7eb; color: #4b5563; padding: 12px; border-radius: 8px; margin-bottom: 20px; text-align: center; font-weight: bold; border: 2px dashed #9ca3af;">
    🔒 Je bekijkt een oude pagina. Vragen beantwoorden is uitgeschakeld.
  </div>
<% } %>

<% if (page.playSoundOnStart && page.soundUrl) { %>
<script>
  new Audio("<%= page.soundUrl %>").play().catch(()=>{ console.warn("Autoplay geblokkeerd"); });
</script>
<% } %>

<% if (page.isMap) { %>
  <div class="card" style="padding: 10px;">
    <div id="map"></div>
    <div class="feedback" id="mapFeedback" style="padding: 10px 5px; text-align: center;">📍 Locatie bepalen…</div>
  </div>
<% } %>

<% (page.modules || []).forEach((mod, qIndex) => { %>
  <% var mData = mod.data || {}; %>
  <% var qId = "q-" + pageIndex + "-" + qIndex; %>

  <% if (mod.type === "title") { %>
    <div class="card"><h2 class="title-module"><%= t(mData.title) %></h2></div>
  <% } %>

  <% if (mod.type === "text") { %>
    <div class="card" style="line-height: 1.6;"><%- t(mData.text) %></div>
  <% } %>

  <% if (mod.type === "image") { %>
    <div class="card"><img src="<%= mData.url || '' %>" class="img-thumb" onclick="openImage(this.src)"></div>
  <% } %>

  <% if (mod.type === "audio") { %>
    <div class="card">
      <audio controls preload="none" style="width:100%;"><source src="<%= mData.url || '' %>"></audio>
    </div>
  <% } %>

  <% if (mod.type === "team-name") { %>
    <div class="card" style="border: 2px solid #4f46e5;">
      <h3 style="margin-top:0; color:#4f46e5;">Kies jullie Teamnaam</h3>
      <input type="text" placeholder="Voer hier de teamnaam in..." value="<%= session?.teamName || '' %>" onblur="saveTeamName(this.value)">
      <div class="feedback" id="teamname-feedback"></div>
      <p style="font-size: 13px; color: #6b7280; margin-top: 10px;">Dit start de klok van jullie speurtocht!</p>
    </div>
  <% } %>

  <% if (mod.type === "photo") { %>
    <div class="card">
      <h3 style="margin-top:0;">📸 Maak een foto</h3>
      <input type="file" accept="image/*" capture="environment" onchange="uploadPhoto(this,<%=pageIndex%>,<%=qIndex%>)" style="padding: 0; border: none;">
      <input type="hidden" id="photo-url-<%=pageIndex%>-<%=qIndex%>" value="<%= mData.url || '' %>">
      <div class="feedback" id="photo-feedback-<%=pageIndex%>-<%=qIndex%>"></div>
      <% if (mData.url) { %><img src="<%= mData.url %>" class="photo-preview" onclick="openImage(this.src)"><% } %>
      <button class="btn" style="margin-top:15px; background: #eef2ff; color: #4f46e5; border: 2px solid #c7d2fe;" onclick="setAsTeamPhoto(document.getElementById('photo-url-<%=pageIndex%>-<%=qIndex%>').value)">⭐ Gebruik als profielfoto</button>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <% 
      var isTimed = mData.isTimed === "true" || mData.isTimed === true; 
      var limit = Number(mData.timeLimit) || 60;
      var maxPts = Number(mData.maxPoints) || 10;
      var pSec = Number(mData.penaltySec) || 10;
      var pPts = Number(mData.penaltyPoints) || 1;
      var qTextClean = t(mData.question).replace(/'/g, "\\'");
    %>
    
    <% if (isTimed) { %>
      <div id="prep-screen-<%= qIndex %>" class="card" style="border: 3px solid #f59e0b; text-align: center; padding: 30px 20px;">
        <div style="font-size: 50px; margin-bottom: 10px;">⏱️</div>
        <h3 style="color: #d97706; margin-top:0; font-size: 22px;">Tijdsgebonden Opdracht</h3>
        <p style="color: #475569; font-size: 16px;">Je hebt <strong><%= limit %> seconden</strong>. Hierna verdien je steeds minder punten!<br><small style="opacity: 0.7; font-size: 13px;">(De pagina opnieuw laden heeft geen zin 😉)</small></p>
        <button class="btn" style="background: #f59e0b; margin-top: 20px; font-size: 18px;" onclick="startTimedChallenge('<%= qIndex %>', '<%= qId %>', <%= limit %>, <%= pSec %>, <%= pPts %>, <%= maxPts %>)">🚀 Start de Tijd!</button>
      </div>
    <% } %>

    <div class="card" id="question-content-<%= qIndex %>" style="<%= isTimed ? 'display:none;' : '' %>">
      <% if (isTimed) { %>
        <div style="background: #fffbeb; color: #d97706; padding: 12px 16px; font-weight: 800; border-radius: 8px; margin-bottom: 18px; border: 2px solid #fde68a; display: flex; justify-content: space-between; font-size: 18px;">
          <span>⏱️ <span id="timer-clock-<%= qIndex %>">00:00</span></span>
          <span>Potentieel: <strong id="timer-pts-<%= qIndex %>"><%= maxPts %></strong> pt</span>
        </div>
      <% } %>
      
      <strong style="display:block; margin-bottom: 15px; font-size:18px; line-height: 1.4;"><%= t(mData.question) %></strong>

      <% if (mData.questionType === "mc") { %>
        <div id="form-<%= qIndex %>" data-good="<%= mData.goodPage ?? '' %>" data-bad="<%= mData.badPage ?? '' %>" data-puzzle="<%= puzzle._id %>">
          <% (mData.options || []).forEach((opt,i)=>{ %>
            <label style="background: #f9fafb; padding: 14px; border-radius: 10px; border: 1px solid #e5e7eb; transition: 0.2s;">
              <input type="radio" name="mc-<%=qIndex%>" value="<%= !!opt.correct %>" style="width: 20px; height: 20px;"> 
              <span style="font-size: 16px;"><%= t(opt.text) %></span>
            </label>
          <% }) %>
          <button class="btn" style="margin-top:18px;" onclick="verifyMC(this, '<%= qIndex %>', '<%= qId %>', <%= maxPts %>, <%= limit %>, <%= pSec %>, <%= pPts %>, <%= isTimed %>, '<%= qTextClean %>')">Controleer Antwoord</button>
          <div class="feedback" id="fb-<%= qIndex %>"></div>
        </div>
      <% } else { %>
        <div id="form-<%= qIndex %>">
          <input type="text" id="open-ans-<%= qIndex %>" placeholder="Jouw antwoord..." style="background: #f9fafb; padding: 14px; font-size: 16px;">
          <input type="hidden" id="open-correct-<%= qIndex %>" value="<%= t(mData.answer) %>">
          <input type="hidden" id="good-<%= qIndex %>" value="<%= mData.goodPage ?? '' %>">
          <input type="hidden" id="bad-<%= qIndex %>" value="<%= mData.badPage ?? '' %>">
          <button class="btn" style="margin-top:15px;" onclick="verifyOpen(this, '<%= qIndex %>', '<%= qId %>', <%= maxPts %>, <%= limit %>, <%= pSec %>, <%= pPts %>, <%= isTimed %>, '<%= qTextClean %>')">Controleer Antwoord</button>
          <div class="feedback" id="fb-<%= qIndex %>"></div>
        </div>
      <% } %>

      <% if (Number(mData.hintCost) > 0) { %>
         <div class="hint-container">
           <button class="hint-btn" onclick="document.getElementById('hint-box-<%= qIndex %>').style.display='block'; this.style.display='none';">
             💡 Hint Nodig? (-<%= mData.hintCost %> pt)
           </button>
           
           <div id="hint-box-<%= qIndex %>" style="display:none; background: #fffbeb; padding: 15px; border-radius: 10px; border: 1px solid #fcd34d;">
              <% if (mData.hintType === 'static') { %>
                <button class="btn" style="background: #d97706; padding: 10px;" onclick="executeStaticHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.staticHintText) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">🔓 Koop Hint (-<%= mData.hintCost %> pt)</button>
              <% } else { %>
                <p style="margin-top:0; color: #92400e; font-size: 14px;">Stel een specifieke vraag aan de AI Hint-Meester (-<%= mData.hintCost %> pt):</p>
                <div style="display:flex; gap:8px;">
                  <input type="text" id="hint-in-<%= qIndex %>" placeholder="Waar loop je vast?" style="border-color: #fcd34d;">
                  <button class="btn" style="background: #d97706; width: auto; padding: 10px 16px;" onclick="executeAiHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.aiKnowledge) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">Vraag</button>
                </div>
              <% } %>
              <div id="hint-res-<%= qIndex %>" style="margin-top: 12px; font-size: 15px; font-weight: 600; color: #b45309; line-height: 1.5;"></div>
           </div>
         </div>
      <% } %>

    </div>
  <% } %>

  <% if (mod.type === 'aiphoto') { %>
    <div class="card" id="ai-mod-<%= qIndex %>" data-prompt="<%= t(mData.prompt) %>" data-maxpoints="<%= mData.points || 10 %>" style="border: 2px solid #c7d2fe; background: #fafafa;">
      <h3 style="margin-top: 0; color: #4f46e5;">✨ AI Opdracht</h3>
      <p style="margin-bottom: 15px; font-size: 16px;"><strong>Opdracht:</strong> <%= t(mData.instruction) %></p>
      
      <input type="file" accept="image/*" capture="environment" class="ai-file-input" style="display: none;">
      <button type="button" class="btn ai-camera-btn" style="background: #4f46e5;">📸 Maak Foto & Controleer</button>
      
      <div class="ai-status feedback" style="display: none; padding: 14px; border-radius: 8px;"></div>
      <img class="ai-preview" style="display: none; width: 100%; border-radius: 10px; margin-top: 15px; border: 1px solid #e5e7eb;">
    </div>
  <% } %>

<% if (mod.type === 'historychat') { %>
  <div class="card" data-maxturns="<%= mData.maxTurns || 3 %>" style="border: 2px solid #fee2e2; padding: 0; overflow: hidden;">
    <div style="background: #fee2e2; padding: 15px; display: flex; align-items: center; gap: 12px;">
      <div style="width: 45px; height: 45px; background: #991b1b; color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px;">🎭</div>
      <div>
        <strong style="display: block; color: #991b1b; font-size: 18px;"><%= t(mData.characterName) %></strong>
      </div>
    </div>
    <div id="chat-win-<%= qIndex %>" style="height: 350px; overflow-y: auto; padding: 15px; background: #fffcfc; display: flex; flex-direction: column; gap: 10px; scroll-behavior: smooth;">
      <div style="background: #f3f4f6; padding: 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; max-width: 85%;">Gegroet! Heb je een vraag?</div>
      
      <div id="typing-indicator-<%= qIndex %>" class="typing-indicator" style="display: none;">
        <span></span><span></span><span></span>
      </div>
    </div>
    <div style="padding: 12px; border-top: 1px solid #fee2e2; display: flex; gap: 10px; background: white;">
      <input type="text" id="chat-input-<%= qIndex %>" placeholder="Stel je vraag..." style="background: #f9fafb; border-radius: 20px;">
      <button id="chat-btn-<%= qIndex %>" style="background: #991b1b; color: white; border: none; width: 50px; border-radius: 25px; cursor: pointer;">➤</button>
    </div>
  </div>
<% } %>

  <% if (mod.type === 'feedback') { %>
    <div class="card" style="border: 3px solid #06b6d4; background: #ecfeff; text-align: center; padding: 30px 20px; box-shadow: 0 10px 25px rgba(6, 182, 212, 0.2);">
      <h2 style="color: #0891b2; margin-bottom: 10px; font-size: 28px;">🎉 Jullie zijn er!</h2>
      <p style="color: #155e75; font-size: 16px; margin-bottom: 20px;">Hoe vonden jullie deze speurtocht? Wat was het leukste of meest frustrerende moment?</p>
      
      <textarea id="finale-feedback" rows="4" placeholder="Typ hier jullie reactie (leuk voor de AI!)..." style="border: 2px solid #67e8f9; margin-bottom: 15px;"></textarea>
      
      <button id="btn-finale" class="btn" style="background: #0891b2; font-size: 18px;" onclick="triggerFinale('<%= puzzle._id %>')">
        ✨ Sluit af & Genereer Reisverslag
      </button>

      <div id="finale-loading" style="display: none; margin-top: 20px; color: #0891b2; font-weight: bold; font-size: 16px;">
        <span style="font-size: 30px; display: block; animation: spin 1.5s linear infinite; margin-bottom: 10px;">⏳</span>
        De AI Ceremoniemeester analyseert jullie logboek...
      </div>

      <div id="finale-result" style="display: none; margin-top: 25px; background: white; border-radius: 12px; padding: 20px; text-align: left; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h3 style="color: #111827; margin-top: 0; font-size: 22px; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px;">📜 Het Oordeel</h3>
        <div id="finale-text" style="color: #374151; line-height: 1.7; font-size: 16px; margin-bottom: 20px; white-space: pre-wrap;"></div>
        
        <div style="background: #fef3c7; border: 2px solid #fde68a; border-radius: 10px; padding: 20px; text-align: center; margin-bottom: 20px;">
          <strong style="display: block; color: #92400e; font-size: 16px; text-transform: uppercase; letter-spacing: 1px;">Eindscore</strong>
          <div style="font-size: 48px; font-weight: 900; color: #b45309; line-height: 1;"><span id="finale-score">0</span><span style="font-size: 24px;">pt</span></div>
          <div style="color: #92400e; font-size: 15px; margin-top: 5px; font-weight: bold;">Geklaard in <span id="finale-time">0</span> minuten</div>
        </div>

        <a href="/leaderboard/<%= puzzle._id %>" class="btn" style="background: #f59e0b; text-decoration: none;">🏆 Bekijk de Hall of Fame</a>
      </div>
    </div>
  <% } %>

<% }) %> 

<% if (page.showNext && pageIndex + 1 < puzzle.pages.length) { %>
  <a class="btn secondary" href="/puzzle/<%= puzzle._id %>/<%= pageIndex + 1 %>">Volgende pagina →</a>
<% } %>

<div class="img-overlay" id="imgOverlay" onclick="this.style.display='none'"><img id="overlayImg"></div>

<script>
function openImage(src){ document.getElementById("overlayImg").src = src; document.getElementById("imgOverlay").style.display = "flex"; }
function updateGlobalScore(newScore) { const el = document.getElementById("ui-score"); if(el) el.innerText = newScore; }

window.activeTimers = {};

async function startTimedChallenge(idx, questionId, limit, pSec, pPts, maxPts) {
  document.getElementById(`prep-screen-${idx}`).style.display = 'none';
  document.getElementById(`question-content-${idx}`).style.display = 'block';
  
  try {
    await fetch('/api/timer/start', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({ questionId }) });
  } catch(e) { console.error("Klok kon niet op server starten."); }

  window.activeTimers[idx] = { startTime: Date.now(), limit, pSec, pPts, maxPts };
  const clockEl = document.getElementById(`timer-clock-${idx}`);
  const ptsEl = document.getElementById(`timer-pts-${idx}`);
  
  setInterval(() => {
    if(!window.activeTimers[idx]) return;
    let passed = Math.floor((Date.now() - window.activeTimers[idx].startTime) / 1000);
    clockEl.innerText = `${String(Math.floor(passed / 60)).padStart(2, '0')}:${String(passed % 60).padStart(2, '0')}`;
    let currentPts = maxPts;
    if (passed > limit) {
      currentPts = Math.max(0, maxPts - (Math.floor((passed - limit) / pSec) * pPts));
      clockEl.parentElement.parentElement.style.background = "#fee2e2"; 
      clockEl.parentElement.parentElement.style.borderColor = "#fecaca"; 
      clockEl.parentElement.parentElement.style.color = "#991b1b"; 
    }
    ptsEl.innerText = currentPts;
  }, 1000);
}

async function handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, questionText) {
  btn.disabled = true;
  const fb = document.getElementById(`fb-${idx}`);
  fb.innerHTML = "✅ Correct! Score verwerken..."; fb.style.color = "#166534";
  
  try {
    let res;
    if (isTimed) {
      delete window.activeTimers[idx];
      res = await fetch('/api/timer/stop', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ questionId, maxPts, limit, pSec, pPts, logMessage: `Vraag beantwoord: "${questionText}"` })
      });
    } else {
      res = await fetch('/api/log-action', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ points: maxPts, logMessage: `Vraag correct beantwoord: "${questionText}"` })
      });
    }
    const data = await res.json();
    updateGlobalScore(data.totalScore);
    fb.innerHTML = `✅ Goed! (+${isTimed ? data.earnedPoints : maxPts} pt)`;
    
    setTimeout(() => {
      const form = document.getElementById(`form-${idx}`);
      const goodPage = isTimed ? form.parentElement.querySelector(`[data-good]`)?.dataset.good : document.getElementById(`good-${idx}`)?.value;
      const puzzleId = isTimed ? form.dataset.puzzle : "<%= puzzle._id %>";
      if(goodPage && goodPage !== "") window.location.href = `/puzzle/${puzzleId}/${goodPage}`;
    }, 1500);

  } catch(e) {
    fb.innerHTML = "⚠️ Netwerkfout bij opslaan. Je antwoord was wel goed!";
  }
}

function verifyMC(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText) {
  const form = document.getElementById(`form-${idx}`);
  const fb = document.getElementById(`fb-${idx}`);
  const checked = form.querySelector('input:checked');
  if(!checked) { fb.innerHTML = "Kies eerst een antwoord."; fb.style.color = "#991b1b"; return; }
  
  if (checked.value === "true") {
    handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText);
  } else {
    fb.innerHTML = "❌ Helaas, dat is niet juist."; fb.style.color = "#991b1b";
  }
}

function verifyOpen(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText) {
  const ans = document.getElementById(`open-ans-${idx}`).value.trim().toLowerCase();
  const correct = document.getElementById(`open-correct-${idx}`).value.trim().toLowerCase();
  const fb = document.getElementById(`fb-${idx}`);
  
  if(ans === correct && ans !== "") {
    handleCorrectAnswer(btn, idx, questionId, maxPts, limit, pSec, pPts, isTimed, qText);
  } else {
    fb.innerHTML = "❌ Fout antwoord, probeer het nog eens!"; fb.style.color = "#991b1b";
  }
}

async function executeStaticHint(btn, idx, staticTextEn, cost, qText, qId) {
  if (!confirm(`Weet je het zeker? Een hint vragen kost punten! (Let op: een tweede hint kost extra).`)) return;
  
  btn.disabled = true; btn.innerHTML = "Laden...";
  try {
    const res = await fetch('/api/get-hint', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ hintType: 'static', staticHintText: decodeURIComponent(staticTextEn), hintCost: cost, questionText: qText, questionId: qId })
    });
    const data = await res.json();
    if (data.limitReached) btn.style.display = 'none';
    document.getElementById(`hint-res-${idx}`).innerHTML = "💡 " + (data.hint || "De Hint-Meester kon even geen antwoord vinden.");
    updateGlobalScore(data.newScore);
    if (!data.limitReached) { btn.disabled = false; btn.innerHTML = "🔓 Koop nog een hint (+2 pt extra)"; }
  } catch(e) { btn.disabled = false; btn.innerHTML = "⚠️ Fout, probeer opnieuw"; }
}

async function executeAiHint(btn, idx, aiKnowledgeEn, cost, qText, qId) {
  const input = document.getElementById(`hint-in-${idx}`);
  const msg = input.value.trim();
  if(!msg) { alert("Typ eerst je vraag!"); return; }
  
  if (!confirm(`Weet je zeker dat je dit wilt vragen? Dit kost punten! (Let op: een 2e vraag kost extra).`)) return;
  
  btn.disabled = true; input.disabled = true; btn.innerHTML = "⏳";
  const resDiv = document.getElementById(`hint-res-${idx}`);
  resDiv.innerHTML = "<em>Hint-Meester denkt na...</em>";

  try {
    const res = await fetch('/api/get-hint', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ hintType: 'ai', userMessage: msg, secretKnowledge: decodeURIComponent(aiKnowledgeEn), hintCost: cost, questionText: qText, questionId: qId })
    });
    const data = await res.json();
    
    if (data.limitReached) {
       input.style.display = 'none'; btn.style.display = 'none';
    }
    
    resDiv.innerHTML = "🤖 " + (data.hint || "De AI gaf een leeg antwoord. Probeer het opnieuw.");
    updateGlobalScore(data.newScore);
    if (!data.limitReached) { btn.innerHTML = "Vraag (Kans 2/2)"; btn.disabled = false; input.disabled = false; input.value = ""; }
  } catch(e) { resDiv.innerHTML = "⚠️ De AI is even offline."; btn.disabled = false; input.disabled = false; btn.innerHTML = "Vraag"; }
}

async function triggerFinale(puzzleId) {
  const btn = document.getElementById('btn-finale');
  const loading = document.getElementById('finale-loading');
  const result = document.getElementById('finale-result');
  const feedback = document.getElementById('finale-feedback').value;

  btn.style.display = 'none';
  loading.style.display = 'block';

  try {
    const res = await fetch('/api/generate-finale-report', {
      method: 'POST', headers: {'Content-Type': 'application/json'},
      body: JSON.stringify({ userFeedback: feedback, puzzleId: puzzleId })
    });
    const data = await res.json();
    
    loading.style.display = 'none';
    result.style.display = 'block';
    
    document.getElementById('finale-text').innerHTML = data.report.replace(/\n/g, '<br>');
    document.getElementById('finale-score').innerText = data.score;
    document.getElementById('finale-time').innerText = data.timeMin;

    if (typeof confetti === "function") {
      var duration = 3000; var end = Date.now() + duration;
      (function frame() {
        confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: ['#0891b2', '#fbbf24', '#4f46e5'] });
        confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, colors: ['#0891b2', '#fbbf24', '#4f46e5'] });
        if (Date.now() < end) requestAnimationFrame(frame);
      }());
    }
  } catch (e) {
    loading.innerHTML = "⚠️ Oeps, de ceremoniemeester is offline gegaan.";
  }
}

document.querySelectorAll('.ai-camera-btn').forEach(btn => {
  btn.addEventListener('click', () => btn.parentElement.querySelector('.ai-file-input').click());
});

document.querySelectorAll('.ai-file-input').forEach(input => {
  input.addEventListener('change', async () => {
    const file = input.files[0]; if (!file) return;
    const mod = input.closest('.card');
    const btn = mod.querySelector('.ai-camera-btn');
    const statusDiv = mod.querySelector('.ai-status');
    const previewImg = mod.querySelector('.ai-preview');

    btn.disabled = true; btn.innerHTML = "🤖 AI jury overlegt...";
    statusDiv.style.display = "block"; statusDiv.style.background = "#eef2ff"; statusDiv.style.color = "#4f46e5";
    statusDiv.innerHTML = "De jury analyseert je foto...";
    previewImg.src = URL.createObjectURL(file); previewImg.style.display = "block";

    const fd = new FormData();
    fd.append("file", file); fd.append("prompt", mod.dataset.prompt); fd.append("maxPoints", mod.dataset.maxpoints);

    try {
      const res = await fetch('/api/verify-aiphoto', { method: 'POST', body: fd });
      const result = await res.json();
      if (!res.ok) throw new Error(result.error);
      
      const currentScore = parseInt(document.getElementById("ui-score")?.innerText || "0");
      updateGlobalScore(currentScore + result.pointsAwarded);

      if (result.match) {
        statusDiv.style.background = "#dcfce7"; statusDiv.style.color = "#166534";
        statusDiv.innerHTML = `✅ <strong>Goedgekeurd!</strong> (Jury Score: ${result.score}%)<br>Je verdient <strong>${result.pointsAwarded} / ${result.maxPoints} pt!</strong><br><small>${result.reason}</small>`;
        btn.style.display = "none"; 
      } else {
        statusDiv.style.background = "#fee2e2"; statusDiv.style.color = "#991b1b";
        statusDiv.innerHTML = "❌ <strong>Helaas!</strong><br>" + result.reason;
        btn.disabled = false; btn.innerHTML = "📸 Probeer opnieuw";
      }
    } catch (err) {
      statusDiv.style.background = "#fee2e2"; statusDiv.style.color = "#991b1b"; statusDiv.innerHTML = "⚠️ Fout: " + err.message;
      btn.disabled = false; btn.innerHTML = "📸 Probeer opnieuw";
    }
  });
});

document.querySelectorAll('[id^="chat-btn-"]').forEach(btn => {
  btn.addEventListener('click', async () => {
    const idx = btn.id.split('-').pop();
    const input = document.getElementById(`chat-input-${idx}`);
    const win = document.getElementById(`chat-win-${idx}`);
    const msg = input.value.trim();
    if(!msg) return;

    input.value = ''; input.disabled = true; btn.disabled = true;
    win.innerHTML += `<div style="background: #991b1b; color: white; padding: 12px; border-radius: 12px 12px 0 12px; align-self: flex-end; max-width: 85%;">${msg}</div>`;
    win.scrollTop = win.scrollHeight;

    try {
      const mod = btn.closest('.card');
      const charName = mod.querySelector('strong').innerText; 
      
      // Toon typing indicator & scroll naar beneden
      const indicator = document.getElementById(`typing-indicator-${idx}`);
      win.appendChild(indicator); // Verplaats hem naar onderen
      indicator.style.display = 'block';
      win.scrollTop = win.scrollHeight;

      const res = await fetch('/api/chat-persona', {
        method: 'POST', headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ 
          message: msg, 
          characterName: charName, 
          systemPrompt: "Je bent " + charName,
          maxTurns: mod.dataset.maxturns,
          history: [] // Optioneel: Voeg history array hier later toe
        })
      });
      
      indicator.style.display = 'none'; // Verberg typen zodra API klaar is
      const data = await res.json();
      
      win.innerHTML += `<div style="background: #f3f4f6; padding: 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; max-width: 85%;">${data.reply || "..."}</div>`;
      win.appendChild(indicator); // Zet indicator weer helemaal onderaan (verborgen)
      
      if (data.closeChat) {
         input.placeholder = "Gesprek beëindigd door " + charName;
         input.disabled = true; 
         btn.style.opacity = "0.5";
         btn.disabled = true;
         return;
      }

    } catch(e) { 
      document.getElementById(`typing-indicator-${idx}`).style.display = 'none';
      win.innerHTML += `<div style="color:red; text-align:center; font-size:12px;">Fout bij laden bericht.</div>`; 
    }
      
      const data = await res.json();
      win.innerHTML += `<div style="background: #f3f4f6; padding: 12px; border-radius: 12px 12px 12px 0; align-self: flex-start; max-width: 85%;">${data.reply || "..."}</div>`;
      
      if (data.closeChat) {
         input.placeholder = "Gesprek beëindigd.";
         input.disabled = true; 
         btn.style.opacity = "0.5";
         btn.disabled = true;
         return;
      }

    } catch(e) { 
      win.innerHTML += `<div style="color:red; text-align:center; font-size:12px;">Fout bij laden bericht.</div>`; 
    }
    
    input.disabled = false; btn.disabled = false; win.scrollTop = win.scrollHeight;
  });
});

async function uploadPhoto(input, pIdx, mIdx) {
  const file = input.files?.[0]; if (!file) return;
  const fb = document.getElementById(`photo-feedback-${pIdx}-${mIdx}`);
  const fd = new FormData(); fd.append("file", file); fb.textContent = "Uploaden…";
  try {
    const res = await fetch("/upload-photo", { method: "POST", body: fd });
    if (!res.ok) throw new Error();
    const json = await res.json();
    document.getElementById(`photo-url-${pIdx}-${mIdx}`).value = json.url;
    fb.textContent = "✅ Foto opgeslagen"; fb.style.color = "green";
  } catch { fb.textContent = "❌ Upload mislukt"; fb.style.color = "red"; }
}

async function setAsTeamPhoto(url) {
  if (!url) { alert("Maak eerst een foto."); return; }
  if (confirm("Deze foto instellen als teamfoto?")) {
    const res = await fetch("/team/profile-photo", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ photoUrl:url }) });
    if (res.ok) location.reload(); else alert("Instellen mislukt");
  }
}
// Gamification Animatie
function popScoreAnim(points) {
  const el = document.createElement("div");
  el.className = "score-float";
  el.innerText = "+" + points;
  document.body.appendChild(el);
  setTimeout(() => el.remove(), 1600);
}

// Overschrijf de oude updateGlobalScore om animaties af te spelen!
const oldUpdate = updateGlobalScore;
updateGlobalScore = function(newScore) {
  const el = document.getElementById("ui-score");
  if(el) {
    const oldScore = parseInt(el.innerText || 0);
    if(newScore > oldScore) popScoreAnim(newScore - oldScore);
    el.innerText = newScore;
  }
};

async function saveTeamName() {
  const nameEl = document.getElementById("team-name-input");
  const emailEl = document.getElementById("team-email-input");
  if(!nameEl || !emailEl) return;
  
  const name = nameEl.value.trim();
  const email = emailEl.value.trim();
  const fb = document.getElementById("teamname-feedback");

  if (!name || !email) { fb.textContent = "Vul beide velden in!"; fb.style.color = "red"; return; }

  fb.textContent = "Opslaan..."; fb.style.color = "black";
  
  // Haal puzzle ID uit de pagina URL of een verborgen veld
  const puzzleId = "<%= puzzle._id %>"; 

  const res = await fetch("/team/name", { 
    method: "POST", 
    headers: { "Content-Type": "application/json" }, 
    body: JSON.stringify({ name, email, puzzleId }) 
  });
  
  const data = await res.json();
  if (res.ok) { 
    fb.textContent = data.isReturningUser ? "✅ Welkom terug! De klok loopt." : "✅ Team geregistreerd! De klok loopt."; 
    fb.style.color = "green"; 
    nameEl.disabled = true; emailEl.disabled = true;
    setTimeout(()=>location.reload(), 1000); 
  } else { 
    fb.textContent = "❌ Opslaan mislukt"; fb.style.color = "red"; 
  }
}
</script>

<% if (typeof isCompleted !== 'undefined' && isCompleted) { %>
  <script>
    document.querySelectorAll('input, select, textarea, button').forEach(el => {
      el.disabled = true;
      el.style.opacity = '0.5';
      el.style.cursor = 'not-allowed';
    });
    document.querySelectorAll('a.btn.secondary').forEach(el => {
      el.style.opacity = '1';
      el.style.cursor = 'pointer';
      el.style.pointerEvents = 'auto';
    });
  </script>
<% } %>

<% if (page.isMap) { %>
<script>
  const target = L.latLng(<%= page.targetLat || 0 %>, <%= page.targetLng || 0 %>);
  const radius = <%= page.targetRadius || 50 %>;
  const showTarget = <%= page.showTarget ? "true" : "false" %>;
  const autoNext = <%= page.autoNext ? "true" : "false" %>;
  if (<%= page.targetLat || 0 %> !== 0 && <%= page.targetLng || 0 %> !== 0) {
    const map = L.map("map").setView(target,16);
    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png").addTo(map);
    if(showTarget){ L.marker(target).addTo(map); L.circle(target,{radius,color:"green",fillOpacity:.15}).addTo(map); }
    const fb = document.getElementById("mapFeedback");
    const nextBtn = document.querySelector(".btn.secondary");
    navigator.geolocation.watchPosition(p=>{
      const user = L.latLng(p.coords.latitude,p.coords.longitude); map.setView(user,17);
      L.marker(user).addTo(map);
      const d = map.distance(user,target);
      if(d<=radius){
        fb.textContent="✅ Doel bereikt!"; fb.style.color="green";
        if(autoNext && nextBtn) setTimeout(()=>location.href=nextBtn.href,1000);
      } else { fb.textContent=`Afstand: ${Math.round(d)} meter`; }
    },()=>{ fb.textContent="Locatie niet beschikbaar"; fb.style.color="red"; });
  } else { document.getElementById("mapFeedback").textContent = "Geen doellocatie ingesteld voor deze kaart."; }
</script>
<% } %>

