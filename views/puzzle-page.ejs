  <% if (mod.type === 'feedback') { %>
    <div class="card" style="border: 3px solid #06b6d4; background: #ecfeff; text-align: center; padding: 30px 20px; box-shadow: 0 10px 25px rgba(6, 182, 212, 0.2);">
      <h2 style="color: #0891b2; margin-bottom: 10px; font-size: 28px;">🎉 Jullie zijn er!</h2>
      <p style="color: #155e75; font-size: 16px; margin-bottom: 20px;">Hoe vonden jullie deze speurtocht? Wat was het leukste of meest frustrerende moment?</p>
      
      <textarea id="finale-feedback" rows="4" placeholder="Typ hier jullie reactie (leuk voor de AI!)..." style="border: 2px solid #67e8f9; margin-bottom: 15px;"></textarea>
      
      <button id="btn-finale" class="btn" style="background: #0891b2; font-size: 18px;" onclick="triggerFinale('<%= puzzle._id %>')">
        ✨ Sluit af & Genereer Reisverslag
      </button>

      <div id="finale-loading" style="display: none; margin-top: 20px; color: #0891b2; font-weight: bold; font-size: 16px;">
        <span style="font-size: 30px; display: block; animation: spin 1.5s linear infinite; margin-bottom: 10px;">⏳</span>
        De AI Ceremoniemeester analyseert jullie logboek...
      </div>

      <div id="finale-result" style="display: none; margin-top: 25px; background: white; border-radius: 12px; padding: 20px; text-align: left; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
        <h3 style="color: #111827; margin-top: 0; font-size: 22px; border-bottom: 2px solid #e5e7eb; padding-bottom: 10px;">📜 Het Oordeel</h3>
        <div id="finale-text" style="color: #374151; line-height: 1.7; font-size: 16px; margin-bottom: 20px; white-space: pre-wrap;"></div>
        
        <div style="background: #fef3c7; border: 2px solid #fde68a; border-radius: 10px; padding: 20px; text-align: center; margin-bottom: 20px;">
          <strong style="display: block; color: #92400e; font-size: 16px; text-transform: uppercase; letter-spacing: 1px;">Eindscore</strong>
          <div style="font-size: 48px; font-weight: 900; color: #b45309; line-height: 1;"><span id="finale-score">0</span><span style="font-size: 24px;">pt</span></div>
          <div style="color: #92400e; font-size: 15px; margin-top: 5px; font-weight: bold;">Geklaard in <span id="finale-time">0</span> minuten</div>
