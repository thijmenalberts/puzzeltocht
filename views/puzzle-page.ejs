<!DOCTYPE html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= puzzle.name %> — <%= page.title %></title>

  <style>
    body {
      font-family: system-ui, sans-serif;
      background: #f5f7fa;
      padding: 24px;
    }
    .card {
      background: #fff;
      padding: 16px;
      border-radius: 12px;
      margin-bottom: 16px;
      box-shadow: 0 4px 12px rgba(0,0,0,.08);
    }
    .btn {
      padding: 10px 16px;
      border-radius: 8px;
      border: none;
      background: #2563eb;
      color: #fff;
      cursor: pointer;
      margin-top: 12px;
      font-size: 15px;
    }
    .btn.secondary {
      background: #334155;
    }
    .feedback {
      margin-top: 8px;
      font-weight: 600;
    }
    label {
      display: flex;
      gap: 8px;
      margin-top: 6px;
      cursor: pointer;
    }
  </style>
</head>

<body>

<h1><%= puzzle.name %></h1>
<h2><%= page.title %></h2>

<% (page.modules || []).forEach((mod, i) => { %>

  <% if (mod.type === "text") { %>
    <div class="card">
      <%- mod.data?.text || "" %>
    </div>
  <% } %>

  <% if (mod.type === "question") { %>
    <div class="card">
      <strong><%= mod.data.question %></strong>

      <% if (mod.data.questionType === "mc") { %>
        <div
          data-mc
          data-options='<%- JSON.stringify(mod.data.options || []) %>'
          data-good="<%= mod.data.goodPage ?? "" %>"
          data-bad="<%= mod.data.badPage ?? "" %>"
          data-puzzle="<%= puzzle.id %>"
        >

          <% (mod.data.options || []).forEach((opt, x) => { %>
            <label>
              <input type="radio" name="mc-<%= i %>" value="<%= x %>">
              <%= opt.text %>
            </label>
          <% }) %>

          <button class="btn" onclick="handleMC(this)">Controleer</button>
          <div class="feedback"></div>
        </div>

      <% } else { %>
        <form onsubmit="return handleOpen(event, this)">
          <input name="answer" placeholder="Jouw antwoord">
          <button class="btn">Controleer</button>
          <div class="feedback"></div>

          <input type="hidden" name="correct" value="<%= mod.data.answer %>">
          <input type="hidden" name="good" value="<%= mod.data.goodPage ?? '' %>">
          <input type="hidden" name="bad" value="<%= mod.data.badPage ?? '' %>">
          <input type="hidden" name="puzzle" value="<%= puzzle.id %>">
        </form>
      <% } %>
    </div>
  <% } %>

<% }) %>

<%
  const hasNextPage = page.showNext === true
    && Array.isArray(puzzle.pages)
    && typeof pageIndex === "number"
    && pageIndex + 1 < puzzle.pages.length;
%>

<% if (hasNextPage) { %>
  <button
    class="btn secondary"
    onclick
    Volgende pagina →
  </button>
<% } %>

<script>
function handleMC(btn) {
  const b = btn.closest('[data-mc]');
  const fb = b.querySelector('.feedback');
  const r = b.querySelector('input:checked');
  if (!r) return fb.textContent = "Kies een antwoord.";

  const opts = JSON.parse(b.dataset.options);
  const ok = !!opts[r.value]?.correct;

  const go = ok ? b.dataset.good : b.dataset.bad;
  if (go !== "") {
    location.href = `/puzzle/${b.dataset.puzzle}/${go}`;
    return;
  }

  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
}

function handleOpen(e, f) {
  e.preventDefault();
  const a = f.answer.value.trim().toLowerCase();
  const c = f.correct.value.trim().toLowerCase();
  const ok = a === c;

  const go = ok ? f.good.value : f.bad.value;
  if (go !== "") {
    location.href = `/puzzle/${f.puzzle.value}/${go}`;
    return false;
  }

  const fb = f.querySelector('.feedback');
  fb.textContent = ok ? "Goed!" : "Fout!";
  fb.style.color = ok ? "green" : "red";
  return false;
}
</script>

</body>
</html>
