      <% if (Number(mData.hintCost) > 0) { %>
         <div class="hint-container">
           <button class="hint-btn" onclick="document.getElementById('hint-box-<%= qIndex %>').style.display='block'; this.style.display='none';">
             💡 Hint Nodig? (-<%= mData.hintCost %> pt)
           </button>
           
           <div id="hint-box-<%= qIndex %>" style="display:none; background: #fffbeb; padding: 15px; border-radius: 10px; border: 1px solid #fcd34d;">
              <% if (mData.hintType === 'static') { %>
                <button class="btn" style="background: #d97706; padding: 10px;" onclick="executeStaticHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.staticHintText) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">🔓 Koop Hint (-<%= mData.hintCost %> pt)</button>
              <% } else { %>
                <p style="margin-top:0; color: #92400e; font-size: 14px;">Stel een specifieke vraag aan de AI Hint-Meester (-<%= mData.hintCost %> pt):</p>
                <div style="display:flex; gap:8px;">
                  <input type="text" id="hint-in-<%= qIndex %>" placeholder="Waar loop je vast?" style="border-color: #fcd34d;">
                  <button class="btn" style="background: #d97706; width: auto; padding: 10px 16px;" onclick="executeAiHint(this, '<%= qIndex %>', '<%= encodeURIComponent(mData.aiKnowledge) %>', <%= mData.hintCost %>, '<%= qTextClean %>', '<%= qId %>')">Vraag</button>
                </div>
              <% } %>
              <div id="hint-res-<%= qIndex %>" style="margin-top: 12px; font-size: 15px; font-weight: 600; color: #b45309; line-height: 1.5;"></div>
           </div>
         </div>
      <% } %>

    </div>
  <% } %>

  <% if (mod.type === 'aiphoto') { %>
    <div class="card" id="ai-mod-<%= qIndex %>" data-prompt="<%= t(mData.prompt) %>" data-maxpoints="<%= mData.points || 10 %>" style="border: 2px solid #c7d2fe; background: #fafafa;">
