<style>
  body {
    max-width: none !important;
  }

  main, .container {
    max-width: none !important;
    width: 100% !important;
  }

  .file-card:hover .delete-btn {
    opacity: 1;
  }

  .preview-img {
    object-fit: cover;
    height: 160px;
    width: 100%;
  }
</style>

<section class="max-w-screen-2xl mx-auto p-8">

  <!-- Header -->
  <div class="flex items-center gap-4 mb-10">
    <a href="/admin-files"
       class="bg-gray-100 hover:bg-gray-200 text-gray-700
              px-4 py-2 rounded-lg font-bold transition">
      ← Terug
    </a>

    <h1 class="text-2xl font-black text-gray-900">
      📁 <%= displayName %>
    </h1>
  </div>

  <% if (!files || files.length === 0) { %>
    <div class="text-gray-500 italic">
      Deze map is leeg.
    </div>
  <% } else { %>

    <div class="grid grid-cols-4 xl:grid-cols-5 gap-6">

      <% files.forEach(file => { 
           const filePath =
             folder === '__root__'
               ? `/uploads/${file.name}`
               : `/uploads/${folder}/${file.name}`;
      %>

        <div class="file-card group relative bg-white rounded-xl border border-gray-200
            shadow-sm overflow-hidden hover:border-indigo-300 transition-all">

          <!-- Preview -->
          <div class="bg-gray-100 border-b">
            <% if (file.name.match(/\.(jpg|jpeg|png|gif|webp)$/i)) { %>
              <img src="<%= filePath %>"
                   class="preview-img"
                   alt="<%= file.name %>">
            <% } else if (file.name.match(/\.(mp3|wav|ogg)$/i)) { %>
              <div class="h-[160px] flex flex-col items-center justify-center bg-amber-50 p-3">
                <span class="text-2xl mb-2">🎵</span>
                <audio controls class="w-full opacity-90">
                  <source src="<%= filePath %>">
                </audio>
              </div>
            <% } else { %>
              <div class="h-[160px] flex items-center justify-center text-4xl bg-gray-50">
                📄
              </div>
            <% } %>
          </div>

          <!-- Info -->
          <div class="p-4">
            <input
              type="text"
              value="<%= file.name %>"
              class="w-full text-sm font-bold text-gray-800 bg-transparent border
                     border-transparent rounded px-1 focus:border-indigo-400 focus:outline-none"
              onblur="renameFile('<%= folder === '__root__' ? '' : folder %>',
                                 '<%= file.name %>',
                                 this.value)"
              onkeydown="if (event.key === 'Enter') this.blur()"
              title="Klik om naam te wijzigen"
            />
          
            <p class="text-xs text-gray-400 mt-1">
              <%= (file.size / 1024).toFixed(1) %> KB
            </p>
          </div>

          <!-- Delete -->
          <div class="absolute top-2 right-2 flex gap-2 opacity-0 group-hover:opacity-100 transition">

            <!-- Kopieer link -->
            <button
              type="button"
              onclick="copyFileLink('<%= folder === '__root__' ? '' : folder %>', '<%= file.name %>')"
              title="Kopieer bestandslink"
              aria-label="Kopieer bestandslink"
              class="bg-gray-700 text-white p-2 rounded-lg hover:bg-gray-800 shadow">
              📋
            </button>
          
            <!-- Verwijderen -->
            <button
              type="button"
              onclick="deleteFile('<%= folder === '__root__' ? '' : folder %>', '<%= file.name %>')"
              title="Verwijderen"
              aria-label="Verwijderen"
              class="bg-red-500 text-white p-2 rounded-lg hover:bg-red-600 shadow">
              ✕
            </button>
          
          </div>
        </div>

      <% }) %>

    </div>

  <% } %>

  <!-- Toast -->
  <div id="toast"
       class="fixed bottom-6 right-6 bg-gray-900 text-white text-sm
              px-4 py-3 rounded-lg shadow-lg opacity-0 pointer-events-none
              transition-opacity duration-300 z-50">
  </div>

</section>

<script>
async function deleteFile(folder, file) {
  if (!confirm('Weet je zeker dat je dit bestand wilt verwijderen?')) return;

  try {
    const res = await fetch('/admin-files/delete', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ folder, file })
    });

    if (res.ok) {
      location.reload();
    } else {
      alert('Verwijderen mislukt');
    }
  } catch (e) {
    alert('Netwerkfout');
  }
}

async function renameFile(folder, oldName, newName) {
  if (!newName || newName === oldName) return;

  try {
    const res = await fetch('/admin-files/rename', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ folder, oldName, newName })
    });

    if (!res.ok) {
      alert('Hernoemen mislukt');
      location.reload();
    }
  } catch (e) {
    alert('Netwerkfout');
    location.reload();
  }
}

function showToast(message) {
  const toast = document.getElementById('toast');
  if (!toast) return;

  toast.textContent = message;
  toast.classList.remove('opacity-0');
  toast.classList.add('opacity-100');

  setTimeout(() => {
    toast.classList.remove('opacity-100');
    toast.classList.add('opacity-0');
  }, 2000);
}

async function copyFileLink(folder, file) {
  const path = folder
    ? `/uploads/${folder}/${file}`
    : `/uploads/${file}`;

  try {
    await navigator.clipboard.writeText(path);
    showToast('✅ Link gekopieerd');
  } catch (err) {
    showToast('❌ Kopiëren mislukt');
  }
}
</script>
