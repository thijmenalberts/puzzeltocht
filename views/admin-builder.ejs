        <div id="wrap-hint-static" style="display:none; margin-top:8px; background:#f9fafb; padding:10px; border-radius:8px; border:1px solid #e5e7eb;">
            <div class="helper" style="margin-bottom:4px; line-height:1.4;">Typ exact de tekst die de speler te zien krijgt als ze een hint kopen. (0 API kosten)</div>
            <textarea id="p-sh-global" rows="3" placeholder="Bijv: Kijk eens onder de houten bank." style="border:1px solid #d1d5db;"></textarea>
        </div>
        
        <label style="margin-top:12px; font-weight:700;">Hint Kosten (punten)</label>
        <div class="helper" style="margin-bottom:4px;">Zet op 0 of laat leeg om geen hint-knop te tonen.</div>
        <input type="number" id="p-hst-global">
      `;
      
      pDyn.insertAdjacentHTML('beforeend', hintUiHtml);

      const iType = document.getElementById("p-hint-type");
      const wrapAi = document.getElementById("wrap-hint-ai");
      const wrapStatic = document.getElementById("wrap-hint-static");
      const iAik = document.getElementById("p-aik-global");
      const iSh = document.getElementById("p-sh-global");
      const iHst = document.getElementById("p-hst-global");

      iType.value = sHTy.value || "ai";
      iAik.value = sAiK.value || "";
      iSh.value = sSHt.value || "";
      iHst.value = sHst.value || 0;

      const updateVisibility = () => {
          wrapAi.style.display = iType.value === 'ai' ? 'block' : 'none';
          wrapStatic.style.display = iType.value === 'static' ? 'block' : 'none';
      };
      updateVisibility();

      iType.onchange = () => { sHTy.value = iType.value; updateVisibility(); };
      iAik.oninput = () => { sAiK.value = iAik.value; };
      iSh.oninput = () => { sSHt.value = iSh.value; };
      iHst.oninput = () => { sHst.value = iHst.value; };
    }
  }

  function clearPanel(){ selected = null; pEmpty.style.display = "block"; pFields.style.display = "none"; pDyn.innerHTML = ""; }

  function collect(){
    const blocks = qsa(".block", phone).filter(b => b.dataset.type && b.dataset.type !== "__preview__");
    return blocks.map(b => {
      const type = b.dataset.type;
      let data = {};

      if (type === "title" || type === "text") {
        data[type] = { ...(b._data?.[type] || {}) };
        data[type][activeLanguage] = qs(`[data-field="${type}"]`, b)?.innerHTML || "";
      }
      if (type === "image" || type === "audio" || type === "photo") data.url = qs('[data-field="url"]', b)?.value?.trim() || "";
      if (type === "team-name" || type === "feedback") data = {}; // Feedback needs no data fields

      if (type === "question") {
        data.question = { ...(b._data?.question || {}) }; data.question[activeLanguage] = qs('[data-field="question"]', b)?.value || "";
        data.questionType = qs('[data-field="questionType"]', b)?.value || "open";
        if (data.questionType === "open") {
          data.answer = { ...(b._data?.answer || {}) }; data.answer[activeLanguage] = qs('[data-field="answer"]', b)?.value || "";
        } else {
          data.options = qsa('.mc-option', b).map((opt, i) => {
            const textObj = { ...(b._data?.options?.[i]?.text || {}) }; textObj[activeLanguage] = opt.querySelector('[data-text]')?.value || "";
            return { text: textObj, correct: !!opt.querySelector('[data-correct]')?.checked };
          });
        }
        data.goodPage = Number(qs('[data-field="goodPage"]', b)?.value) || null;
        data.badPage  = Number(qs('[data-field="badPage"]', b)?.value) || null;
        data.maxPoints = Number(qs('[data-field="pts"]', b)?.value) || 10;
        data.isTimed = qs('[data-field="istimed"]', b)?.value === "true";
        data.timeLimit = Number(qs('[data-field="tlimit"]', b)?.value) || 60;
        data.penaltyPoints = Number(qs('[data-field="ppen"]', b)?.value) || 1;
        data.penaltySec = Number(qs('[data-field="psec"]', b)?.value) || 10;
      }
      
      if (type === "aiphoto") {
        data.instruction = { ...(b._data?.instruction || {}) }; data.instruction[activeLanguage] = qs('[data-field="ai-instruction"]', b)?.value || "";
        data.prompt = { ...(b._data?.prompt || {}) }; data.prompt[activeLanguage] = qs('[data-field="ai-prompt"]', b)?.value || "";
        data.points = Number(qs('[data-field="ai-points"]', b)?.value) || 10;
      }

      if (type === "historychat") {
        data.characterName = { ...(b._data?.characterName || {}) }; data.characterName[activeLanguage] = qs('[data-field="chat-name"]', b)?.value || "";
        data.systemPrompt = { ...(b._data?.systemPrompt || {}) }; data.systemPrompt[activeLanguage] = qs('[data-field="chat-prompt"]', b)?.value || "";
        const lat = qs('[data-field="chat-lat"]', b)?.value; const lng = qs('[data-field="chat-lng"]', b)?.value; const rad = qs('[data-field="chat-radius"]', b)?.value;
        data.lat = lat !== "" ? Number(lat) : null; data.lng = lng !== "" ? Number(lng) : null; data.radius = rad !== "" ? Number(rad) : 50;
        data.maxTurns = Number(qs('[data-field="chat-max-turns"]', b)?.value) || 3;
      }
    
      if (type === "location") {
        const lat = qs('input[data-field="lat"]', b)?.value; const lng = qs('input[data-field="lng"]', b)?.value; const rad = qs('input[data-field="radius"]', b)?.value;
        data.lat = lat !== "" ? Number(lat) : null; data.lng = lng !== "" ? Number(lng) : null; data.radius = rad !== "" ? Number(rad) : 50;
      }

      // ⭐ FASE 2 & 3: UNIVERSELE GAMIFICATION OPSLAG
      data.aiKnowledge = qs('[data-field="aiknowledge"]', b)?.value || "";
      data.hintType = qs('[data-field="hinttype"]', b)?.value || "ai";
      data.staticHintText = qs('[data-field="statichint"]', b)?.value || "";
      data.hintCost = Number(qs('[data-field="hintcost"]', b)?.value) || 0;
      
      return { type, data };
    });
  }

<div style="background: #f8fafc; border: 1px solid #cbd5e1; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
  <h3 style="font-size: 12px; font-weight: 900; color: #334155; text-transform: uppercase; margin-top: 0;">🎨 Visueel Thema</h3>
  
  <label style="display: block; font-size: 11px; font-weight: bold; margin-top: 10px; margin-bottom: 4px;">Sfeer Preset:</label>
  <select id="theme-preset" style="width: 100%; padding: 8px; border-radius: 6px; border: 1px solid #cbd5e1; font-size: 13px;">
    <option value="standard" <%= puzzle.theme?.preset === 'standard' ? 'selected' : '' %>>Standaard (Modern)</option>
    <option value="medieval" <%= puzzle.theme?.preset === 'medieval' ? 'selected' : '' %>>🏰 Middeleeuwen (Perkament)</option>
    <option value="future" <%= puzzle.theme?.preset === 'future' ? 'selected' : '' %>>🚀 De Toekomst (Cyberpunk)</option>
    <option value="iceage" <%= puzzle.theme?.preset === 'iceage' ? 'selected' : '' %>>🥶 De Ijstijd (Bevroren)</option>
  </select>

  <label style="display: block; font-size: 11px; font-weight: bold; margin-top: 10px; margin-bottom: 4px;">Accent Kleur:</label>
  <input type="color" id="theme-color" value="<%= puzzle.theme?.primaryColor || '#4f46e5' %>" style="width: 100%; height: 35px; border: none; border-radius: 6px; cursor: pointer;">
</div>

  async function saveAll(){
    savePageSettings(); pages[currentPage].modules = collect();
    try{
      const res = await fetch(`/admin-builder/${phone.dataset.id}/save-all`, {
        method:"POST", headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ pages, languages: availableLanguages, defaultLanguage: puzzleMeta.defaultLanguage || activeLanguage })
      });
      if(!res.ok) throw new Error(); toast("Opgeslagen ✅");
    } catch { toast("Opslaan mislukt ❌", true); }
  }

  qs("#btn-save").addEventListener("click", saveAll);
  qs("#btn-reset").addEventListener("click", () => location.reload());
  qs("#add-page-btn").addEventListener("click", addPage);
  qs("#delete-page-btn").addEventListener("click", deletePage);

  // PAGE INPUT HANDLERS (MAP & GELUID)
  qs("#page-title-input").addEventListener("input", () => { pages[currentPage].title = pages[currentPage].title || {}; pages[currentPage].title[activeLanguage] = qs("#page-title-input").value; qs("#page-title-label").textContent = qs("#page-title-input").value; renderPageList(); });
  qs("#page-shownext").addEventListener("change", ()=> pages[currentPage].showNext = !!qs("#page-shownext").checked);
  qs("#page-ismap").addEventListener("change", () => { const isMap = !!qs("#page-ismap").checked; pages[currentPage].isMap = isMap; qs("#map-extra-options").style.display = isMap ? "block" : "none"; renderPage(currentPage); });
  qs("#page-showtarget").addEventListener("change", ()=>{ pages[currentPage].showTarget = !!qs("#page-showtarget").checked; if(pages[currentPage].isMap) updateMapPreview(); });
  qs("#page-autonext").addEventListener("change", ()=>{ pages[currentPage].autoNext = !!qs("#page-autonext").checked; if(pages[currentPage].isMap) updateMapPreview(); });
  qs("#page-playsound-start").addEventListener("change", () => { const checked = qs("#page-playsound-start").checked; pages[currentPage].playSoundOnStart = checked; qs("#sound-file-section").style.display = checked ? "block" : "none"; });
  qs("#page-soundurl").addEventListener("input", ()=>{ pages[currentPage].soundUrl = qs("#page-soundurl").value; });
  qs("#page-target-lat").addEventListener("input", (e)=>{ pages[currentPage].targetLat = e.target.value !== "" ? Number(e.target.value) : null; updateMapPreview(); });
  qs("#page-target-lng").addEventListener("input", (e)=>{ pages[currentPage].targetLng = e.target.value !== "" ? Number(e.target.value) : null; updateMapPreview(); });
  qs("#page-target-radius").addEventListener("input", (e)=>{ pages[currentPage].targetRadius = e.target.value !== "" ? Number(e.target.value) : 50; updateMapPreview(); });

  function updateMapPreview(){
    const pg = pages[currentPage]; if(!pg?.isMap) return;
    const wrap = phone.querySelector(".map-target-preview"); if(!wrap) return;
    const hasCoords = (pg.targetLat !== null && pg.targetLat !== "" && pg.targetLng !== null && pg.targetLng !== "");
    if(!hasCoords){ wrap.innerHTML = `<div class="helper">Nog geen doel ingesteld.</div>`; return; }
    
    const lat = Number(pg.targetLat), lng = Number(pg.targetLng), radius = Number(pg.targetRadius || 50);
    wrap.innerHTML = `
      <div style="display:flex; gap:12px; align-items:center;">
        <canvas id="map-mini" width="160" height="160" style="border:1px solid #e5e7eb; border-radius:10px; background:#fff;"></canvas>
        <div style="display:flex; flex-direction:column; gap:6px;">
          <div><strong>Doellocatie</strong></div>
          <div style="font-family: ui-monospace, monospace;">Lat: ${isFinite(lat)?lat.toFixed(6):"_"}<br>Lng: ${isFinite(lng)?lng.toFixed(6):"_"}</div>
          <div>Radius: <strong>${radius}</strong> meter</div>
        </div>
      </div>
    `;
    const cv = wrap.querySelector("#map-mini"), ctx = cv?.getContext("2d");
    if(ctx){
      ctx.clearRect(0,0,cv.width,cv.height); ctx.fillStyle = "#fff"; ctx.fillRect(0,0,cv.width,cv.height);
      ctx.fillStyle = "#eef2ff"; ctx.strokeStyle = "#6366f1"; ctx.lineWidth = 2;
      const pxRadius = Math.max(10, Math.min(70, radius / 5));
      ctx.beginPath(); ctx.arc(cv.width/2, cv.height/2, pxRadius, 0, Math.PI*2); ctx.fill(); ctx.stroke();
      ctx.fillStyle = "#111"; ctx.beginPath(); ctx.arc(cv.width/2, cv.height/2, 3, 0, Math.PI*2); ctx.fill();
    }
  }

  function toast(msg, error=false){
    const t = document.createElement("div"); t.textContent = msg;
    Object.assign(t.style, { position: 'fixed', right: '20px', bottom: '20px', background: error ? '#ef4444' : 'var(--primary)', color: '#fff', padding: '10px 14px', borderRadius: '12px', boxShadow: '0 8px 24px rgba(0,0,0,.2)', zIndex: '9999', fontSize: '14px' });
    document.body.appendChild(t); setTimeout(() => t.remove(), 2000);
  }

  updateLanguageSelect(); renderPageList(); renderPage(currentPage);
})();
</script>
</div>
