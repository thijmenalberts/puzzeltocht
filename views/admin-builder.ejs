  function getAfterEl(container, y){
    const blocks = qsa(".block:not(.dragging)", container);

    return blocks.reduce((closest, child)=>{
      const box = child.getBoundingClientRect();
      const offset = y - (box.top + box.height / 2);

      if(offset < 0 && offset > closest.offset){
        return { offset, element: child };
      }
      return closest;
    }, { offset:-Infinity, element:null }).element;
  }

  phone.addEventListener("dragover", (e)=>{
    if(!dragged) return;
    e.preventDefault();

    const after = getAfterEl(phone, e.clientY);
    if(after == null) phone.appendChild(dragged);
    else phone.insertBefore(dragged, after);
  });

  function wireBlock(block){
    /* =========================
       DRAG & DROP
    ========================== */
    block.addEventListener("dragstart", (e) => {
      dragged = block;
      block.classList.add("dragging");
  
      if (e.dataTransfer) {
        e.dataTransfer.setData("text/plain", "");
        e.dataTransfer.effectAllowed = "move";
      }
    });
  
    block.addEventListener("dragend", () => {
      block.classList.remove("dragging");
      dragged = null;
    });
  
    /* =========================
       INPUT PREVIEW (IMAGE + AUDIO)
    ========================== */
    block.addEventListener("input", (e) => {
      if (!e.target.matches('input[data-field="url"]')) return;
  
      const url = e.target.value.trim();
  
      /* IMAGE PREVIEW */
      if (block.dataset.type === "image") {
        let img = block.querySelector("img.preview");
        let helper = block.querySelector(".helper");
  
        if (url) {
          if (!img) {
            img = document.createElement("img");
            img.className = "preview";
            img.style.width = "100%";
            img.style.borderRadius = "10px";
  
            if (helper) helper.replaceWith(img);
            else block.querySelector(".content").appendChild(img);
          }
          img.src = url;
        } else if (img) {
          const h = document.createElement("div");
          h.className = "helper";
          h.textContent = "Voeg een afbeelding URL toe of upload.";
          img.replaceWith(h);
        }
      }
  
      /* ✅ AUDIO PREVIEW */
      if (block.dataset.type === "audio") {
        const audio = block.querySelector("audio");
        if (!audio) return;
  
        if (url) {
          audio.src = url;
          audio.style.display = "block";
        } else {
          audio.removeAttribute("src");
          audio.style.display = "none";
        }
      }
    });
  
    /* =========================
       UPLOAD (IMAGE + AUDIO)
    ========================== */
    const uploadBtn = block.querySelector(".btn-upload");
    const fileInput = block.querySelector(".file-hidden");
    const urlInput  = block.querySelector('input[data-field="url"]');
  
    if (uploadBtn && fileInput && urlInput) {
      uploadBtn.addEventListener("click", () => fileInput.click());
  
      fileInput.addEventListener("change", async () => {
        const file = fileInput.files?.[0];
        if (!file) return;
  
        const fd = new FormData();
        fd.append("file", file);
  
        try {
          const res = await fetch("/admin-upload-media", {
            method: "POST",
            body: fd
          });
          if (!res.ok) throw new Error(await res.text());
  
          const json = await res.json();
          urlInput.value = json.url;
          urlInput.dispatchEvent(new Event("input"));
  
          toast("Upload voltooid ✅");
        }
        catch (err) {
          console.error(err);
          alert("Upload mislukt");
        }
        finally {
          fileInput.value = "";
        }
      });
    }
  
    /* =========================
       PHOTO MODULE (CAMERA)
    ========================== */
    const cameraBtn  = block.querySelector(".btn-camera");
    const cameraFile = block.querySelector(".file-hidden");
    const photoUrl   = block.querySelector('[data-field="url"]');
  
    if (cameraBtn && cameraFile && photoUrl) {
      cameraBtn.addEventListener("click", () => cameraFile.click());
  
      cameraFile.addEventListener("change", async () => {
        const file = cameraFile.files?.[0];
        if (!file) return;
  
        let img = block.querySelector("img.preview");
        if (!img) {
          img = document.createElement("img");
          img.className = "preview";
          img.style.width = "100%";
          img.style.borderRadius = "10px";
          block.querySelector(".content").appendChild(img);
        }
        img.src = URL.createObjectURL(file);
  
        const fd = new FormData();
        fd.append("file", file);
  
        try {
          const res = await fetch("/admin-upload-media", {
            method: "POST",
            body: fd
          });
          if (!res.ok) throw new Error(await res.text());
  
          const json = await res.json();
          photoUrl.value = json.url;
  
          toast("Foto geüpload 📸");
        }
        catch (err) {
          console.error(err);
          alert("Upload mislukt");
        }
        finally {
          cameraFile.value = "";
        }
      });
    }
  
    /* =========================
       BLOCK SELECTIE
    ========================== */
