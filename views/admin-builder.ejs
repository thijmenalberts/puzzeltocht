  </aside>
</div> <!-- einde .builder-wrap -->

<script>
(function(){  
  // ✅ PUZZLE OBJECT BESCHIKBAAR MAKEN IN JS
  const puzzle = <%- JSON.stringify({
    languages: puzzle.languages || ["nl"],
    defaultLanguage: puzzle.defaultLanguage || "nl",
    _id: puzzle._id
  }) %>;

  const phone = document.getElementById("phone");
  if(!phone) return;

  const qs  = (s,p=document)=>p.querySelector(s);
  const qsa = (s,p=document)=>Array.from(p.querySelectorAll(s));

  // ✅ MEERTALIGHEID BASIS
  let availableLanguages = puzzle.languages || ["nl"];
  let activeLanguage = puzzle.defaultLanguage || "nl";

  // ➕ NIEUWE TAAL TOEVOEGEN
  qs("#add-language-btn").addEventListener("click", () => {
    const lang = prompt(
      "Voer taalcode in (bijv. en, de, fr):"
    );
  
    if (!lang) return;
    if (availableLanguages.includes(lang)) {
      alert("Deze taal bestaat al.");
      return;
    }
  
    addLanguage(lang);
  });

  let pages = JSON.parse(`<%- JSON.stringify(pagesSafe) %>`);
  if(!Array.isArray(pages) || !pages.length){
    pages = [{
      title:"Pagina 1",
      showNext:true,
      isMap:false,
      showTarget:true,
      autoNext:false,
      playSound:false,
      soundUrl:"",
      modules:[]
    }];
  }

  // 🌍 TAAL WISSELEN
  const langSelect = qs("#language-select");
  
  if (langSelect) {
    langSelect.value = activeLanguage;
  
    langSelect.addEventListener("change", () => {
      // huidige taal opslaan
      savePageSettings();
      pages[currentPage].modules = collect();
  
      activeLanguage = langSelect.value;
      renderPage(currentPage);
    });
  }

  let currentPage = 0;
  let selected = null;
  let dragged = null;
  let draggedPageIndex = null;

  function mapGoogleDriveUrl(url){
    try{
      const u = new URL(url);
      if (u.hostname.includes("drive.google.com")) {
        const m = u.pathname.match(/\/file\/d\/([^/]+)/);
        if (m && m[1]) return `https://drive.google.com/uc?export=view&id=${m[1]}`;
        const id = u.searchParams.get("id");
        if (id) return `https://drive.google.com/uc?export=view&id=${id}`;
      }
    } catch {}
    return url;
  }

  function setPageTitleUI(){
    const page = pages[currentPage];

    const title =
      typeof page.title === "string"
        ? page.title
        : page.title?.[activeLanguage]
          || page.title?.[puzzle.defaultLanguage]
          || ("Pagina " + (currentPage + 1));

    const isMap = !!page?.isMap;

    qs("#page-title-label").textContent = title;
    qs("#page-title-input").value =
      typeof page.title === "string"
        ? page.title
        : page.title?.[activeLanguage] || "";

    qs("#page-shownext").checked = !!page.showNext;
    qs("#page-ismap").checked = !!page.isMap;
    qs("#page-playsound-start").checked = !!page.playSoundOnStart;
    qs("#map-extra-options").style.display = page.isMap ? "block" : "none";

    // --- NIEUWE VELDEN ---
    qs("#page-showtarget").checked = !!page.showTarget;
    qs("#page-autonext").checked = !!page.autoNext;
    qs("#page-soundurl").value   = page.soundUrl || "";
    qs("#sound-file-section").style.display =
      page.playSoundOnStart ? "block" : "none";

    // Bestaande targetvelden
    qs("#page-target-lat").value = page?.targetLat ?? "";
    qs("#page-target-lng").value = page?.targetLng ?? "";
    qs("#page-target-radius").value = page?.targetRadius ?? 50;

    // Toon/verberg target-instellingen als 'isMap' aan staat
    qs("#map-target-settings").style.display = isMap ? "block" : "none";
  }

  function renderPageList(){
    const wrap = qs("#page-list");
    wrap.innerHTML = "";

    pages.forEach((p,i)=>{
      const item = document.createElement("div");
      item.className = "page-item" + (i===currentPage ? " active" : "");
      item.draggable = true;
      item.dataset.index = i;
      item.dataset.page = i;
      const title =
        typeof p.title === "string"
          ? p.title
          : p.title?.[activeLanguage]
            || p.title?.[puzzle.defaultLanguage]
            || `Pagina ${i+1}`;
      
      item.innerHTML = `<span>${title}</span>`;
      item.addEventListener("click", ()=> switchPage(i));
      item.addEventListener("dragstart", (e) => {
        draggedPageIndex = i;
        item.classList.add("dragging");
        e.dataTransfer.effectAllowed = "move";
      });
      
      item.addEventListener("dragend", () => {
        item.classList.remove("dragging");
        draggedPageIndex = null;
      });
      
      item.addEventListener("dragover", (e) => {
        e.preventDefault();
      });
      
      item.addEventListener("drop", (e) => {
        e.preventDefault();
      
        const targetIndex = Number(item.dataset.index);
        if (
          draggedPageIndex === null ||
          draggedPageIndex === targetIndex
        ) return;
      
        movePage(draggedPageIndex, targetIndex);
      });
      wrap.appendChild(item);
    });
  }

  function clearBlocks(){
    qsa(".block", phone).forEach(b => b.remove());
  }

  function renderPage(idx){
    clearBlocks();
    const pg = pages[idx];

    // --- MAP PREVIEW-MODUS ---
    if (pg.isMap === true) {
      const info = document.createElement("div");
      info.className = "block";
      info.dataset.type = "__preview__";
      info.draggable = false;
      info.style.borderStyle = "dashed";

      info.innerHTML = `
        <h4>
          <span>Kaartpagina</span>
          <span class="kind">map</span>
        </h4>
        <div class="helper">
          In de speler zie je een live kaart met je huidige locatie.
          Modules op deze pagina worden genegeerd.
        </div>

        <div class="map-target-preview"
          style="margin-top:8px; background:#f9fafb; border:1px solid #e5e7eb;
                 padding:10px; border-radius:10px;">
          <div class="helper">Nog geen doel ingesteld.</div>
        </div>

        <!-- NIEUW: indicatoren voor opties -->
        <div style="margin-top:10px; font-size:13px; color:#555;">
          <div>🎯 Doel zichtbaar: <strong>${pg.showTarget ? "ja" : "nee"}</strong></div>
          <div>⏭ Automatisch door: <strong>${pg.autoNext ? "ja" : "nee"}</strong></div>
          ${pg.soundUrl
            ? "<div>📁 Geluid: <code>" + pg.soundUrl + "</code></div>"
            : ""}
        </div>
      `;

      phone.appendChild(info);

      setPageTitleUI();
      clearPanel();
      updateMapPreview(); 
      return;
    }

    // --- NORMALE PAGINA: MODULES ---
    (pg.modules || []).forEach(m=>{
      const block = createBlock(m.type);
      phone.appendChild(block);

      const data = m.data || {};

      if (m.type === "photo") {
        const url = data?.url;
      
        if (url) {
          const img = document.createElement("img");
          img.className = "preview";
          img.src = url;
          img.style.width = "100%";
          img.style.borderRadius = "10px";
          qs(".content", block).appendChild(img);
        }
      }

      if (m.type === "text") {
        const value =
          typeof data.text === "string"
            ? data.text
            : data.text?.[activeLanguage] || "";
      
        qs('[data-field="text"]', block).innerHTML = value;
      }

      if(m.type==="image"){
        const url = data?.url || "";
        const inp = qs('input[data-field="url"]', block);
        inp.value = url;

        if(url){
          const img = document.createElement("img");
          img.className = "preview";
          img.src = url;
          img.style.width = "100%";
          img.style.borderRadius = "10px";
          qs(".content", block).appendChild(img);
        } else {
          const helper = document.createElement("div");
          helper.className = "helper";
          helper.textContent = "Voeg een afbeelding URL toe of upload.";
          qs(".content", block).appendChild(helper);
        }
      }

      if(m.type==="question"){
        qs('[data-field="question"]', block).value =
          typeof data.question === "string"
            ? data.question
            : data.question?.[activeLanguage] || "";
        qs('[data-field="questionType"]', block).value = data?.questionType || "open";
      
        const openWrap = qs('[data-open]', block);
        const mcWrap   = qs('[data-mc]', block);
      
        if(data?.questionType === "mc"){
          openWrap.style.display = "none";
          mcWrap.style.display = "block";
      
          qsa('[data-option]', mcWrap).forEach((opt, i) => {
            opt.querySelector('[data-text]').value =
              data?.options?.[i]?.text || "";
            opt.querySelector('[data-correct]').checked =
              !!data?.options?.[i]?.correct;
          });
        } else {
          openWrap.style.display = "block";
          mcWrap.style.display = "none";
          qs('[data-field="answer"]', block).value = data?.answer || "";
        }
      
        qs('[data-field="goodPage"]', block).value =
          Number.isInteger(data?.goodPage) ? data.goodPage : "";
        qs('[data-field="badPage"]', block).value =
          Number.isInteger(data?.badPage) ? data.badPage : "";
      }

      if(m.type==="location"){
        qs('[data-field="lat"]',    block).value = data?.lat ?? "";
        qs('[data-field="lng"]',    block).value = data?.lng ?? "";
        qs('[data-field="radius"]', block).value = data?.radius ?? 50;
      }
    });

    setPageTitleUI();
    clearPanel();
  }

function savePageSettings() {
  const pg = pages[currentPage];

  pg.title = pg.title || {};
  pg.title[activeLanguage] =
    qs("#page-title-input").value;
  pg.showNext     = qs("#page-shownext").checked;
  pg.isMap        = qs("#page-ismap").checked;

  // nieuwe velden
  pg.showTarget   = qs("#page-showtarget").checked;
  pg.autoNext     = qs("#page-autonext").checked;
  pg.playSoundOnStart = qs("#page-playsound-start").checked;
