<%
  // Normaliseer puzzle.pages naar .data + voeg nieuwe velden toe
  const normalizePages = (puz) => {
    if (!puz || !Array.isArray(puz.pages) || !puz.pages.length) {
      return [{
        title: "Pagina 1",
        showNext: true,
        isMap: false,
        showTarget: true,        // NIEUW
        autoNext: false,         // NIEUW
        playSoundOnStart: false,
        soundUrl: "",            // NIEUW
        modules: []
      }];
    }

    return puz.pages.map(pg => ({
      title:
        typeof pg?.title === "object"
          ? pg.title
          : (pg?.title || "Pagina"),
      showNext: typeof pg?.showNext === "boolean" ? pg.showNext : true,
      isMap: typeof pg?.isMap === "boolean" ? pg.isMap : false,

      // --- NIEUW TOEGEVOEGDE VELDEN ---
      showTarget: typeof pg?.showTarget === "boolean" ? pg.showTarget : true,
      autoNext: typeof pg?.autoNext === "boolean" ? pg.autoNext : false,
      playSoundOnStart: typeof pg?.playSoundOnStart === "boolean" ? pg.playSoundOnStart : false,
      soundUrl: pg?.soundUrl || "",

      // Bestaande target-informatie
      targetLat: pg?.targetLat ?? null,
      targetLng: pg?.targetLng ?? null,
      targetRadius: pg?.targetRadius ?? 50,

      modules: Array.isArray(pg?.modules)
        ? pg.modules.map(m => ({
            type: m?.type || "",
            data: m?.data || m?.content || {}
          }))
        : []
    }));
  };

  const pagesSafe = normalizePages(puzzle);
%>

<style>
  :root{
    --primary:#6366f1;
    --bg:#f5f7fa;
    --text:#111827;
  }
  main{
    max-width:100% !important;
    padding:0 !important;
    margin:0 !important;
  }
  *{ box-sizing:border-box; }

  .builder-wrap{
    display:grid;
    grid-template-columns: 280px 1fr 330px;
    gap:0;
    height:calc(100vh - 56px);
    background:var(--bg);
    font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue";
    color:var(--text);
  }

  /* SIDEBAR */
  .sidebar{
    background:#fff;
    border-right:1px solid #e5e7eb;
    padding:22px;
    display:flex;
    flex-direction:column;
    gap:20px;
  }
  .sidebar h2{
    font-size:20px;
    font-weight:800;
    margin:0;
  }
  .element-btn{
    width:100%;
    display:flex;
    align-items:center;
    gap:10px;
    padding:12px;
    background:#f9fafb;
    border:1px solid #e5e7eb;
    border-radius:10px;
    cursor:pointer;
    font-weight:600;
    transition:.15s ease;
  }
  .element-btn:hover{
    background:#eef2ff;
    border-color:var(--primary);
  }

  .sidebar-actions{
    margin-top:auto;
    display:flex;
    gap:12px;
  }

  .btn{
    flex:1;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    font-weight:700;
    cursor:pointer;
  }
  .btn-primary{
    background:var(--primary);
    color:#fff;
    border:none;
  }

  /* MID CANVAS */
  .canvas{
    display:flex;
    justify-content:center;
    align-items:flex-start;
    padding:30px;
  }
  .phone{
    width:380px;
    height:740px;
    background:#fff;
    border-radius:35px;
    border:4px solid #111;
    overflow-y:auto;
    box-shadow:0 20px 50px rgba(0,0,0,0.18);
    padding:18px 18px 22px;
  }
  .phone-header{
    position:sticky;
    top:0;
    background:#fff;
    z-index:5;
    padding:8px 0 10px;
    margin-bottom:10px;
    border-bottom:1px dashed #ddd;
    display:flex;
    justify-content:space-between;
    gap:10px;
    align-items:center;
  }

  .block{
    padding:18px;
    background:#fff;
    border:1px solid #e5e7eb;
    border-radius:14px;
    margin-bottom:14px;
    box-shadow:0 4px 10px rgba(0,0,0,0.05);
    cursor:grab;
    position:relative;
  }

  .block.dragging{ opacity:.45; }

  .block h4{
    margin:0 0 8px;
    font-weight:700;
    font-size:15px;
    display:flex;
    gap:6px;
    align-items:center;
  }
  .kind{
    background:#f3f4f6;
    border:1px solid #ddd;
    padding:2px 6px;
    border-radius:8px;
    font-size:11px;
  }
  .remove{
    position:absolute;
    top:10px;
    right:10px;
    background:#ef4444;
    color:#fff;
    width:24px;
    height:24px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:900;
  }

  [contenteditable="true"]{
    padding:6px;
    border-radius:8px;
    transition:.15s;
    outline:2px dashed transparent;
  }
  [contenteditable="true"]:focus{
    background:#f0f4ff;
    outline-color:#aab4ff;
  }

  .block input, .block textarea{
    width:100%;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    margin-bottom:8px;
    font-size:14px;
  }

  .form-row{
    display:flex;
    gap:10px;
  }

  .helper{
    font-size:12px;
    color:#6b7280;
  }

  /* RIGHT PANEL */
  .right-panel{
    background:#fff;
    border-left:1px solid #e5e7eb;
    padding:18px;
    overflow-y:auto;
  }
  .right-panel h3{
    margin:0 0 10px;
    font-size:16px;
    font-weight:800;
  }

  .page-list{
    display:flex;
    flex-direction:column;
    gap:6px;
  }

  .page-item{
    padding:8px 10px;
    background:#f3f4f6;
    border:1px solid #e5e7eb;
    border-radius:8px;
    cursor:pointer;
    font-size:14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .page-item.active{
    background:var(--primary);
    border-color:var(--primary);
    color:#fff;
  }
  
  .panel-section{ margin-top:16px; }

  .right-panel label{
    font-size:13px;
    margin-top:10px;
    display:block;
  }

  .right-panel input:not([type="checkbox"]),
  .right-panel textarea,
  .right-panel select{
    width:100%;
    padding:10px;
    margin-top:4px;
    border-radius:8px;
    border:1px solid #ccc;
    background:#fff;
  }

  hr.sep{
    border:none;
    border-top:1px solid #eee;
    margin:16px 0;
  }

  .mc-option {
    cursor: grab;
  }
  .mc-option.dragging {
    opacity: 0.5;
  }
  .mc-option .drag-handle {
    cursor: grab;
    user-select: none;
  }

  .page-item.dragging {
    opacity: 0.5;
  }
  
  .page-item {
    cursor: grab;
  }
  
  .page-item:active {
    cursor: grabbing;
  }

  .right-panel input[type="checkbox"] {
    width: auto;
    padding: 0;
    margin: 0;
    border-radius: 3px;
  }

  /* Net uitgelijnde checkbox-rijen */
  .right-panel label.check-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 8px;
    font-size: 13px;
  }
  
  .right-panel label.check-row input[type="checkbox"] {
    margin: 0;
    flex-shrink: 0;
  }
</style>

<!-- 🌍 TAAL SELECTIE -->
