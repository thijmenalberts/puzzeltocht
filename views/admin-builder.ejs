  function switchPage(nextIndex){
    savePageSettings(); pages[currentPage].modules = collect();
    currentPage = nextIndex; renderPageList(); renderPage(currentPage);
  }

  function addLanguage(lang) {
    availableLanguages.push(lang); puzzleMeta.languages = availableLanguages;
    puzzleMeta.defaultLanguage = puzzleMeta.defaultLanguage || activeLanguage;
    pages.forEach(page => {
      if (typeof page.title === "string") page.title = { [puzzleMeta.defaultLanguage]: page.title };
      page.title[lang] = "";
      page.modules.forEach(m => {
        for (const key in m.data) {
          if (typeof m.data[key] === "string") m.data[key] = { [puzzleMeta.defaultLanguage]: m.data[key], [lang]: "" };
        }
      });
    });
    updateLanguageSelect(); activeLanguage = lang; renderPage(currentPage);
  }

  function updateLanguageSelect() {
    const sel = qs("#language-select"); sel.innerHTML = "";
    availableLanguages.forEach(l => {
      const opt = document.createElement("option"); opt.value = l; opt.textContent = l.toUpperCase(); sel.appendChild(opt);
    });
    sel.value = activeLanguage;
  }

  function movePage(fromIndex, toIndex){
    savePageSettings(); pages[currentPage].modules = collect();
    const moved = pages.splice(fromIndex, 1)[0];
    pages.splice(toIndex, 0, moved);
    if (currentPage === fromIndex) currentPage = toIndex;
    else if (currentPage > fromIndex && currentPage <= toIndex) currentPage--;
    else if (currentPage < fromIndex && currentPage >= toIndex) currentPage++;
    renderPageList(); renderPage(currentPage);
  }

