    const id = phone.dataset.id;

    try{
      const res = await fetch(`/admin-builder/${id}/save-all`, {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ pages })
      });

      if(!res.ok) throw new Error(await res.text());
      toast("Opgeslagen ✅");
    }
    catch(err){
      console.error(err);
      toast("Opslaan mislukt ❌", true);
    }
  }

  function resetPage(){
    location.reload();
  }

  qs("#btn-save").addEventListener("click", saveAll);
  qs("#btn-reset").addEventListener("click", resetPage);

  qs("#add-page-btn").addEventListener("click", addPage);
  qs("#delete-page-btn").addEventListener("click", deletePage);

  // PAGE INPUT HANDLERS
  qs("#page-title-input").addEventListener("input", () => {
    pages[currentPage].title = pages[currentPage].title || {};
    pages[currentPage].title[activeLanguage] =
      qs("#page-title-input").value;
  
    qs("#page-title-label").textContent =
      qs("#page-title-input").value;
  
    renderPageList();
  });

  qs("#page-shownext").addEventListener("change", ()=>{
    pages[currentPage].showNext = !!qs("#page-shownext").checked;
  });

  qs("#page-ismap").addEventListener("change", () => {
    const isMap = !!qs("#page-ismap").checked;
    pages[currentPage].isMap = isMap;

    // Extra opties tonen of verbergen
    qs("#map-extra-options").style.display = isMap ? "block" : "none";

    renderPage(currentPage);
  });

  // NIEUW: SHOW TARGET
  qs("#page-showtarget").addEventListener("change", ()=>{
    pages[currentPage].showTarget = !!qs("#page-showtarget").checked;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // NIEUW: AUTO NEXT
  qs("#page-autonext").addEventListener("change", ()=>{
    pages[currentPage].autoNext = !!qs("#page-autonext").checked;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // NIEUW: PLAY SOUND
  qs("#page-playsound-start").addEventListener("change", () => {
    const checked = qs("#page-playsound-start").checked;
    pages[currentPage].playSoundOnStart = checked;
  
    // toon/verberg geluidsbestand
    qs("#sound-file-section").style.display = checked ? "block" : "none";
  });

  // NIEUW: SOUND URL
  qs("#page-soundurl").addEventListener("input", ()=>{
    pages[currentPage].soundUrl = qs("#page-soundurl").value;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // TARGET INPUTS
  qs("#page-target-lat").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetLat = v !== "" ? Number(v) : null;
    updateMapPreview();
  });

  qs("#page-target-lng").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetLng = v !== "" ? Number(v) : null;
    updateMapPreview();
  });

  qs("#page-target-radius").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetRadius = v !== "" ? Number(v) : 50;
    updateMapPreview();
  });


  // --- MINI MAP PREVIEW (tekst + canvas) ---
  function updateMapPreview(){
    const pg = pages[currentPage];
    if(!pg?.isMap) return;

    const wrap = phone.querySelector(".map-target-preview");
    if(!wrap) return;

    const hasCoords = (
      pg.targetLat !== null && pg.targetLat !== "" &&
      pg.targetLng !== null && pg.targetLng !== ""
    );

    if(!hasCoords){
      wrap.innerHTML = `<div class="helper">Nog geen doel ingesteld.</div>`;
      return;
    }

    const lat = Number(pg.targetLat);
    const lng = Number(pg.targetLng);
    const radius = Number(pg.targetRadius || 50);

    const latTxt = isFinite(lat) ? lat.toFixed(6) : "—";
    const lngTxt = isFinite(lng) ? lng.toFixed(6) : "—";

    wrap.innerHTML = `
      <div style="display:flex; gap:12px; align-items:center;">
        <canvas id="map-mini" width="160" height="160"
          style="border:1px solid #e5e7eb; border-radius:10px; background:#fff;">
        </canvas>

        <div style="display:flex; flex-direction:column; gap:6px;">
          <div><strong>Doellocatie</strong></div>

          <div style="font-family: ui-monospace, monospace;">
            Lat: ${latTxt}<br>
            Lng: ${lngTxt}
          </div>

          <div>Radius: <strong>${radius}</strong> meter</div>

          <div class="helper">
            De speler gaat automatisch verder als je binnen de radius komt (indien optie aanstaat).
          </div>
        </div>
      </div>
    `;

    const cv = wrap.querySelector("#map-mini");
    const ctx = cv?.getContext("2d");

    if(ctx){
      ctx.clearRect(0,0,cv.width,cv.height);

      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0,0,cv.width,cv.height);

      ctx.fillStyle = "#eef2ff";
      ctx.strokeStyle = "#6366f1";
      ctx.lineWidth = 2;

      const rMin = 10, rMax = 70;
      const pxRadius = Math.max(rMin, Math.min(rMax, radius / 5));
      const cx = cv.width/2;
      const cy = cv.height/2;

      ctx.beginPath();
      ctx.arc(cx, cy, pxRadius, 0, Math.PI*2);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = "#111827";
      ctx.beginPath();
      ctx.arc(cx, cy, 3, 0, Math.PI*2);
      ctx.fill();
    }
  }
// --- TOAST MECHANISME ---
  function toast(msg, error=false){
    const t = document.createElement("div");
    t.textContent = msg;

    Object.assign(t.style, {
      position: 'fixed',
      right: '20px',
      bottom: '20px',
      background: error ? '#ef4444' : 'var(--primary)',
      color: '#fff',
      padding: '10px 14px',
      borderRadius: '12px',
      boxShadow: '0 8px 24px rgba(0,0,0,.2)',
      zIndex: '9999',
      fontSize: '14px'
    });

    document.body.appendChild(t);

    setTimeout(() => t.remove(), 2000);
  }
  // --- SOUND UPLOAD LOGICA ---
  const soundUploadBtn = qs("#btn-sound-upload");
  const soundFileInput = qs("#file-sound-upload");
  const soundUrlInput  = qs("#page-soundurl");

  if (soundUploadBtn && soundFileInput && soundUrlInput) {

    // Open file selector
    soundUploadBtn.addEventListener("click", () => {
      soundFileInput.click();
    });

    // Upload bestand
    soundFileInput.addEventListener("change", async () => {
      const file = soundFileInput.files?.[0];
      if (!file) return;

      const fd = new FormData();
      fd.append("file", file); // zelfde endpoint werkt voor audio

      try {
        const res = await fetch("/admin-upload-media", {
          method: "POST",
          body: fd
        });

        if (!res.ok) throw new Error(await res.text());

        const json = await res.json();
        soundUrlInput.value = json.url;

        // opslaan in live data
        pages[currentPage].soundUrl = json.url;

        toast("Geluid geüpload 🎵");
      }
      catch (err) {
        console.error(err);
        alert("Upload mislukt");
      }
      finally {
        soundFileInput.value = "";
      }
    });
  }

  // INIT
  renderPageList();
  renderPage(currentPage);

  function playSoundIfNeeded() {
    const pg = pages[currentPage];
    if (!pg?.playSoundOnStart) return;
    if (!pg?.soundUrl) return;

    const audio = new Audio(pg.soundUrl);
    audio.play().catch(err => {
      console.warn("Autoplay geblokkeerd door browser:", err);
    });
  }

})(); // einde IIFE
</script>
</div> <!-- einde .builder-wrap -->
