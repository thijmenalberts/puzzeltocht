function switchPage(nextIndex){
    savePageSettings();
    pages[currentPage].modules = collect();
    currentPage = nextIndex;
    renderPageList();
    renderPage(currentPage);
}

function addLanguage(lang) {
  availableLanguages.push(lang);
  puzzle.languages = availableLanguages;

  pages.forEach(page => {
    // pagina titel
    if (typeof page.title === "string") {
      page.title = {
        [puzzle.defaultLanguage]: page.title
      };
    }
    page.title[lang] = "";

    // modules
    page.modules.forEach(m => {
      for (const key in m.data) {
        if (typeof m.data[key] === "string") {
          m.data[key] = {
            [puzzle.defaultLanguage]: m.data[key],
            [lang]: ""
          };
        }
      }
    });
  });

  updateLanguageSelect();
  activeLanguage = lang;
  renderPage(currentPage);
}

function updateLanguageSelect() {
  const sel = qs("#language-select");
  sel.innerHTML = "";

  availableLanguages.forEach(l => {
    const opt = document.createElement("option");
    opt.value = l;
    opt.textContent = l.toUpperCase();
    sel.appendChild(opt);
  });

  sel.value = activeLanguage;
}

function movePage(fromIndex, toIndex){
  const moved = pages.splice(fromIndex, 1)[0];
  pages.splice(toIndex, 0, moved);

  // Current page correct houden
  if (currentPage === fromIndex) {
    currentPage = toIndex;
  } else if (
    currentPage > fromIndex &&
    currentPage <= toIndex
  ) {
    currentPage--;
  } else if (
    currentPage < fromIndex &&
    currentPage >= toIndex
  ) {
    currentPage++;
  }

  renderPageList();
  renderPage(currentPage);
}

