<%
const normalizePages = (puz) => {
  if (!puz || !Array.isArray(puz.pages) || !puz.pages.length) {
    return [{ title: { nl: "Pagina 1" }, showNext: true, isMap: false, modules: [] }];
  }
  return puz.pages.map(pg => ({
    ...pg,
    title: typeof pg.title === "string" ? { nl: pg.title } : (pg.title || {}),
    modules: Array.isArray(pg.modules) ? pg.modules : []
  }));
};
const pagesSafe = normalizePages(puzzle);
%>

<style>
  :root { --primary: #4f46e5; --bg: #f1f5f9; --border: #e2e8f0; }
  body { margin: 0; height: 100vh; overflow: hidden; font-family: 'Inter', sans-serif; background: var(--bg); }
  
  .builder-layout { display: grid; grid-template-columns: 280px 1fr 350px; height: calc(100vh - 60px); }
  .column { height: 100%; overflow-y: auto; background: #fff; padding: 20px; border-right: 1px solid var(--border); }
  .column-main { background: #cbd5e1; display: flex; justify-content: center; align-items: flex-start; padding: 40px 20px; }
  
  /* SNAPPING DRAG INDICATOR */
  .page-item { padding: 12px; background: #f8fafc; border: 1px solid var(--border); border-radius: 8px; margin-bottom: 8px; cursor: grab; transition: 0.2s; position: relative; }
  .page-item.active { background: var(--primary); color: #fff; border-color: var(--primary); }
  .page-item.drag-over-top { border-top: 4px solid var(--primary); }
  .page-item.drag-over-bottom { border-bottom: 4px solid var(--primary); }

  /* TELEFOON PREVIEW */
  .phone { width: 375px; min-height: 700px; background: #fff; border: 12px solid #1e293b; border-radius: 40px; box-shadow: 0 25px 50px rgba(0,0,0,0.3); padding: 20px 15px; position: relative; flex-shrink: 0; }
  .block { padding: 15px; background: #fff; border: 1px solid var(--border); border-radius: 12px; margin-bottom: 12px; position: relative; cursor: grab; }
  
  .btn-save { background: var(--primary); color: white; padding: 10px 20px; border-radius: 8px; font-weight: 800; cursor: pointer; border: none; }
</style>

<div style="height: 60px; background: #fff; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; padding: 0 20px;">
  <h1 style="font-size: 18px; font-weight: 900;">Builder: <%= puzzle.name %></h1>
  <div style="display:flex; gap:10px;">
    <select id="language-select" style="padding: 5px; border-radius: 5px;"></select>
    <button id="btn-save" class="btn-save">💾 Opslaan</button>
  </div>
</div>

<div class="builder-layout">
  <aside class="column">
    <h3 style="font-size:12px; color:#94a3b8; text-transform:uppercase;">Modules</h3>
    <button class="element-btn" onclick="addBlock('title')">🏷️ Titel</button>
    <button class="element-btn" onclick="addBlock('text')">📝 Tekst</button>
    <button class="element-btn" onclick="addBlock('question')">❓ Vraag</button>
    <button class="element-btn" onclick="addBlock('historychat')">🎭 NPC Chat</button>
    <button class="element-btn" onclick="addBlock('image')">🖼️ Afbeelding</button>
    <button class="element-btn" onclick="addBlock('feedback')">⭐ Finale</button>
  </aside>

  <main class="column-main">
    <div class="phone" id="phone" data-id="<%= puzzle._id %>">
        <div id="phone-content"></div>
    </div>
  </main>

  <aside class="column" style="border-right:none; border-left:1px solid var(--border);">
    <div style="background: #eef2ff; padding: 15px; border-radius: 12px; margin-bottom: 20px; border: 1px solid #c7d2fe;">
        <h3 style="margin-top:0; font-size:13px;">🎨 Thema</h3>
        <select id="auto-theme-preset" style="width:100%; padding:8px; border-radius:8px;">
            <option value="standard" <%= puzzle.theme?.preset==='standard'?'selected':''%>>Standaard</option>
            <option value="medieval" <%= puzzle.theme?.preset==='medieval'?'selected':''%>>Middeleeuwen</option>
            <option value="future" <%= puzzle.theme?.preset==='future'?'selected':''%>>Toekomst</option>
            <option value="iceage" <%= puzzle.theme?.preset==='iceage'?'selected':''%>>Ijstijd</option>
        </select>
        <input type="color" id="auto-theme-color" value="<%= puzzle.theme?.primaryColor || '#4f46e5' %>" style="width:100%; margin-top:10px; height:30px; border:none; cursor:pointer;">
    </div>

    <h3>Pagina's</h3>
    <div id="page-list"></div>
    <button onclick="addPage()" style="width:100%; padding:10px; margin-top:10px; border:1px dashed #cbd5e1; background:none; cursor:pointer;">+ Nieuwe Pagina</button>
    
    <hr style="margin: 20px 0; border: none; border-top: 1px solid #eee;">
    <div id="page-settings">
        <label>Paginatitel</label>
        <input type="text" id="page-title-input" style="width:100%; margin-bottom:10px;">
        <label style="display:flex; align-items:center; gap:8px; cursor:pointer;">
            <input type="checkbox" id="page-ismap"> GPS Kaartpagina
        </label>
    </div>

    <div id="panel-dynamic" style="margin-top:20px; border-top:1px solid #eee; padding-top:20px;">
        <p style="color:#94a3b8; font-style:italic; font-size:12px;">Selecteer een blok om te bewerken.</p>
    </div>
  </aside>
</div>

<script>
(function(){
  let pages = <%- JSON.stringify(pagesSafe) %>;
  let currentPage = 0;
  let activeLanguage = "nl";
  const phone = document.getElementById("phone-content");

  // --- CORE FUNCTIONS ---
  function renderPageList(){
    const wrap = document.getElementById("page-list");
    wrap.innerHTML = "";
    pages.forEach((p, i) => {
      const item = document.createElement("div");
      item.className = `page-item ${i === currentPage ? 'active' : ''}`;
      item.draggable = true;
      item.innerHTML = `<span>${i + 1}. ${p.title?.[activeLanguage] || 'Pagina'}</span>`;
      
      item.onclick = () => switchPage(i);
      
      // Snapping Logic
      item.ondragstart = (e) => { e.dataTransfer.setData("text/plain", i); item.style.opacity = 0.5; };
      item.ondragend = () => { item.style.opacity = 1; document.querySelectorAll('.page-item').forEach(el => el.classList.remove('drag-over-top', 'drag-over-bottom')); };
      item.ondragover = (e) => {
        e.preventDefault();
        const rect = item.getBoundingClientRect();
        const mid = rect.top + rect.height / 2;
        item.classList.toggle('drag-over-top', e.clientY < mid);
        item.classList.toggle('drag-over-bottom', e.clientY >= mid);
      };
      item.ondragleave = () => { item.classList.remove('drag-over-top', 'drag-over-bottom'); };
      item.ondrop = (e) => {
        const fromIdx = parseInt(e.dataTransfer.getData("text/plain"));
        const rect = item.getBoundingClientRect();
        const toIdx = e.clientY < (rect.top + rect.height / 2) ? i : i + 1;
        movePage(fromIdx, toIdx);
      };
      wrap.appendChild(item);
    });
  }

  function movePage(from, to) {
    const item = pages.splice(from, 1)[0];
    pages.splice(to > from ? to - 1 : to, 0, item);
    currentPage = pages.indexOf(item);
    renderPageList(); renderPage();
  }

  function switchPage(idx) {
    if(!pages[currentPage].isMap) pages[currentPage].modules = collect();
    currentPage = idx;
    renderPageList(); renderPage();
  }

  function collect() {
    return Array.from(document.querySelectorAll('.block')).map(b => b._data).filter(d => d);
  }

  function renderPage() {
    phone.innerHTML = "";
    const pg = pages[currentPage];
    document.getElementById("page-title-input").value = pg.title?.[activeLanguage] || "";
    document.getElementById("page-ismap").checked = !!pg.isMap;

    if(pg.isMap) {
        phone.innerHTML = "<div style='padding:40px; text-align:center; border:2px dashed var(--primary); border-radius:20px; margin-top:50px;'>🗺️ Kaartmodus actief</div>";
    } else {
        (pg.modules || []).forEach(m => {
            const b = createBlockUI(m);
            phone.appendChild(b);
        });
    }
  }

  function createBlockUI(moduleData) {
    const div = document.createElement("div");
    div.className = "block";
    div._data = moduleData;
    div.innerHTML = `<strong>${moduleData.type.toUpperCase()}</strong>`;
    div.onclick = () => { 
        document.getElementById("panel-dynamic").innerHTML = `<h4>Instellingen: ${moduleData.type}</h4><p>Pas de data hier aan...</p>`;
    };
    return div;
  }

  document.getElementById("btn-save").onclick = async () => {
    if(!pages[currentPage].isMap) pages[currentPage].modules = collect();
    
    // THEMA DATA OPHALEN
    const theme = {
        preset: document.getElementById("auto-theme-preset").value,
        primaryColor: document.getElementById("auto-theme-color").value
    };

    try {
        const res = await fetch(`/admin-builder/${document.getElementById("phone").dataset.id}/save-all`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ pages, theme, languages: ["nl"], defaultLanguage: "nl" })
        });
        if(res.ok) alert("✅ Opgeslagen!"); else throw new Error();
    } catch(e) { alert("❌ Opslaan mislukt. Probeer het opnieuw."); }
  };

  window.addPage = () => { pages.push({ title: {nl: "Nieuwe Pagina"}, modules: [] }); switchPage(pages.length-1); };

  renderPageList(); renderPage();
})();
</script>
