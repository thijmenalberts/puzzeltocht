<script>
(function(){  
  const puzzleMeta = <%- JSON.stringify({
    languages: puzzle.languages || ["nl"],
    defaultLanguage: puzzle.defaultLanguage || "nl",
    _id: puzzle._id
  }) %>;

  const phone = document.getElementById("phone");
  if(!phone) return;

  const qs  = (s,p=document)=>p.querySelector(s);
  const qsa = (s,p=document)=>Array.from(p.querySelectorAll(s));

  let availableLanguages = Array.isArray(puzzleMeta.languages) && puzzleMeta.languages.length ? [...puzzleMeta.languages] : ["nl"];
  let activeLanguage = puzzleMeta.defaultLanguage || "nl";

  qs("#add-language-btn").addEventListener("click", () => {
    const lang = prompt("Voer taalcode in (bijv. en, de, fr):");
    if (!lang) return;
    if (availableLanguages.includes(lang)) { alert("Deze taal bestaat al."); return; }
    addLanguage(lang);
  });

  let pages = <%- JSON.stringify(pagesSafe) %>;
  if(!Array.isArray(pages) || !pages.length){
    pages = [{ title:"Pagina 1", showNext:true, isMap:false, showTarget:true, autoNext:false, playSound:false, soundUrl:"", modules:[] }];
  }

  const langSelect = qs("#language-select");
  if (langSelect) {
    langSelect.value = activeLanguage;
    langSelect.addEventListener("change", () => {
      savePageSettings();
      pages[currentPage].modules = collect();
      activeLanguage = langSelect.value;
      renderPage(currentPage);
    });
  }

  let currentPage = 0;
  let selected = null;
  let dragged = null;
  let draggedPageIndex = null;

  function mapGoogleDriveUrl(url){
    try{
      const u = new URL(url);
      if (u.hostname.includes("drive.google.com")) {
        const m = u.pathname.match(/\/file\/d\/([^/]+)/);
        if (m && m[1]) return `https://drive.google.com/uc?export=view&id=${m[1]}`;
        const id = u.searchParams.get("id");
        if (id) return `https://drive.google.com/uc?export=view&id=${id}`;
      }
    } catch {}
    return url;
  }

  function setPageTitleUI(){
    const page = pages[currentPage];
    const title = typeof page.title === "string" ? page.title : page.title?.[activeLanguage] || page.title?.[puzzleMeta.defaultLanguage] || ("Pagina " + (currentPage + 1));
    const isMap = !!page?.isMap;

    qs("#page-title-label").textContent = title;
    qs("#page-title-input").value = typeof page.title === "string" ? page.title : page.title?.[activeLanguage] || "";

    qs("#page-shownext").checked = !!page.showNext;
    qs("#page-ismap").checked = !!page.isMap;
    qs("#page-playsound-start").checked = !!page.playSoundOnStart;
    qs("#map-extra-options").style.display = page.isMap ? "block" : "none";
    
    qs("#page-showtarget").checked = !!page.showTarget;
    qs("#page-autonext").checked = !!page.autoNext;
    qs("#page-soundurl").value   = page.soundUrl || "";
    qs("#sound-file-section").style.display = page.playSoundOnStart ? "block" : "none";

    qs("#page-target-lat").value = page?.targetLat ?? "";
    qs("#page-target-lng").value = page?.targetLng ?? "";
    qs("#page-target-radius").value = page?.targetRadius ?? 50;
    qs("#map-target-settings").style.display = isMap ? "block" : "none";
  }

  function renderPageList(){
    const wrap = qs("#page-list");
    wrap.innerHTML = "";
    pages.forEach((p,i)=>{
      const item = document.createElement("div");
      item.className = "page-item" + (i===currentPage ? " active" : "");
      item.draggable = true;
      item.dataset.index = i;
      const title = typeof p.title === "string" ? p.title : p.title?.[activeLanguage] || p.title?.[puzzleMeta.defaultLanguage] || `Pagina ${i+1}`;
      
      item.innerHTML = `<span>${title}</span>`;
      item.addEventListener("click", ()=> switchPage(i));
      item.addEventListener("dragstart", (e) => {
        draggedPageIndex = i;
        item.classList.add("dragging");
        e.dataTransfer.effectAllowed = "move";
      });
      item.addEventListener("dragend", () => { item.classList.remove("dragging"); draggedPageIndex = null; });
      item.addEventListener("dragover", (e) => e.preventDefault());
      item.addEventListener("drop", (e) => {
        e.preventDefault();
        const targetIndex = Number(item.dataset.index);
        if (draggedPageIndex === null || draggedPageIndex === targetIndex) return;
        movePage(draggedPageIndex, targetIndex);
      });
      wrap.appendChild(item);
    });
  }

  function clearBlocks(){ qsa(".block", phone).forEach(b => b.remove()); }

  function renderPage(idx){
    clearBlocks();
    const pg = pages[idx];

    if (pg.isMap === true) {
      const info = document.createElement("div");
      info.className = "block"; info.dataset.type = "__preview__"; info.draggable = false; info.style.borderStyle = "dashed";
      info.innerHTML = `
        <h4><span>Kaartpagina</span><span class="kind">map</span></h4>
        <div class="helper">In de speler zie je een live kaart met je huidige locatie. Modules op deze pagina worden genegeerd.</div>
        <div class="map-target-preview" style="margin-top:8px; background:#f9fafb; border:1px solid #e5e7eb; padding:10px; border-radius:10px;">
          <div class="helper">Nog geen doel ingesteld.</div>
        </div>
        <div style="margin-top:10px; font-size:13px; color:#555;">
          <div>🎯 Doel zichtbaar: <strong>${pg.showTarget ? "ja" : "nee"}</strong></div>
          <div>⏭ Automatisch door: <strong>${pg.autoNext ? "ja" : "nee"}</strong></div>
        </div>
      `;
      phone.appendChild(info);
      setPageTitleUI(); clearPanel(); updateMapPreview(); 
      return;
    }

    (pg.modules || []).forEach(m => {
      const block = createBlock(m.type);
      phone.appendChild(block);
      block._data = JSON.parse(JSON.stringify(m.data || {}));
      const data = m.data || {};

      if (m.type === "aiphoto") {
        const instrInput = qs('[data-field="ai-instruction"]', block);
        const promptInput = qs('[data-field="ai-prompt"]', block);
        const pointsInput = qs('[data-field="ai-points"]', block);
        if (instrInput) instrInput.value = typeof data.instruction === "string" ? data.instruction : data.instruction?.[activeLanguage] || "";
        if (promptInput) promptInput.value = typeof data.prompt === "string" ? data.prompt : data.prompt?.[activeLanguage] || "";
        if (pointsInput) pointsInput.value = data.points !== undefined ? data.points : 10;
      }

      if (m.type === "historychat") {
        const nameInput = qs('[data-field="chat-name"]', block);
        const promptInput = qs('[data-field="chat-prompt"]', block);
        const latInput = qs('[data-field="chat-lat"]', block);
        const lngInput = qs('[data-field="chat-lng"]', block);
        const radInput = qs('[data-field="chat-radius"]', block);
        if (nameInput) nameInput.value = typeof data.characterName === "string" ? data.characterName : data.characterName?.[activeLanguage] || "";
        if (promptInput) promptInput.value = typeof data.systemPrompt === "string" ? data.systemPrompt : data.systemPrompt?.[activeLanguage] || "";
        if (latInput) latInput.value = data.lat ?? "";
        if (lngInput) lngInput.value = data.lng ?? "";
        if (radInput) radInput.value = data.radius ?? 50;
      }

      if (m.type === "photo" && data?.url) {
        const img = document.createElement("img");
        img.className = "preview"; img.src = data.url; img.style.width = "100%"; img.style.borderRadius = "10px";
        qs(".content", block).appendChild(img);
      }

      if (m.type === "title") qs('[data-field="title"]', block).innerHTML = typeof data.title === "string" ? data.title : data.title?.[activeLanguage] || "";
      if (m.type === "text") qs('[data-field="text"]', block).innerHTML = typeof data.text === "string" ? data.text : data.text?.[activeLanguage] || "";
      
      if(m.type==="image"){
        qs('input[data-field="url"]', block).value = data?.url || "";
        if(data?.url){
          const img = document.createElement("img"); img.className = "preview"; img.src = data.url; img.style.width = "100%"; img.style.borderRadius = "10px";
          qs(".content", block).appendChild(img);
        } else {
          const helper = document.createElement("div"); helper.className = "helper"; helper.textContent = "Voeg een URL toe.";
          qs(".content", block).appendChild(helper);
        }
      }

      if(m.type==="question"){
        qs('[data-field="question"]', block).value = typeof data.question === "string" ? data.question : data.question?.[activeLanguage] || "";
        qs('[data-field="questionType"]', block).value = data?.questionType || "open";
        block.querySelector('[data-field="questionType"]').dispatchEvent(new Event('change'));
        
        if(data?.questionType === "mc"){
            const optWrap = qs('[data-options]', block);
            optWrap.innerHTML = ""; 
            (data.options || []).forEach(opt => {
              const text = typeof opt.text === "string" ? opt.text : opt.text?.[activeLanguage] || "";
              block.createOption(text, opt.correct);
            });
            if(optWrap.children.length === 0) block.createOption();
        } else {
            qs('[data-field="answer"]', block).value = typeof data.answer === "string" ? data.answer : data.answer?.[activeLanguage] || "";
        }
      
        qs('[data-field="goodPage"]', block).value = Number.isInteger(data?.goodPage) ? data.goodPage : "";
        qs('[data-field="badPage"]', block).value = Number.isInteger(data?.badPage) ? data.badPage : "";
        
        qs('[data-field="pts"]', block).value = data?.maxPoints ?? 10;
        qs('[data-field="istimed"]', block).value = data?.isTimed ? "true" : "false";
        qs('[data-field="tlimit"]', block).value = data?.timeLimit ?? 60;
        qs('[data-field="ppen"]', block).value = data?.penaltyPoints ?? 1;
        qs('[data-field="psec"]', block).value = data?.penaltySec ?? 10;
      }

      if(m.type==="location"){
        qs('[data-field="lat"]', block).value = data?.lat ?? "";
        qs('[data-field="lng"]', block).value = data?.lng ?? "";
        qs('[data-field="radius"]', block).value = data?.radius ?? 50;
      }
    
      // 🔥 UNIVERSELE HINTS INLADEN (Fase 2 & 3)
      const sAiK = qs('[data-field="aiknowledge"]', block);
      const sHst = qs('[data-field="hintcost"]', block);
