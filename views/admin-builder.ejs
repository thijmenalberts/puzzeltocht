<%
  // Normaliseer puzzle.pages naar .data + voeg nieuwe velden toe
  const normalizePages = (puz) => {
    if (!puz || !Array.isArray(puz.pages) || !puz.pages.length) {
      return [{
        title: "Pagina 1",
        showNext: true,
        isMap: false,
        showTarget: true,        // NIEUW
        autoNext: false,         // NIEUW
        playSoundOnStart: false,
        soundUrl: "",            // NIEUW
        modules: []
      }];
    }

    return puz.pages.map(pg => ({
      title: pg?.title || "Pagina",
      showNext: typeof pg?.showNext === "boolean" ? pg.showNext : true,
      isMap: typeof pg?.isMap === "boolean" ? pg.isMap : false,

      // --- NIEUW TOEGEVOEGDE VELDEN ---
      showTarget: typeof pg?.showTarget === "boolean" ? pg.showTarget : true,
      autoNext: typeof pg?.autoNext === "boolean" ? pg.autoNext : false,
      playSoundOnStart: typeof pg?.playSoundOnStart === "boolean" ? pg.playSoundOnStart : false,
      soundUrl: pg?.soundUrl || "",

      // Bestaande target-informatie
      targetLat: pg?.targetLat ?? null,
      targetLng: pg?.targetLng ?? null,
      targetRadius: pg?.targetRadius ?? 50,

      modules: Array.isArray(pg?.modules)
        ? pg.modules.map(m => ({
            type: m?.type || "",
            data: m?.data || m?.content || {}
          }))
        : []
    }));
  };

  const pagesSafe = normalizePages(puzzle);
%>

<style>
  :root{
    --primary:#6366f1;
    --bg:#f5f7fa;
    --text:#111827;
  }
  main{
    max-width:100% !important;
    padding:0 !important;
    margin:0 !important;
  }
  *{ box-sizing:border-box; }

  .builder-wrap{
    display:grid;
    grid-template-columns: 280px 1fr 330px;
    gap:0;
    height:calc(100vh - 56px);
    background:var(--bg);
    font-family: Inter, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue";
    color:var(--text);
  }

  /* SIDEBAR */
  .sidebar{
    background:#fff;
    border-right:1px solid #e5e7eb;
    padding:22px;
    display:flex;
    flex-direction:column;
    gap:20px;
  }
  .sidebar h2{
    font-size:20px;
    font-weight:800;
    margin:0;
  }
  .element-btn{
    width:100%;
    display:flex;
    align-items:center;
    gap:10px;
    padding:12px;
    background:#f9fafb;
    border:1px solid #e5e7eb;
    border-radius:10px;
    cursor:pointer;
    font-weight:600;
    transition:.15s ease;
  }
  .element-btn:hover{
    background:#eef2ff;
    border-color:var(--primary);
  }

  .sidebar-actions{
    margin-top:auto;
    display:flex;
    gap:12px;
  }

  .btn{
    flex:1;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    font-weight:700;
    cursor:pointer;
  }
  .btn-primary{
    background:var(--primary);
    color:#fff;
    border:none;
  }

  /* MID CANVAS */
  .canvas{
    display:flex;
    justify-content:center;
    align-items:flex-start;
    padding:30px;
  }
  .phone{
    width:380px;
    height:740px;
    background:#fff;
    border-radius:35px;
    border:4px solid #111;
    overflow-y:auto;
    box-shadow:0 20px 50px rgba(0,0,0,0.18);
    padding:18px 18px 22px;
  }
  .phone-header{
    position:sticky;
    top:0;
    background:#fff;
    z-index:5;
    padding:8px 0 10px;
    margin-bottom:10px;
    border-bottom:1px dashed #ddd;
    display:flex;
    justify-content:space-between;
    gap:10px;
    align-items:center;
  }

  .block{
    padding:18px;
    background:#fff;
    border:1px solid #e5e7eb;
    border-radius:14px;
    margin-bottom:14px;
    box-shadow:0 4px 10px rgba(0,0,0,0.05);
    cursor:grab;
    position:relative;
  }

  .block.dragging{ opacity:.45; }

  .block h4{
    margin:0 0 8px;
    font-weight:700;
    font-size:15px;
    display:flex;
    gap:6px;
    align-items:center;
  }
  .kind{
    background:#f3f4f6;
    border:1px solid #ddd;
    padding:2px 6px;
    border-radius:8px;
    font-size:11px;
  }
  .remove{
    position:absolute;
    top:10px;
    right:10px;
    background:#ef4444;
    color:#fff;
    width:24px;
    height:24px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:900;
  }

  [contenteditable="true"]{
    padding:6px;
    border-radius:8px;
    transition:.15s;
    outline:2px dashed transparent;
  }
  [contenteditable="true"]:focus{
    background:#f0f4ff;
    outline-color:#aab4ff;
  }

  .block input, .block textarea{
    width:100%;
    padding:10px;
    border-radius:10px;
    border:1px solid #ddd;
    margin-bottom:8px;
    font-size:14px;
  }

  .form-row{
    display:flex;
    gap:10px;
  }

  .helper{
    font-size:12px;
    color:#6b7280;
  }

  /* RIGHT PANEL */
  .right-panel{
    background:#fff;
    border-left:1px solid #e5e7eb;
    padding:18px;
    overflow-y:auto;
  }
  .right-panel h3{
    margin:0 0 10px;
    font-size:16px;
    font-weight:800;
  }

  .page-list{
    display:flex;
    flex-direction:column;
    gap:6px;
  }

  .page-item{
    padding:8px 10px;
    background:#f3f4f6;
    border:1px solid #e5e7eb;
    border-radius:8px;
    cursor:pointer;
    font-size:14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
  }
  .page-item.active{
    background:var(--primary);
    border-color:var(--primary);
    color:#fff;
  }
  
  .panel-section{ margin-top:16px; }

  .right-panel label{
    font-size:13px;
    margin-top:10px;
    display:block;
  }

  .right-panel input,
  .right-panel textarea,
  .right-panel select{
    width:100%;
    padding:10px;
    margin-top:4px;
    border-radius:8px;
    border:1px solid #ccc;
    background:#fff;
  }

  hr.sep{
    border:none;
    border-top:1px solid #eee;
    margin:16px 0;
  }
</style>

<div class="builder-wrap">

  <!-- SIDEBAR -->
  <aside class="sidebar">
    <h2>Builder</h2>

    <div>
      <button class="element-btn" type="button" data-type="text">📝 Tekst</button>
      <button class="element-btn" type="button" data-type="image">🖼️ Afbeelding</button>
      <button class="element-btn" type="button" data-type="question">❓ Vraag</button>
      <button class="element-btn" type="button" data-type="location">📍 Locatie</button>
    </div>

    <div class="sidebar-actions">
      <button class="btn" type="button" id="btn-reset">Reset</button>
      <button class="btn btn-primary" type="button" id="btn-save">Opslaan</button>
    </div>
  </aside>

  <!-- MIDDEN / TELEFOON CANVAS -->
  <section class="canvas">
    <div class="phone" id="phone" data-id="<%= puzzle._id %>">
      <div class="phone-header">
        <strong id="app-title"><%= puzzle.name %></strong>
        <span id="page-title-label"></span>
      </div>
    </div>
  </section>

  <!-- RECHTERPANEEL -->
  <aside class="right-panel" id="right-panel">

    <div>
      <h3>Paginas</h3>
      <div id="page-list" class="page-list"></div>

      <button id="add-page-btn" class="btn" type="button" style="margin-top:10px;">
        + Nieuwe pagina
      </button>

      <div class="panel-section">

        <!-- PAGINA TITEL -->
        <label>Paginatitel</label>
        <input id="page-title-input" type="text" placeholder="Paginatitel" />

        <!-- SHOW NEXT PAGE -->
        <label style="display:flex; align-items:center; gap:8px; margin-top:10px;">
          <input id="page-shownext" type="checkbox" />
          Toon “Volgende pagina”-knop
        </label>

        <!-- IS MAP -->
        <label style="display:flex; align-items:center; gap:8px; margin-top:10px;">
          <input id="page-ismap" type="checkbox" />
          Kaartpagina (toon alleen kaart met je locatie)
        </label>

        <!-- ⭐ ALTIJD ZICHTBARE GELUIDSOPTIES ⭐ -->
        <div id="page-sound-settings"
             style="background:#f9fafb; border:1px solid #e5e7eb;
                    padding:12px; border-radius:10px; margin-top:10px;">
        
            <!-- Speel geluid bij openen pagina -->
            <label style="display:flex; align-items:center; gap:8px;">
              <input id="page-playsound-start" type="checkbox" />
              Speel geluid bij openen pagina
            </label>
        
            <!-- Geluidsbestand -->
            <div id="sound-file-section" style="margin-top:10px; display:none;">
            
              <label>Geluidsbestand</label>
            
              <div style="display:flex; gap:8px; margin-bottom:8px;">
                <input id="page-soundurl" type="text" placeholder="/uploads/sound.mp3" style="flex:1;">
            
                <button type="button" id="btn-sound-upload" class="btn-upload" style="white-space:nowrap;">
                  Uploaden
                </button>
            
                <input type="file" id="file-sound-upload" accept="audio/*" style="display:none;">
              </div>
            </div>
        </div>

        <!-- TARGET SETTINGS -->
        <div id="map-target-settings"
          style="display:none; background:#f9fafb; border:1px solid #e5e7eb; padding:12px; border-radius:10px; margin-top:10px;">

          <label style="margin-top:0;"><strong>Doellocatie (optioneel)</strong></label>
          <div class="helper" style="margin-bottom:8px;">
            Als je dit invult, gaat de app automatisch naar de volgende pagina zodra de speler binnen de radius is.
          </div>

          <div class="form-row">
            <div>
              <label>Lat</label>
              <input id="page-target-lat" type="number" step="0.000001" placeholder="bijv. 52.123">
            </div>
            <div>
              <label>Lng</label>
              <input id="page-target-lng" type="number" step="0.000001" placeholder="bijv. 5.123">
            </div>
          </div>

          <label>Radius (meters)</label>
          <input id="page-target-radius" type="number" step="1" value="50">
        </div>

        <div id="map-extra-options" style="display:none; margin-top:10px;">

          <label style="display:flex; align-items:center; gap:8px; margin-top:10px;">
            <input id="page-showtarget" type="checkbox" />
            Toon doellocatie aan speler
          </label>

          <label style="display:flex; align-items:center; gap:8px; margin-top:8px;">
            <input id="page-autonext" type="checkbox" />
            Ga automatisch naar volgende pagina bij binnen radius
          </label>
        </div>

        <!-- DELETE PAGE -->
        <div style="display:flex; gap:8px; margin-top:12px;">
          <button id="delete-page-btn" class="btn" type="button"
            style="background:#fee2e2; color:#991b1b; border-color:#fecaca;">
            Pagina verwijderen
          </button>
        </div>

        <div id="page-warning"
          style="display:none; background:#fee2e2; color:#991b1b; border:1px solid #fecaca;
                 border-radius:10px; padding:10px; margin-top:10px;">
          Je kunt de laatste pagina niet verwijderen.
        </div>

      </div>
    </div>

    <hr class="sep">

    <!-- BLOKINSTELLINGEN -->
    <div class="panel-section">
      <h3>Blok‑instellingen</h3>
      <small id="panel-empty">Selecteer een blok om te bewerken.</small>

      <div id="panel-fields" style="display:none;">
        <label>Type</label>
        <input id="panel-type" disabled />

        <div id="panel-dynamic" style="margin-top:8px;"></div>
      </div>
    </div>

  </aside>
</div> <!-- einde .builder-wrap -->

<script>
(function(){
  const phone = document.getElementById("phone");
  if(!phone) return;

  const qs  = (s,p=document)=>p.querySelector(s);
  const qsa = (s,p=document)=>Array.from(p.querySelectorAll(s));

  let pages = JSON.parse(`<%- JSON.stringify(pagesSafe) %>`);
  if(!Array.isArray(pages) || !pages.length){
    pages = [{
      title:"Pagina 1",
      showNext:true,
      isMap:false,
      showTarget:true,
      autoNext:false,
      playSound:false,
      soundUrl:"",
      modules:[]
    }];
  }

  let currentPage = 0;
  let selected = null;
  let dragged = null;

  function mapGoogleDriveUrl(url){
    try{
      const u = new URL(url);
      if (u.hostname.includes("drive.google.com")) {
        const m = u.pathname.match(/\/file\/d\/([^/]+)/);
        if (m && m[1]) return `https://drive.google.com/uc?export=view&id=${m[1]}`;
        const id = u.searchParams.get("id");
        if (id) return `https://drive.google.com/uc?export=view&id=${id}`;
      }
    } catch {}
    return url;
  }

  function setPageTitleUI(){
    const page = pages[currentPage];

    const title = page?.title || ("Pagina " + (currentPage+1));
    const isMap = !!page?.isMap;

    qs("#page-title-label").textContent = title;
    qs("#page-title-input").value = title;

    qs("#page-shownext").checked = !!page.showNext;
    qs("#page-ismap").checked = !!page.isMap;
    qs("#page-playsound-start").checked = !!page.playSoundOnStart;
    qs("#map-extra-options").style.display = page.isMap ? "block" : "none";

    // --- NIEUWE VELDEN ---
    qs("#page-showtarget").checked = !!page.showTarget;
    qs("#page-autonext").checked = !!page.autoNext;
    qs("#page-soundurl").value   = page.soundUrl || "";
    qs("#sound-file-section").style.display =
      page.playSoundOnStart ? "block" : "none";

    // Bestaande targetvelden
    qs("#page-target-lat").value = page?.targetLat ?? "";
    qs("#page-target-lng").value = page?.targetLng ?? "";
    qs("#page-target-radius").value = page?.targetRadius ?? 50;

    // Toon/verberg target-instellingen als 'isMap' aan staat
    qs("#map-target-settings").style.display = isMap ? "block" : "none";
  }

  function renderPageList(){
    const wrap = qs("#page-list");
    wrap.innerHTML = "";

    pages.forEach((p,i)=>{
      const item = document.createElement("div");
      item.className = "page-item" + (i===currentPage ? " active" : "");
      item.dataset.page = i;
      item.innerHTML = `<span>${p.title?.trim() ? p.title : ("Pagina " + (i+1))}</span>`;
      item.addEventListener("click", ()=> switchPage(i));
      wrap.appendChild(item);
    });
  }

  function clearBlocks(){
    qsa(".block", phone).forEach(b => b.remove());
  }

  function renderPage(idx){
    clearBlocks();
    const pg = pages[idx];

    // --- MAP PREVIEW-MODUS ---
    if (pg.isMap === true) {
      const info = document.createElement("div");
      info.className = "block";
      info.dataset.type = "__preview__";
      info.draggable = false;
      info.style.borderStyle = "dashed";

      info.innerHTML = `
        <h4>
          <span>Kaartpagina</span>
          <span class="kind">map</span>
        </h4>
        <div class="helper">
          In de speler zie je een live kaart met je huidige locatie.
          Modules op deze pagina worden genegeerd.
        </div>

        <div class="map-target-preview"
          style="margin-top:8px; background:#f9fafb; border:1px solid #e5e7eb;
                 padding:10px; border-radius:10px;">
          <div class="helper">Nog geen doel ingesteld.</div>
        </div>

        <!-- NIEUW: indicatoren voor opties -->
        <div style="margin-top:10px; font-size:13px; color:#555;">
          <div>🎯 Doel zichtbaar: <strong>${pg.showTarget ? "ja" : "nee"}</strong></div>
          <div>⏭ Automatisch door: <strong>${pg.autoNext ? "ja" : "nee"}</strong></div>
          ${pg.soundUrl ? `<div>📁 Geluid: <code>${pg.soundUrl}</code></div>` : ""}
        </div>
      `;

      phone.appendChild(info);

      setPageTitleUI();
      clearPanel();
      updateMapPreview(); 
      return;
    }

    // --- NORMALE PAGINA: MODULES ---
    (pg.modules || []).forEach(m=>{
      const block = createBlock(m.type);
      phone.appendChild(block);

      const data = m.data || {};

      if(m.type==="text"){
        qs('[data-field="text"]', block).innerHTML = data?.text || "Nieuwe tekst";
      }

      if(m.type==="image"){
        const url = data?.url || "";
        const inp = qs('input[data-field="url"]', block);
        inp.value = url;

        if(url){
          const img = document.createElement("img");
          img.className = "preview";
          img.src = url;
          img.style.width = "100%";
          img.style.borderRadius = "10px";
          qs(".content", block).appendChild(img);
        } else {
          const helper = document.createElement("div");
          helper.className = "helper";
          helper.textContent = "Voeg een afbeelding URL toe of upload.";
          qs(".content", block).appendChild(helper);
        }
      }

      if(m.type==="question"){
        qs('[data-field="question"]', block).value = data?.question || "";
        qs('[data-field="questionType"]', block).value = data?.questionType || "open";
      
        const openWrap = qs('[data-open]', block);
        const mcWrap   = qs('[data-mc]', block);
      
        if(data?.questionType === "mc"){
          openWrap.style.display = "none";
          mcWrap.style.display = "block";
      
          qsa('[data-option]', mcWrap).forEach((opt, i) => {
            opt.querySelector('[data-text]').value =
              data?.options?.[i]?.text || "";
            opt.querySelector('[data-correct]').checked =
              !!data?.options?.[i]?.correct;
          });
        } else {
          openWrap.style.display = "block";
          mcWrap.style.display = "none";
          qs('[data-field="answer"]', block).value = data?.answer || "";
        }
      
        qs('[data-field="goodPage"]', block).value =
          Number.isInteger(data?.goodPage) ? data.goodPage : "";
        qs('[data-field="badPage"]', block).value =
          Number.isInteger(data?.badPage) ? data.badPage : "";
      }

      if(m.type==="location"){
        qs('[data-field="lat"]',    block).value = data?.lat ?? "";
        qs('[data-field="lng"]',    block).value = data?.lng ?? "";
        qs('[data-field="radius"]', block).value = data?.radius ?? 50;
      }
    });

    setPageTitleUI();
    clearPanel();
  }

function savePageSettings() {
  const pg = pages[currentPage];

  pg.title        = qs("#page-title-input").value;
  pg.showNext     = qs("#page-shownext").checked;
  pg.isMap        = qs("#page-ismap").checked;

  // nieuwe velden
  pg.showTarget   = qs("#page-showtarget").checked;
  pg.autoNext     = qs("#page-autonext").checked;
  pg.playSoundOnStart = qs("#page-playsound-start").checked;
  pg.soundUrl     = qs("#page-soundurl").value;

  // target velden
  pg.targetLat    = qs("#page-target-lat").value !== "" ? Number(qs("#page-target-lat").value) : null;
  pg.targetLng    = qs("#page-target-lng").value !== "" ? Number(qs("#page-target-lng").value) : null;
  pg.targetRadius = qs("#page-target-radius").value !== "" ? Number(qs("#page-target-radius").value) : 50;
}

function switchPage(nextIndex){
    savePageSettings();
    pages[currentPage].modules = collect();
    currentPage = nextIndex;
    renderPageList();
    renderPage(currentPage);
}

  function addPage(){
    pages.push({
      title:"Nieuwe pagina",
      showNext:true,
      isMap:false,
      showTarget:true,
      autoNext:false,
      playSound:false,
      soundUrl:"",
      modules:[]
    });
    currentPage = pages.length - 1;
    renderPageList();
    renderPage(currentPage);
  }

  function deletePage(){
    if(pages.length <= 1){
      const warn = qs("#page-warning");
      warn.style.display = "block";
      setTimeout(()=> warn.style.display="none", 1800);
      return;
    }

    pages.splice(currentPage, 1);
    currentPage = Math.max(0, currentPage - 1);

    renderPageList();
    renderPage(currentPage);
  }
function createBlock(type){
    const div = document.createElement("div");
    div.className = "block";
    div.draggable = true;
    div.dataset.type = type;

    div.innerHTML = `
      <button class="remove" type="button">×</button>
      <h4>
        <span>${type[0].toUpperCase() + type.slice(1)}</span>
        <span class="kind">${type}</span>
      </h4>
      <div class="content"></div>
    `;

    const content = qs(".content", div);

    if(type === "text"){
      content.innerHTML = `
        <div contenteditable="true" data-field="text">Nieuwe tekst</div>
      `;
    }

    if(type === "image"){
      content.innerHTML = `
        <div style="display:flex; gap:8px; margin-bottom:8px;">
          <input type="url" data-field="url" placeholder="Afbeeldings-URL" style="flex:1;">
          <button type="button" class="btn-upload" style="white-space:nowrap;">Uploaden</button>
          <input type="file" accept="image/*" class="file-hidden" style="display:none;">
        </div>
        <div class="helper">Voeg een URL toe of upload een afbeelding.</div>
      `;
    }

    if(type === "question"){
      content.innerHTML = `
        <label>Vraag:</label>
        <input data-field="question">
    
        <label>Vraagtype:</label>
        <select data-field="questionType">
          <option value="open">Open vraag</option>
          <option value="mc">Multiple choice</option>
        </select>
    
        <div data-mc style="display:none; margin-top:8px;">
          <label>Antwoordopties</label>
    
          <div data-option style="display:grid; gap:4px; margin-bottom:10px;">
            <label style="font-size:12px; color:#6b7280;">Juist</label>
          
            <div style="display:flex; align-items:center; gap:8px;">
              <input
                data-text
                placeholder="Antwoord"
                style="flex:1;"
              >
              <input type="checkbox" data-correct>
            </div>
          </div>
    
        <div data-open>
          <label>Antwoord:</label>
          <input data-field="answer">
        </div>
    
        <input type="hidden" data-field="goodPage">
        <input type="hidden" data-field="badPage">
      `;
    }

    if(type === "location"){
      content.innerHTML = `
        <div class="form-row">
          <input type="number" step="0.000001" placeholder="Lat" data-field="lat">
          <input type="number" step="0.000001" placeholder="Lng" data-field="lng">
        </div>
        <input type="number" step="1" placeholder="Radius" data-field="radius" value="50">
      `;
    }

    wireBlock(div);
    return div;
  }

  function addBlock(type){
    const block = createBlock(type);
    phone.appendChild(block);
    setSelected(block);
  }

  // Sidebar buttons
  qsa(".element-btn").forEach(btn=>{
    btn.addEventListener("click", () => addBlock(btn.dataset.type));
  });

  function getAfterEl(container, y){
    const blocks = qsa(".block:not(.dragging)", container);

    return blocks.reduce((closest, child)=>{
      const box = child.getBoundingClientRect();
      const offset = y - (box.top + box.height / 2);

      if(offset < 0 && offset > closest.offset){
        return { offset, element: child };
      }
      return closest;
    }, { offset:-Infinity, element:null }).element;
  }

  phone.addEventListener("dragover", (e)=>{
    if(!dragged) return;
    e.preventDefault();

    const after = getAfterEl(phone, e.clientY);
    if(after == null) phone.appendChild(dragged);
    else phone.insertBefore(dragged, after);
  });

  function wireBlock(block){
    // Drag
    block.addEventListener("dragstart", (e)=>{
      dragged = block;
      block.classList.add("dragging");

      if(e.dataTransfer){
        e.dataTransfer.setData("text/plain", "");
        e.dataTransfer.effectAllowed = "move";
      }
    });

    block.addEventListener("dragend", ()=>{
      block.classList.remove("dragging");
      dragged = null;
    });

    // IMAGE INPUT HANDLING
    block.addEventListener("input", (e)=>{
      if(e.target.matches('input[data-field="url"]')){
        const url = e.target.value.trim();
        const oldImg = qs("img.preview", block);
        const helper = qs(".helper", block);

        if(url){
          if(oldImg){
            oldImg.src = url;
          } else {
            const img = document.createElement("img");
            img.className = "preview";
            img.src = url;
            img.style.width = "100%";
            img.style.borderRadius = "10px";

            if(helper) helper.replaceWith(img);
            else qs(".content", block).appendChild(img);
          }
        } else if(oldImg){
          const h = document.createElement("div");
          h.className = "helper";
          h.textContent = "Voeg een afbeelding URL toe of upload.";

          oldImg.replaceWith(h);
        }
      }
    });

    // UPLOAD LOGIC
    const uploadBtn = block.querySelector(".btn-upload");
    const fileInput = block.querySelector(".file-hidden");
    const urlInput  = block.querySelector('input[data-field="url"]');

    if(uploadBtn && fileInput && urlInput){
      uploadBtn.addEventListener("click", ()=> fileInput.click());

      fileInput.addEventListener("change", async () => {
        const file = fileInput.files?.[0];
        if(!file) return;

        const fd = new FormData();
        fd.append("file", file);

        try {
          const res = await fetch("/admin-upload-media", {
            method: "POST",
            body: fd
          });
          if(!res.ok) throw new Error(await res.text());

          const json = await res.json();
          urlInput.value = json.url;
          urlInput.dispatchEvent(new Event("input"));
        }
        catch(err){
          console.error(err);
          alert("Upload mislukt");
        }
        finally {
          fileInput.value = "";
        }
      });

      urlInput.addEventListener("change", ()=>{
        const raw = urlInput.value.trim();
        const mapped = mapGoogleDriveUrl(raw);

        if(mapped !== raw){
          urlInput.value = mapped;
          urlInput.dispatchEvent(new Event("input"));
        }
      });
    }

    // BLOCK SELECTION
    block.addEventListener("click", ()=>{
      setSelected(block);
    });
  }

  phone.addEventListener("click", (e)=>{
    if(e.target.classList.contains("remove")){
      const bl = e.target.closest(".block");
      if(bl){
        if(selected === bl) clearPanel();
        bl.remove();
      }
    }
  });

  document.addEventListener("dragstart", ()=> document.body.style.userSelect = "none");
  document.addEventListener("dragend",   ()=> document.body.style.userSelect = "");
const pEmpty = qs("#panel-empty");
  const pFields = qs("#panel-fields");
  const pType = qs("#panel-type");
  const pDyn = qs("#panel-dynamic");

  function buildPageSelect(id){
    const sel = document.createElement("select");
    sel.id = id;

    const opt0 = document.createElement("option");
    opt0.value = "";
    opt0.textContent = "— kies pagina —";
    sel.appendChild(opt0);

    pages.forEach((p, idx) => {
      const opt = document.createElement("option");
      opt.value = String(idx);
      opt.textContent = `${idx+1}. ${p.title?.trim() ? p.title : "Pagina " + (idx+1)}`;
      sel.appendChild(opt);
    });

    return sel;
  }

  function setSelected(block){
    selected = block;

    pEmpty.style.display = "none";
    pFields.style.display = "block";
    pDyn.innerHTML = "";

    const type = block.dataset.type;
    pType.value = type;

    // TEXT BLOCK
    if(type === "text"){
      const src = qs('[data-field="text"]', block);

      pDyn.innerHTML = `
        <label>Tekst</label>
        <textarea id="p-text" rows="4"></textarea>
      `;

      const ta = qs("#p-text");
      ta.value = src?.innerHTML || "";

      ta.oninput = () => {
        if(src) src.innerHTML = ta.value;
      };
    }

    // IMAGE BLOCK
    if(type === "image"){
      const src = qs('input[data-field="url"]', block);

      pDyn.innerHTML = `
        <label>Afbeeldings‑URL</label>
        <input id="p-url" type="url" placeholder="https://...">
      `;

      const inp = qs("#p-url");
      inp.value = src?.value || "";

      inp.oninput = () => {
        if(src){
          src.value = mapGoogleDriveUrl(inp.value);
          src.dispatchEvent(new Event("input"));
        }
      };
    }

    // QUESTION BLOCK
    if(type === "question"){
      const q = qs('[data-field="question"]', block);
      const qt = qs('[data-field="questionType"]', block);
      const openWrap = qs('[data-open]', block);
      const mcWrap = qs('[data-mc]', block);
    
      pDyn.innerHTML = "";
    
      // Vraag
      pDyn.innerHTML += `<label>Vraag</label><input id="p-q">`;
      qs("#p-q").value = q.value;
      qs("#p-q").oninput = () => q.value = qs("#p-q").value;
    
      // Vraagtype
      pDyn.innerHTML += `
        <label>Vraagtype</label>
        <select id="p-qt">
          <option value="open">Open vraag</option>
          <option value="mc">Multiple choice</option>
        </select>
      `;
      qs("#p-qt").value = qt.value || "open";
    
      const syncType = () => {
        const v = qs("#p-qt").value;
        qt.value = v;
        openWrap.style.display = v === "open" ? "block" : "none";
        mcWrap.style.display   = v === "mc"   ? "block" : "none";
      };
      qs("#p-qt").onchange = syncType;
      syncType();
    
      // Antwoorden MC syncen
      qsa('[data-option]', mcWrap).forEach((opt, i) => {
        const text = opt.querySelector('[data-text]');
        const correct = opt.querySelector('[data-correct]');
        text.oninput = correct.onchange = () => {};
      });
    }

    // LOCATION BLOCK
    if(type === "location"){
      const lat = qs('input[data-field="lat"]', block);
      const lng = qs('input[data-field="lng"]', block);
      const r   = qs('input[data-field="radius"]', block);

      pDyn.innerHTML = `
        <div class="form-row">
          <div>
            <label>Lat</label>
            <input id="p-lat" type="number" step="0.000001">
          </div>
          <div>
            <label>Lng</label>
            <input id="p-lng" type="number" step="0.000001">
          </div>
        </div>

        <label>Radius</label>
        <input id="p-r" type="number" step="1">
      `;

      qs("#p-lat").value = lat?.value || "";
      qs("#p-lng").value = lng?.value || "";
      qs("#p-r").value   = r?.value   || 50;

      qs("#p-lat").oninput = () => { if(lat) lat.value = qs("#p-lat").value; };
      qs("#p-lng").oninput = () => { if(lng) lng.value = qs("#p-lng").value; };
      qs("#p-r").oninput   = () => { if(r)   r.value   = qs("#p-r").value;   };
    }
  }

  function clearPanel(){
    selected = null;
    pEmpty.style.display = "block";
    pFields.style.display = "none";
    pDyn.innerHTML = "";
  }
function collect(){
    const blocks = qsa(".block", phone).filter(b => {
      const t = (b.dataset.type || "").trim();
      return t && t !== "__preview__";
    });

    return blocks.map(b=>{
      const type = b.dataset.type;
      const data = {};

      if(type === "text"){
        data.text = qs('[data-field="text"]', b)?.innerHTML || "";
      }

      if(type === "image"){
        data.url = qs('input[data-field="url"]', b)?.value?.trim() || "";
      }

      if(type === "question"){
        data.question = qs('[data-field="question"]', b)?.value || "";
        data.questionType = qs('[data-field="questionType"]', b)?.value || "open";
      
        if(data.questionType === "open"){
          data.answer = qs('[data-field="answer"]', b)?.value || "";
        } else {
          data.options = qsa('[data-option]', b).map(opt => ({
            text: opt.querySelector('[data-text]')?.value || "",
            correct: !!opt.querySelector('[data-correct]')?.checked
          }));
        }
      
        data.goodPage = Number(qs('[data-field="goodPage"]', b)?.value) || null;
        data.badPage  = Number(qs('[data-field="badPage"]',  b)?.value) || null;
      }

      if(type === "location"){
        const lat = qs('input[data-field="lat"]', b)?.value;
        const lng = qs('input[data-field="lng"]', b)?.value;
        const rad = qs('input[data-field="radius"]', b)?.value;

        data.lat    = lat !== "" ? Number(lat) : null;
        data.lng    = lng !== "" ? Number(lng) : null;
        data.radius = rad !== "" ? Number(rad) : 50;
      }

      return { type, data };
    });
  }

  async function saveAll(){
    savePageSettings();
    pages[currentPage].modules = collect();

    const id = phone.dataset.id;

    try{
      const res = await fetch(`/admin-builder/${id}/save-all`, {
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ pages })
      });

      if(!res.ok) throw new Error(await res.text());
      toast("Opgeslagen ✅");
    }
    catch(err){
      console.error(err);
      toast("Opslaan mislukt ❌", true);
    }
  }

  function resetPage(){
    location.reload();
  }

  qs("#btn-save").addEventListener("click", saveAll);
  qs("#btn-reset").addEventListener("click", resetPage);

  qs("#add-page-btn").addEventListener("click", addPage);
  qs("#delete-page-btn").addEventListener("click", deletePage);

  // PAGE INPUT HANDLERS
  qs("#page-title-input").addEventListener("input", ()=>{
    pages[currentPage].title = qs("#page-title-input").value;
    qs("#page-title-label").textContent = pages[currentPage].title;
    renderPageList();
  });

  qs("#page-shownext").addEventListener("change", ()=>{
    pages[currentPage].showNext = !!qs("#page-shownext").checked;
  });

  qs("#page-ismap").addEventListener("change", () => {
    const isMap = !!qs("#page-ismap").checked;
    pages[currentPage].isMap = isMap;

    // Extra opties tonen of verbergen
    qs("#map-extra-options").style.display = isMap ? "block" : "none";

    renderPage(currentPage);
  });

  // NIEUW: SHOW TARGET
  qs("#page-showtarget").addEventListener("change", ()=>{
    pages[currentPage].showTarget = !!qs("#page-showtarget").checked;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // NIEUW: AUTO NEXT
  qs("#page-autonext").addEventListener("change", ()=>{
    pages[currentPage].autoNext = !!qs("#page-autonext").checked;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // NIEUW: PLAY SOUND
  qs("#page-playsound-start").addEventListener("change", () => {
    const checked = qs("#page-playsound-start").checked;
    pages[currentPage].playSoundOnStart = checked;
  
    // toon/verberg geluidsbestand
    qs("#sound-file-section").style.display = checked ? "block" : "none";
  });

  // NIEUW: SOUND URL
  qs("#page-soundurl").addEventListener("input", ()=>{
    pages[currentPage].soundUrl = qs("#page-soundurl").value;
    if(pages[currentPage].isMap) updateMapPreview();
  });

  // TARGET INPUTS
  qs("#page-target-lat").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetLat = v !== "" ? Number(v) : null;
    updateMapPreview();
  });

  qs("#page-target-lng").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetLng = v !== "" ? Number(v) : null;
    updateMapPreview();
  });

  qs("#page-target-radius").addEventListener("input", (e)=>{
    const v = e.target.value;
    pages[currentPage].targetRadius = v !== "" ? Number(v) : 50;
    updateMapPreview();
  });


  // --- MINI MAP PREVIEW (tekst + canvas) ---
  function updateMapPreview(){
    const pg = pages[currentPage];
    if(!pg?.isMap) return;

    const wrap = phone.querySelector(".map-target-preview");
    if(!wrap) return;

    const hasCoords = (
      pg.targetLat !== null && pg.targetLat !== "" &&
      pg.targetLng !== null && pg.targetLng !== ""
    );

    if(!hasCoords){
      wrap.innerHTML = `<div class="helper">Nog geen doel ingesteld.</div>`;
      return;
    }

    const lat = Number(pg.targetLat);
    const lng = Number(pg.targetLng);
    const radius = Number(pg.targetRadius || 50);

    const latTxt = isFinite(lat) ? lat.toFixed(6) : "—";
    const lngTxt = isFinite(lng) ? lng.toFixed(6) : "—";

    wrap.innerHTML = `
      <div style="display:flex; gap:12px; align-items:center;">
        <canvas id="map-mini" width="160" height="160"
          style="border:1px solid #e5e7eb; border-radius:10px; background:#fff;">
        </canvas>

        <div style="display:flex; flex-direction:column; gap:6px;">
          <div><strong>Doellocatie</strong></div>

          <div style="font-family: ui-monospace, monospace;">
            Lat: ${latTxt}<br>
            Lng: ${lngTxt}
          </div>

          <div>Radius: <strong>${radius}</strong> meter</div>

          <div class="helper">
            De speler gaat automatisch verder als je binnen de radius komt (indien optie aanstaat).
          </div>
        </div>
      </div>
    `;

    const cv = wrap.querySelector("#map-mini");
    const ctx = cv?.getContext("2d");

    if(ctx){
      ctx.clearRect(0,0,cv.width,cv.height);

      ctx.fillStyle = "#ffffff";
      ctx.fillRect(0,0,cv.width,cv.height);

      ctx.fillStyle = "#eef2ff";
      ctx.strokeStyle = "#6366f1";
      ctx.lineWidth = 2;

      const rMin = 10, rMax = 70;
      const pxRadius = Math.max(rMin, Math.min(rMax, radius / 5));
      const cx = cv.width/2;
      const cy = cv.height/2;

      ctx.beginPath();
      ctx.arc(cx, cy, pxRadius, 0, Math.PI*2);
      ctx.fill();
      ctx.stroke();

      ctx.fillStyle = "#111827";
      ctx.beginPath();
      ctx.arc(cx, cy, 3, 0, Math.PI*2);
      ctx.fill();
    }
  }
// --- TOAST MECHANISME ---
  function toast(msg, error=false){
    const t = document.createElement("div");
    t.textContent = msg;

    Object.assign(t.style, {
      position: 'fixed',
      right: '20px',
      bottom: '20px',
      background: error ? '#ef4444' : 'var(--primary)',
      color: '#fff',
      padding: '10px 14px',
      borderRadius: '12px',
      boxShadow: '0 8px 24px rgba(0,0,0,.2)',
      zIndex: '9999',
      fontSize: '14px'
    });

    document.body.appendChild(t);

    setTimeout(() => t.remove(), 2000);
  }
  // --- SOUND UPLOAD LOGICA ---
  const soundUploadBtn = qs("#btn-sound-upload");
  const soundFileInput = qs("#file-sound-upload");
  const soundUrlInput  = qs("#page-soundurl");

  if (soundUploadBtn && soundFileInput && soundUrlInput) {

    // Open file selector
    soundUploadBtn.addEventListener("click", () => {
      soundFileInput.click();
    });

    // Upload bestand
    soundFileInput.addEventListener("change", async () => {
      const file = soundFileInput.files?.[0];
      if (!file) return;

      const fd = new FormData();
      fd.append("file", file); // zelfde endpoint werkt voor audio

      try {
        const res = await fetch("/admin-upload-media", {
          method: "POST",
          body: fd
        });

        if (!res.ok) throw new Error(await res.text());

        const json = await res.json();
        soundUrlInput.value = json.url;

        // opslaan in live data
        pages[currentPage].soundUrl = json.url;

        toast("Geluid geüpload 🎵");
      }
      catch (err) {
        console.error(err);
        alert("Upload mislukt");
      }
      finally {
        soundFileInput.value = "";
      }
    });
  }

  // INIT
  renderPageList();
  renderPage(currentPage);

  function playSoundIfNeeded() {
    const pg = pages[currentPage];
    if (!pg?.playSoundOnStart) return;
    if (!pg?.soundUrl) return;

    const audio = new Audio(pg.soundUrl);
    audio.play().catch(err => {
      console.warn("Autoplay geblokkeerd door browser:", err);
    });
  }

})(); // einde IIFE
</script>
